module Main export (main) {
  import Prelude exposing (Unit(..), IO, bind, putStrLn);
  import SeedContract exposing (FrontendSeedContract(..), acceptsFrontendSeedContract, frontendSeedContract);
  import SeedLexer exposing (renderLexerEvidence, lexerEvidence);
  import SeedParser exposing (renderParserEvidence, parserEvidence);

  def main : IO Unit =
    bind (putStrLn (renderLexerEvidence lexerEvidence))
      (λ(_lexerEvidencePrinted : Unit) putStrLn (renderParserEvidence parserEvidence));
}
