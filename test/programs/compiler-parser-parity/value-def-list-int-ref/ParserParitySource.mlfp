module ParserParitySource export (SourceSpan(..), SourceCursor(..), valueDefListSourceFile, valueDefListSourceText, moduleSpan, moduleKeywordSpan, moduleNameSpan, exportKeywordSpan, exportLeftParenSpan, exportMainSpan, exportRightParenSpan, moduleLeftBraceSpan, importKeywordSpan, importModuleSpan, exposingKeywordSpan, importLeftParenSpan, importIntSpan, importRightParenSpan, importSemicolonSpan, firstDefKeywordSpan, firstDefNameSpan, firstDefColonSpan, firstDefIntTypeSpan, firstDefEqualsSpan, firstDefIntLiteralSpan, firstDefSemicolonSpan, secondDefKeywordSpan, secondDefNameSpan, secondDefColonSpan, secondDefIntTypeSpan, secondDefEqualsSpan, secondDefValueRefSpan, secondDefSemicolonSpan, moduleRightBraceSpan, defTwoSpan, defMainSpan, unexpectedSpan, renderSpan) {
  import Prelude exposing (stringAppend);

  data SourceSpan =
      SourceSpan : String -> SourceSpan;

  data SourceCursor =
      SourceCursor : String -> SourceCursor;

  def valueDefListSourceFile : String =
    "test/conformance/mlfp/parser-parity/value-def-list-int-ref/src/Main.mlfp";

  def valueDefListSourceText : String =
    "module Main export (main) {\n  import Prelude exposing (Int);\n  def two : Int = 2;\n  def main : Int = two;\n}\n";

  def moduleSpan : SourceSpan =
    SourceSpan "1:1-6:1";

  def moduleKeywordSpan : SourceSpan =
    SourceSpan "1:1-1:7";

  def moduleNameSpan : SourceSpan =
    SourceSpan "1:8-1:12";

  def exportKeywordSpan : SourceSpan =
    SourceSpan "1:13-1:19";

  def exportLeftParenSpan : SourceSpan =
    SourceSpan "1:20-1:21";

  def exportMainSpan : SourceSpan =
    SourceSpan "1:21-1:25";

  def exportRightParenSpan : SourceSpan =
    SourceSpan "1:25-1:26";

  def moduleLeftBraceSpan : SourceSpan =
    SourceSpan "1:27-1:28";

  def importKeywordSpan : SourceSpan =
    SourceSpan "2:3-2:9";

  def importModuleSpan : SourceSpan =
    SourceSpan "2:10-2:18";

  def exposingKeywordSpan : SourceSpan =
    SourceSpan "2:18-2:26";

  def importLeftParenSpan : SourceSpan =
    SourceSpan "2:27-2:28";

  def importIntSpan : SourceSpan =
    SourceSpan "2:28-2:31";

  def importRightParenSpan : SourceSpan =
    SourceSpan "2:31-2:32";

  def importSemicolonSpan : SourceSpan =
    SourceSpan "2:32-2:33";

  def firstDefKeywordSpan : SourceSpan =
    SourceSpan "3:3-3:6";

  def firstDefNameSpan : SourceSpan =
    SourceSpan "3:7-3:10";

  def firstDefColonSpan : SourceSpan =
    SourceSpan "3:11-3:12";

  def firstDefIntTypeSpan : SourceSpan =
    SourceSpan "3:13-3:16";

  def firstDefEqualsSpan : SourceSpan =
    SourceSpan "3:17-3:18";

  def firstDefIntLiteralSpan : SourceSpan =
    SourceSpan "3:19-3:20";

  def firstDefSemicolonSpan : SourceSpan =
    SourceSpan "3:20-3:21";

  def secondDefKeywordSpan : SourceSpan =
    SourceSpan "4:3-4:6";

  def secondDefNameSpan : SourceSpan =
    SourceSpan "4:7-4:11";

  def secondDefColonSpan : SourceSpan =
    SourceSpan "4:12-4:13";

  def secondDefIntTypeSpan : SourceSpan =
    SourceSpan "4:14-4:17";

  def secondDefEqualsSpan : SourceSpan =
    SourceSpan "4:18-4:19";

  def secondDefValueRefSpan : SourceSpan =
