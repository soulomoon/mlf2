  def secondDefSemicolonSpan : SourceSpan =
    SourceSpan "4:23-4:24";

  def moduleRightBraceSpan : SourceSpan =
    SourceSpan "5:1-5:2";

  def defTwoSpan : SourceSpan =
    SourceSpan "3:3-4:3";

  def defMainSpan : SourceSpan =
    SourceSpan "4:3-5:1";

  def unexpectedSpan : SourceSpan =
    SourceSpan "1:1-1:1";

  def renderSpan : String -> SourceSpan -> String =
    λ(file : String) λ(span : SourceSpan) case span of {
      SourceSpan coordinates -> stringAppend file (stringAppend ":" coordinates)
    };
}
