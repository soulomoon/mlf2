module ParserParitySource export (SourceSpan(..), SourceCursor(..), letLambdaApplicationSourceFile, letLambdaApplicationSourceText, moduleSpan, moduleKeywordSpan, moduleNameSpan, exportKeywordSpan, exportLeftParenSpan, exportMainSpan, exportRightParenSpan, moduleLeftBraceSpan, importKeywordSpan, importModuleSpan, exposingKeywordSpan, importLeftParenSpan, importIntSpan, importRightParenSpan, importSemicolonSpan, defKeywordSpan, defNameSpan, defColonSpan, defIntTypeSpan, defEqualsSpan, letKeywordSpan, letBindingNameSpan, letEqualsSpan, lambdaTokenSpan, lambdaParamSpan, lambdaBodyValueRefSpan, letInSpan, appFunctionSpan, appIntLiteralSpan, defSemicolonSpan, moduleRightBraceSpan, defMainSpan, unexpectedSpan, renderSpan) {
  import Prelude exposing (stringAppend);

  data SourceSpan =
      SourceSpan : String -> SourceSpan;

  data SourceCursor =
      SourceCursor : String -> SourceCursor;

  def letLambdaApplicationSourceFile : String =
    "test/conformance/mlfp/parser-parity/let-lambda-application/src/Main.mlfp";

  def letLambdaApplicationSourceText : String =
    "module Main export (main) {\n  import Prelude exposing (Int);\n  def main : Int = let id = λx x in id 1;\n}\n";

  def moduleSpan : SourceSpan =
    SourceSpan "1:1-5:1";

  def moduleKeywordSpan : SourceSpan =
    SourceSpan "1:1-1:7";

  def moduleNameSpan : SourceSpan =
    SourceSpan "1:8-1:12";

  def exportKeywordSpan : SourceSpan =
    SourceSpan "1:13-1:19";

  def exportLeftParenSpan : SourceSpan =
    SourceSpan "1:20-1:21";

  def exportMainSpan : SourceSpan =
    SourceSpan "1:21-1:25";

  def exportRightParenSpan : SourceSpan =
    SourceSpan "1:25-1:26";

  def moduleLeftBraceSpan : SourceSpan =
    SourceSpan "1:27-1:28";

  def importKeywordSpan : SourceSpan =
    SourceSpan "2:3-2:9";

  def importModuleSpan : SourceSpan =
    SourceSpan "2:10-2:18";

  def exposingKeywordSpan : SourceSpan =
    SourceSpan "2:18-2:26";

  def importLeftParenSpan : SourceSpan =
    SourceSpan "2:27-2:28";

  def importIntSpan : SourceSpan =
    SourceSpan "2:28-2:31";

  def importRightParenSpan : SourceSpan =
    SourceSpan "2:31-2:32";

  def importSemicolonSpan : SourceSpan =
    SourceSpan "2:32-2:33";

  def defKeywordSpan : SourceSpan =
    SourceSpan "3:3-3:6";

  def defNameSpan : SourceSpan =
    SourceSpan "3:7-3:11";

  def defColonSpan : SourceSpan =
    SourceSpan "3:12-3:13";

  def defIntTypeSpan : SourceSpan =
    SourceSpan "3:14-3:17";

  def defEqualsSpan : SourceSpan =
    SourceSpan "3:18-3:19";

  def letKeywordSpan : SourceSpan =
    SourceSpan "3:20-3:23";

  def letBindingNameSpan : SourceSpan =
    SourceSpan "3:24-3:26";

  def letEqualsSpan : SourceSpan =
    SourceSpan "3:27-3:28";

  def lambdaTokenSpan : SourceSpan =
    SourceSpan "3:29-3:30";

  def lambdaParamSpan : SourceSpan =
    SourceSpan "3:30-3:31";

  def lambdaBodyValueRefSpan : SourceSpan =
    SourceSpan "3:32-3:33";

  def letInSpan : SourceSpan =
    SourceSpan "3:34-3:36";

  def appFunctionSpan : SourceSpan =
    SourceSpan "3:37-3:39";

  def appIntLiteralSpan : SourceSpan =
    SourceSpan "3:40-3:41";

  def defSemicolonSpan : SourceSpan =
    SourceSpan "3:41-3:42";

  def moduleRightBraceSpan : SourceSpan =
    SourceSpan "4:1-4:2";

  def defMainSpan : SourceSpan =
    SourceSpan "3:3-4:1";

  def unexpectedSpan : SourceSpan =
    SourceSpan "1:1-1:1";

  def renderSpan : String -> SourceSpan -> String =
    λ(file : String) λ(span : SourceSpan) case span of {
      SourceSpan coordinates -> stringAppend file (stringAppend ":" coordinates)
    };
}
