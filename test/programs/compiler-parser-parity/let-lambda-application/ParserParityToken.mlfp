module ParserParityToken export (ModuleKeywordToken(..), ModuleNameToken(..), ExportKeywordToken(..), ExportLeftParenToken(..), ExportMainToken(..), ExportRightParenToken(..), ModuleLeftBraceToken(..), ImportKeywordToken(..), ImportModuleToken(..), ExposingKeywordToken(..), ImportLeftParenToken(..), ImportIntToken(..), ImportRightParenToken(..), ImportSemicolonToken(..), DefKeywordToken(..), DefNameToken(..), DefColonToken(..), IntTypeToken(..), EqualsToken(..), LetKeywordToken(..), LetBindingNameToken(..), LetEqualsToken(..), LambdaToken(..), LambdaParamToken(..), LambdaBodyToken(..), LetInToken(..), AppFunctionToken(..), AppIntLiteralToken(..), DefSemicolonToken(..), ModuleRightBraceToken(..), HeaderPrefixTokens(..), HeaderSuffixTokens(..), ImportDeclTokens(..), LambdaExprTokens(..), AppExprTokens(..), LetExprTokens(..), DefTokens(..), TokenStream(..), LexerDiagnosticKind(..), LexerDiagnostic(..), LexerResult(..), tokenizeLetLambdaApplicationDefinition) {
  import Prelude exposing (Option(..), stringCharAtOption, stringIndexOf, stringSlice);
  import ParserParitySource exposing (SourceSpan, SourceCursor(..), moduleKeywordSpan, moduleNameSpan, exportKeywordSpan, exportLeftParenSpan, exportMainSpan, exportRightParenSpan, moduleLeftBraceSpan, importKeywordSpan, importModuleSpan, exposingKeywordSpan, importLeftParenSpan, importIntSpan, importRightParenSpan, importSemicolonSpan, defKeywordSpan, defNameSpan, defColonSpan, defIntTypeSpan, defEqualsSpan, letKeywordSpan, letBindingNameSpan, letEqualsSpan, lambdaTokenSpan, lambdaParamSpan, lambdaBodyValueRefSpan, letInSpan, appFunctionSpan, appIntLiteralSpan, defSemicolonSpan, moduleRightBraceSpan, unexpectedSpan);

  data ModuleKeywordToken =
      ModuleKeywordTok : SourceSpan -> ModuleKeywordToken;

  data ModuleNameToken =
      ModuleNameTok : SourceSpan -> ModuleNameToken;

  data ExportKeywordToken =
      ExportKeywordTok : SourceSpan -> ExportKeywordToken;

  data ExportLeftParenToken =
      ExportLeftParenTok : SourceSpan -> ExportLeftParenToken;

  data ExportMainToken =
      ExportMainTok : SourceSpan -> ExportMainToken;

  data ExportRightParenToken =
      ExportRightParenTok : SourceSpan -> ExportRightParenToken;

  data ModuleLeftBraceToken =
      ModuleLeftBraceTok : SourceSpan -> ModuleLeftBraceToken;

  data ImportKeywordToken =
      ImportKeywordTok : SourceSpan -> ImportKeywordToken;

  data ImportModuleToken =
      ImportModuleTok : SourceSpan -> ImportModuleToken;

  data ExposingKeywordToken =
      ExposingKeywordTok : SourceSpan -> ExposingKeywordToken;

  data ImportLeftParenToken =
      ImportLeftParenTok : SourceSpan -> ImportLeftParenToken;

  data ImportIntToken =
      ImportIntTok : SourceSpan -> ImportIntToken;

  data ImportRightParenToken =
      ImportRightParenTok : SourceSpan -> ImportRightParenToken;

  data ImportSemicolonToken =
      ImportSemicolonTok : SourceSpan -> ImportSemicolonToken;

  data DefKeywordToken =
      DefKeywordTok : SourceSpan -> DefKeywordToken;

  data DefNameToken =
      DefMainNameTok : SourceSpan -> DefNameToken;

  data DefColonToken =
      DefColonTok : SourceSpan -> DefColonToken;

  data IntTypeToken =
      IntTypeTok : SourceSpan -> IntTypeToken;

  data EqualsToken =
      EqualsTok : SourceSpan -> EqualsToken;

  data LetKeywordToken =
      LetKeywordTok : SourceSpan -> LetKeywordToken;

  data LetBindingNameToken =
      LetBindingNameTok : SourceSpan -> LetBindingNameToken;

  data LetEqualsToken =
      LetEqualsTok : SourceSpan -> LetEqualsToken;

  data LambdaToken =
      LambdaTok : SourceSpan -> LambdaToken;

  data LambdaParamToken =
      LambdaParamTok : SourceSpan -> LambdaParamToken;

  data LambdaBodyToken =
      LambdaBodyValueRefTok : SourceSpan -> LambdaBodyToken;

  data LetInToken =
      LetInTok : SourceSpan -> LetInToken
    | MissingLetInSlot : SourceSpan -> LetInToken;

  data AppFunctionToken =
      AppFunctionIdTok : SourceSpan -> AppFunctionToken;

  data AppIntLiteralToken =
      AppIntLiteralTok : SourceSpan -> AppIntLiteralToken;

  data DefSemicolonToken =
      DefSemicolonTok : SourceSpan -> DefSemicolonToken;

  data ModuleRightBraceToken =
      ModuleRightBraceTok : SourceSpan -> ModuleRightBraceToken;

  data HeaderPrefixTokens =
      HeaderPrefixTokens : ModuleKeywordToken -> ModuleNameToken -> ExportKeywordToken -> HeaderPrefixTokens;

  data HeaderSuffixTokens =
      HeaderSuffixTokens : ExportLeftParenToken -> ExportMainToken -> ExportRightParenToken -> ModuleLeftBraceToken -> HeaderSuffixTokens;

  data ImportDeclTokens =
      ImportDeclTokens : ImportKeywordToken -> ImportModuleToken -> ExposingKeywordToken -> ImportLeftParenToken -> ImportIntToken -> ImportRightParenToken -> ImportSemicolonToken -> ImportDeclTokens;

  data LambdaExprTokens =
      LambdaExprTokens : LambdaToken -> LambdaParamToken -> LambdaBodyToken -> LambdaExprTokens;

  data AppExprTokens =
      AppExprTokens : AppFunctionToken -> AppIntLiteralToken -> AppExprTokens;

  data LetExprTokens =
      LetExprTokens : LetKeywordToken -> LetBindingNameToken -> LetEqualsToken -> LambdaExprTokens -> LetInToken -> AppExprTokens -> LetExprTokens;

  data DefTokens =
      DefTokens : DefKeywordToken -> DefNameToken -> DefColonToken -> IntTypeToken -> EqualsToken -> LetExprTokens -> DefSemicolonToken -> DefTokens;

  data TokenStream =
      TokenStream : HeaderPrefixTokens -> HeaderSuffixTokens -> ImportDeclTokens -> DefTokens -> ModuleRightBraceToken -> TokenStream;

  data LexerDiagnosticKind =
      UnexpectedSourceText : LexerDiagnosticKind;

  data LexerDiagnostic =
      LexerDiagnostic : SourceSpan -> LexerDiagnosticKind -> LexerDiagnostic;

  data LexerResult =
      LexerOk : TokenStream -> LexerResult
    | LexerError : LexerDiagnostic -> LexerResult;

  def tokenizeLetLambdaApplicationDefinition : String -> LexerResult =
    λ(source : String) tokensFromCursor (SourceCursor source);

  def tokensFromCursor : SourceCursor -> LexerResult =
    λ(cursor : SourceCursor) case cursor of {
      SourceCursor source -> lexModule source
    };

  def lexModule : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 0 6) "module" of {
      None -> LexerError (LexerDiagnostic moduleKeywordSpan UnexpectedSourceText);
      Some _ -> lexAfterModule source
    };

  def lexAfterModule : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 7 4) "Main" of {
      None -> LexerError (LexerDiagnostic moduleNameSpan UnexpectedSourceText);
      Some _ -> lexAfterModuleName source
    };

  def lexAfterModuleName : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 12 6) "export" of {
      None -> LexerError (LexerDiagnostic exportKeywordSpan UnexpectedSourceText);
      Some _ -> lexAfterExport source
    };

  def lexAfterExport : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 19 1) "(" of {
      None -> LexerError (LexerDiagnostic exportLeftParenSpan UnexpectedSourceText);
      Some _ -> lexAfterExportLeftParen source
    };

  def lexAfterExportLeftParen : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 20 4) "main" of {
      None -> LexerError (LexerDiagnostic exportMainSpan UnexpectedSourceText);
      Some _ -> lexAfterExportMain source
    };

  def lexAfterExportMain : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 24 1) ")" of {
      None -> LexerError (LexerDiagnostic exportRightParenSpan UnexpectedSourceText);
      Some _ -> lexAfterExportRightParen source
    };

  def lexAfterExportRightParen : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 26 1) "{" of {
      None -> LexerError (LexerDiagnostic moduleLeftBraceSpan UnexpectedSourceText);
      Some _ -> lexAfterModuleLeftBrace source
    };

  def lexAfterModuleLeftBrace : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 30 6) "import" of {
      None -> LexerError (LexerDiagnostic importKeywordSpan UnexpectedSourceText);
      Some _ -> lexAfterImport source
    };

  def lexAfterImport : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 37 7) "Prelude" of {
      None -> LexerError (LexerDiagnostic importModuleSpan UnexpectedSourceText);
      Some _ -> lexAfterImportModule source
    };

  def lexAfterImportModule : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 45 8) "exposing" of {
      None -> LexerError (LexerDiagnostic exposingKeywordSpan UnexpectedSourceText);
      Some _ -> lexAfterExposing source
    };

  def lexAfterExposing : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 54 1) "(" of {
      None -> LexerError (LexerDiagnostic importLeftParenSpan UnexpectedSourceText);
      Some _ -> lexAfterImportLeftParen source
    };

  def lexAfterImportLeftParen : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 55 3) "Int" of {
      None -> LexerError (LexerDiagnostic importIntSpan UnexpectedSourceText);
      Some _ -> lexAfterImportInt source
    };

  def lexAfterImportInt : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 58 1) ")" of {
      None -> LexerError (LexerDiagnostic importRightParenSpan UnexpectedSourceText);
      Some _ -> lexAfterImportRightParen source
    };

  def lexAfterImportRightParen : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 59 1) ";" of {
      None -> LexerError (LexerDiagnostic importSemicolonSpan UnexpectedSourceText);
      Some _ -> lexAfterImportSemicolon source
    };

  def lexAfterImportSemicolon : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 63 3) "def" of {
      None -> LexerError (LexerDiagnostic defKeywordSpan UnexpectedSourceText);
      Some _ -> lexAfterDef source
    };

  def lexAfterDef : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 67 4) "main" of {
      None -> LexerError (LexerDiagnostic defNameSpan UnexpectedSourceText);
      Some _ -> lexAfterDefName source
    };

  def lexAfterDefName : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 72 1) ":" of {
      None -> LexerError (LexerDiagnostic defColonSpan UnexpectedSourceText);
      Some _ -> lexAfterDefColon source
    };

  def lexAfterDefColon : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 74 3) "Int" of {
      None -> LexerError (LexerDiagnostic defIntTypeSpan UnexpectedSourceText);
      Some _ -> lexAfterDefInt source
    };

  def lexAfterDefInt : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 78 1) "=" of {
      None -> LexerError (LexerDiagnostic defEqualsSpan UnexpectedSourceText);
      Some _ -> lexAfterDefEquals source
    };

  def lexAfterDefEquals : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 80 3) "let" of {
      None -> LexerError (LexerDiagnostic letKeywordSpan UnexpectedSourceText);
      Some _ -> lexAfterLet source
    };

  def lexAfterLet : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 84 2) "id" of {
      None -> LexerError (LexerDiagnostic letBindingNameSpan UnexpectedSourceText);
      Some _ -> lexAfterLetBinding source
    };

  def lexAfterLetBinding : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 87 1) "=" of {
      None -> LexerError (LexerDiagnostic letEqualsSpan UnexpectedSourceText);
      Some _ -> lexAfterLetEquals source
    };

  def lexAfterLetEquals : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 89 1) "λ" of {
      None -> LexerError (LexerDiagnostic lambdaTokenSpan UnexpectedSourceText);
      Some _ -> lexAfterLambda source
    };

  def lexAfterLambda : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 90 1) "x" of {
      None -> LexerError (LexerDiagnostic lambdaParamSpan UnexpectedSourceText);
      Some _ -> lexAfterLambdaParam source
    };

  def lexAfterLambdaParam : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 92 1) "x" of {
      None -> LexerError (LexerDiagnostic lambdaBodyValueRefSpan UnexpectedSourceText);
      Some _ -> lexAfterLambdaBody source
    };

  def lexAfterLambdaBody : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 94 2) "in" of {
      None -> LexerError (LexerDiagnostic letInSpan UnexpectedSourceText);
      Some _ -> lexAfterLetIn source
    };

  def lexAfterLetIn : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 97 2) "id" of {
      None -> LexerError (LexerDiagnostic appFunctionSpan UnexpectedSourceText);
      Some _ -> lexAfterAppFunction source
    };

  def lexAfterAppFunction : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 100 1) "1" of {
      None -> LexerError (LexerDiagnostic appIntLiteralSpan UnexpectedSourceText);
      Some _ -> lexAfterAppIntLiteral source
    };

  def lexAfterAppIntLiteral : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 101 1) ";" of {
      None -> LexerError (LexerDiagnostic defSemicolonSpan UnexpectedSourceText);
      Some _ -> lexAfterDefSemicolon source
    };

  def lexAfterDefSemicolon : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 103 1) "}" of {
      None -> LexerError (LexerDiagnostic moduleRightBraceSpan UnexpectedSourceText);
      Some _ -> lexAfterRightBrace source
    };

  def lexAfterRightBrace : String -> LexerResult =
    λ(source : String) case stringIndexOf (stringSlice source 104 1) "\n" of {
      None -> LexerError (LexerDiagnostic unexpectedSpan UnexpectedSourceText);
      Some _ -> lexEnd source
    };

  def lexEnd : String -> LexerResult =
    λ(source : String) case stringCharAtOption source 105 of {
      None -> LexerOk letLambdaApplicationTokenStream;
      Some _ -> LexerError (LexerDiagnostic unexpectedSpan UnexpectedSourceText)
    };

  def letLambdaApplicationTokenStream : TokenStream =
    TokenStream
      (HeaderPrefixTokens
        (ModuleKeywordTok moduleKeywordSpan)
        (ModuleNameTok moduleNameSpan)
        (ExportKeywordTok exportKeywordSpan))
      (HeaderSuffixTokens
        (ExportLeftParenTok exportLeftParenSpan)
        (ExportMainTok exportMainSpan)
        (ExportRightParenTok exportRightParenSpan)
        (ModuleLeftBraceTok moduleLeftBraceSpan))
      (ImportDeclTokens
        (ImportKeywordTok importKeywordSpan)
        (ImportModuleTok importModuleSpan)
        (ExposingKeywordTok exposingKeywordSpan)
        (ImportLeftParenTok importLeftParenSpan)
        (ImportIntTok importIntSpan)
        (ImportRightParenTok importRightParenSpan)
        (ImportSemicolonTok importSemicolonSpan))
      (DefTokens
        (DefKeywordTok defKeywordSpan)
        (DefMainNameTok defNameSpan)
        (DefColonTok defColonSpan)
        (IntTypeTok defIntTypeSpan)
        (EqualsTok defEqualsSpan)
        (LetExprTokens
          (LetKeywordTok letKeywordSpan)
          (LetBindingNameTok letBindingNameSpan)
          (LetEqualsTok letEqualsSpan)
          (LambdaExprTokens
            (LambdaTok lambdaTokenSpan)
            (LambdaParamTok lambdaParamSpan)
            (LambdaBodyValueRefTok lambdaBodyValueRefSpan))
          (LetInTok letInSpan)
          (AppExprTokens
            (AppFunctionIdTok appFunctionSpan)
            (AppIntLiteralTok appIntLiteralSpan)))
        (DefSemicolonTok defSemicolonSpan))
      (ModuleRightBraceTok moduleRightBraceSpan);
}
