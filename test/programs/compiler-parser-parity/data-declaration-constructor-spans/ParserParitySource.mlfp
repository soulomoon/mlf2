module ParserParitySource export (SourceSpan(..), SourceCursor(..), dataDeclarationSourceFile, dataDeclarationSourceText, moduleSpan, moduleKeywordSpan, moduleNameSpan, exportKeywordSpan, exportLeftParenSpan, exportNatSpan, exportCommaSpan, exportMainSpan, exportRightParenSpan, moduleLeftBraceSpan, dataKeywordSpan, dataNameSpan, dataEqualsSpan, zeroNameSpan, zeroColonSpan, zeroTypeSpan, constructorSeparatorSpan, succNameSpan, succColonSpan, succArgTypeSpan, succArrowSpan, succResultTypeSpan, dataSemicolonSpan, defKeywordSpan, defNameSpan, defColonSpan, defNatTypeSpan, defEqualsSpan, defFunctionSpan, defArgumentSpan, defSemicolonSpan, moduleRightBraceSpan, dataDeclSpan, zeroConstructorSpan, succConstructorSpan, defMainSpan, unexpectedSpan, renderSpan) {
  import Prelude exposing (stringAppend);

  data SourceSpan =
      SourceSpan : String -> SourceSpan;

  data SourceCursor =
      SourceCursor : String -> SourceCursor;

  def dataDeclarationSourceFile : String =
    "test/conformance/mlfp/parser-parity/data-declaration-constructor-spans/src/Main.mlfp";

  def dataDeclarationSourceText : String =
    "module Main export (Nat(..), main) {\n  data Nat =\n      Zero : Nat\n    | Succ : Nat -> Nat;\n\n  def main : Nat = Succ Zero;\n}\n";

  def moduleSpan : SourceSpan =
    SourceSpan "1:1-8:1";

  def moduleKeywordSpan : SourceSpan =
    SourceSpan "1:1-1:7";

  def moduleNameSpan : SourceSpan =
    SourceSpan "1:8-1:12";

  def exportKeywordSpan : SourceSpan =
    SourceSpan "1:13-1:19";

  def exportLeftParenSpan : SourceSpan =
    SourceSpan "1:20-1:21";

  def exportNatSpan : SourceSpan =
    SourceSpan "1:21-1:28";

  def exportCommaSpan : SourceSpan =
    SourceSpan "1:28-1:29";

  def exportMainSpan : SourceSpan =
    SourceSpan "1:30-1:34";

  def exportRightParenSpan : SourceSpan =
    SourceSpan "1:34-1:35";

  def moduleLeftBraceSpan : SourceSpan =
    SourceSpan "1:36-1:37";

  def dataKeywordSpan : SourceSpan =
    SourceSpan "2:3-2:7";

  def dataNameSpan : SourceSpan =
    SourceSpan "2:8-2:11";

  def dataEqualsSpan : SourceSpan =
    SourceSpan "2:12-2:13";

  def zeroNameSpan : SourceSpan =
    SourceSpan "3:7-3:11";

  def zeroColonSpan : SourceSpan =
    SourceSpan "3:12-3:13";

  def zeroTypeSpan : SourceSpan =
    SourceSpan "3:14-3:17";

  def constructorSeparatorSpan : SourceSpan =
    SourceSpan "4:5-4:6";

  def succNameSpan : SourceSpan =
    SourceSpan "4:7-4:11";

  def succColonSpan : SourceSpan =
    SourceSpan "4:12-4:13";

  def succArgTypeSpan : SourceSpan =
    SourceSpan "4:14-4:17";

  def succArrowSpan : SourceSpan =
    SourceSpan "4:18-4:20";

  def succResultTypeSpan : SourceSpan =
    SourceSpan "4:21-4:24";

  def dataSemicolonSpan : SourceSpan =
    SourceSpan "4:24-4:25";

  def defKeywordSpan : SourceSpan =
    SourceSpan "6:3-6:6";

  def defNameSpan : SourceSpan =
    SourceSpan "6:7-6:11";

  def defColonSpan : SourceSpan =
    SourceSpan "6:12-6:13";

  def defNatTypeSpan : SourceSpan =
    SourceSpan "6:14-6:17";

  def defEqualsSpan : SourceSpan =
    SourceSpan "6:18-6:19";

  def defFunctionSpan : SourceSpan =
    SourceSpan "6:20-6:24";

  def defArgumentSpan : SourceSpan =
    SourceSpan "6:25-6:29";

  def defSemicolonSpan : SourceSpan =
    SourceSpan "6:29-6:30";

  def moduleRightBraceSpan : SourceSpan =
    SourceSpan "7:1-7:2";

  def dataDeclSpan : SourceSpan =
    SourceSpan "2:3-6:3";

  def zeroConstructorSpan : SourceSpan =
    SourceSpan "3:7-4:5";

  def succConstructorSpan : SourceSpan =
    SourceSpan "4:7-4:24";

  def defMainSpan : SourceSpan =
    SourceSpan "6:3-7:1";

  def unexpectedSpan : SourceSpan =
    SourceSpan "1:1-1:1";

  def renderSpan : String -> SourceSpan -> String =
    λ(file : String) λ(span : SourceSpan) case span of {
      SourceSpan coordinates -> stringAppend file (stringAppend ":" coordinates)
    };
}
