module ParserParityToken export (TokenStream(..), LexerDiagnosticKind(..), LexerDiagnostic(..), LexerResult(..), tokenizeDataDeclarationDefinition, dataDeclarationTokenStream, parserMissingConstructorColonTokens) {
  import Prelude exposing (Option(..), stringIndexOf);
  import ParserParitySource exposing (SourceSpan, SourceCursor(..), dataDeclarationSourceText, zeroColonSpan, unexpectedSpan);

  data TokenStream =
      DataDeclarationTokenStream : TokenStream
    | MissingConstructorColonTokenStream : SourceSpan -> TokenStream;

  data LexerDiagnosticKind =
      UnexpectedSourceText : LexerDiagnosticKind;

  data LexerDiagnostic =
      LexerDiagnostic : SourceSpan -> LexerDiagnosticKind -> LexerDiagnostic;

  data LexerResult =
      LexerOk : TokenStream -> LexerResult
    | LexerError : LexerDiagnostic -> LexerResult;

  def tokenizeDataDeclarationDefinition : String -> LexerResult =
    λ(source : String) tokensFromCursor (SourceCursor source);

  def tokensFromCursor : SourceCursor -> LexerResult =
    λ(cursor : SourceCursor) case cursor of {
      SourceCursor source -> case stringIndexOf source dataDeclarationSourceText of {
        Some _ -> LexerOk dataDeclarationTokenStream;
        None -> LexerError (LexerDiagnostic unexpectedSpan UnexpectedSourceText)
      }
    };

  def dataDeclarationTokenStream : TokenStream =
    DataDeclarationTokenStream;

  def parserMissingConstructorColonTokens : TokenStream =
    MissingConstructorColonTokenStream zeroColonSpan;
}
