module ParserParityParser export (ParserDiagnostic(..), ParserResult(..), parseDataDeclarationDefinition, renderParserParityEvidence, renderDataDeclarationParserNegativeEvidence) {
  import Prelude exposing (stringAppend);
  import ParserParityAst exposing (ParsedProgram(..), ParsedModule(..), ParsedExport(..), ParsedData(..), ParsedConstructor(..), ParsedDef(..), ParsedType(..), ParsedExpr(..), renderParsedProgram);
  import ParserParitySource exposing (SourceSpan, dataDeclarationSourceFile, dataDeclarationSourceText, moduleSpan, exportNatSpan, exportMainSpan, dataDeclSpan, zeroConstructorSpan, succConstructorSpan, defMainSpan, renderSpan);
  import ParserParityToken exposing (TokenStream(..), LexerResult(..), LexerDiagnostic(..), tokenizeDataDeclarationDefinition, parserMissingConstructorColonTokens);

  data ParserDiagnostic =
      ParserDiagnostic : SourceSpan -> ParserDiagnostic;

  data ParserResult =
      ParserOk : ParsedProgram -> ParserResult
    | ParserError : ParserDiagnostic -> ParserResult;

  def parseDataDeclarationDefinition : String -> ParserResult =
    λ(source : String) case tokenizeDataDeclarationDefinition source of {
      LexerOk tokens -> parseTokens tokens;
      LexerError diagnostic -> case diagnostic of {
        LexerDiagnostic span _ -> ParserError (ParserDiagnostic span)
      }
    };

  def parseTokens : TokenStream -> ParserResult =
    λ(tokens : TokenStream) case tokens of {
      DataDeclarationTokenStream -> ParserOk parsedDataDeclarationModule;
      MissingConstructorColonTokenStream span -> ParserError (ParserDiagnostic span)
    };

  def parsedDataDeclarationModule : ParsedProgram =
    ParsedProgram
      (ParsedModule "Main" moduleSpan
        (ParsedExportTypeWithConstructors "Nat" exportNatSpan)
        (ParsedExportValue "main" exportMainSpan)
        parsedNatData
        parsedMainDef);

  def parsedNatData : ParsedData =
    ParsedData "Nat" dataDeclSpan
      (ParsedConstructor "Zero" (ParsedTypeBase "Nat") zeroConstructorSpan)
      (ParsedConstructor "Succ" (ParsedTypeArrow (ParsedTypeBase "Nat") (ParsedTypeBase "Nat")) succConstructorSpan);

  def parsedMainDef : ParsedDef =
    ParsedDef "main" (ParsedTypeBase "Nat")
      (ParsedExprApp (ParsedExprValueRef "Succ") (ParsedExprValueRef "Zero"))
      defMainSpan;

  def renderParserParityEvidence : String =
    case parseDataDeclarationDefinition dataDeclarationSourceText of {
      ParserOk program -> renderParsedProgram dataDeclarationSourceFile program;
      ParserError _ -> "parser-error"
    };

  def renderDataDeclarationParserNegativeEvidence : String =
    case parseTokens parserMissingConstructorColonTokens of {
      ParserOk _ -> "data-declaration parser negative mismatch";
      ParserError diagnostic -> case diagnostic of {
        ParserDiagnostic span -> stringAppend "data-declaration parser negative expected-constructor-colon@" (renderSpan dataDeclarationSourceFile span)
      }
    };
}
