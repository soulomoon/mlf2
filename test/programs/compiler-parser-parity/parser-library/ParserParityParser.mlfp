  def appendImportProjectionRowsAndClose : String -> ParserValue -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleNameToken : ParserValue) λ(existingRows : ParserValue) λ(nextRows : ParserValue)
      parserBind (appendProjectionValues existingRows nextRows) (parseImportProjectionMoreOrClose0 sourceFile moduleNameToken);

  def parseImportProjectionMoreOrClose0 : String -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(_sourceFile : String) λ(_moduleNameToken : ParserValue) λ(itemRows : ParserValue)
      parserChoice
        (parserBind (expectText ")") (parseImportProjectionSemicolon itemRows))
        parserFailExpectedImportExposingSeparatorAtCurrent;

  def parseImportProjectionItem : String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(_start : ParserValue)
      parserBind expectAnyIdentifier
        (parseProjectionImportItemTail sourceFile);

  def parseProjectionImportItemTail : String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(nameToken : ParserValue)
      parserChoice
        (parserBind (parseTypeWithConstructorsMarker ValueUnit) (finishConstructedTypeImportItem sourceFile nameToken))
        (finishPlainProjectionImportItem sourceFile nameToken);

  def finishConstructedTypeImportItem : String -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(nameToken : ParserValue) λ(markerClose : ParserValue)
      projectionLineFromSpan sourceFile
        (stringAppend (stringAppend "import exposing type-with-constructors " (identifierNameFromValue nameToken)) " span=")
        (spanFromTokenBounds nameToken markerClose);

  def finishPlainProjectionImportItem : String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(nameToken : ParserValue) case nameToken of {
      ValueToken token ->
        projectionLineFromSpan sourceFile
          (stringAppend (stringAppend (projectionImportKindPrefix (identifierNameFromValue nameToken)) (identifierNameFromValue nameToken)) " span=")
          (tokenSpan token);
      ValueProjectionRows _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueModuleKey _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueUnit -> parserFail (ExpectedCompleteModule basicUnexpectedSpan)
    };

  def parseImportedMainDefinition : String -> String -> String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleStart : String) λ(moduleName : String) λ(exportRows : String) λ(importRowsValue : ParserValue) case importRowsValue of {
      ValueProjectionRows importRows ->
        parserChoice
          (parserBind (parseImportedBoolMainRows sourceFile ValueUnit)
            (finishImportedBodyRows sourceFile moduleStart moduleName exportRows importRows))
          (parserChoice
            (parserBind (parseImportedNatMainRows sourceFile ValueUnit)
              (finishImportedBodyRows sourceFile moduleStart moduleName exportRows importRows))
            (parserBind (parseTextLiteralDefinitionRows sourceFile ValueUnit)
              (finishImportedBodyRows sourceFile moduleStart moduleName exportRows importRows)));
      ValueModuleKey _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueToken _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueUnit -> parserFail (ExpectedCompleteModule basicUnexpectedSpan)
    };

  def finishImportedBodyRows : String -> String -> String -> String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleStart : String) λ(moduleName : String) λ(exportRows : String) λ(importRows : String) λ(definitionRows : ParserValue) case definitionRows of {
      ValueProjectionRows definitionText -> finishModuleBodyRows sourceFile moduleStart moduleName exportRows (ValueProjectionRows (appendLine importRows definitionText));
      ValueModuleKey _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueToken _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueUnit -> parserFail (ExpectedCompleteModule basicUnexpectedSpan)
    };

