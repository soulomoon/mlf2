  def appendImportProjectionRowsAndContinue1 : String -> ParserValue -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleNameToken : ParserValue) λ(existingRows : ParserValue) λ(nextRows : ParserValue)
      parserBind (appendProjectionValues existingRows nextRows) (parseImportProjectionMoreOrClose1 sourceFile moduleNameToken);

  def parseImportProjectionMoreOrClose1 : String -> ParserValue -> ParserValue -> Parser ParserValue =
