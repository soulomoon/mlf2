  def finishNatDataRows : String -> String -> String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(dataStart : String) λ(zeroSpan : String) λ(succStart : String) λ(semicolonToken : ParserValue)
      parserBind (parserCurrentTokenStartOr (tokenEndCoordinate semicolonToken))
        (λ(dataEnd : ParserValue)
