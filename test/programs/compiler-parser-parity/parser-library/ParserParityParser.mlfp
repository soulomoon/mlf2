  def renderParserParityRetryEvidence : String -> String -> String -> String =
    λ(sourceFile : String) λ(sourceText : String) λ(lexerMismatchSourceText : String)
      stringAppend (renderPositiveTokenEvidence sourceFile sourceText)
        (stringAppend "\n"
          (stringAppend (renderLexerNegativeEvidence sourceFile lexerMismatchSourceText)
            (stringAppend "\n" (renderParserNegativeEvidenceFromSourceText "parser negative " sourceFile basicParserNegativeSourceText))));

  def renderPositiveTokenEvidence : String -> String -> String =
    λ(sourceFile : String) λ(sourceText : String) case tokenizeCompleteModule sourceText of {
      LexerOk input -> renderTokenPrefixEvidence sourceFile input;
      LexerError diagnostic -> stringAppend "tokens " (renderDiagnosticEvidence sourceFile diagnostic)
    };

  def renderLexerNegativeEvidence : String -> String -> String =
    λ(sourceFile : String) λ(lexerMismatchSourceText : String) case tokenizeCompleteModule lexerMismatchSourceText of {
      LexerOk _ -> "lexer negative unexpected-success";
      LexerError diagnostic -> stringAppend "lexer negative " (renderDiagnosticEvidence sourceFile diagnostic)
    };

  def basicParserNegativeSourceText : String =
    "module Main export (main) {\n  def main : Bool   true;\n}";

  def renderParserNegativeEvidenceFromSourceText : String -> String -> String -> String =
    λ(prefix : String) λ(sourceFile : String) λ(sourceText : String)
      renderParserNegativeEvidence prefix sourceFile (parseCompleteModule sourceText);

  def renderParserNegativeEvidence : String -> String -> ParserResult -> String =
    λ(prefix : String) λ(sourceFile : String) λ(result : ParserResult) case result of {
      ParserOk _ -> stringAppend prefix "unexpected-success";
      ParserError diagnostic -> stringAppend prefix (renderDiagnosticEvidence sourceFile diagnostic)
    };

  def renderDiagnosticEvidence : String -> ParserDiagnostic -> String =
    λ(sourceFile : String) λ(diagnostic : ParserDiagnostic) case diagnostic of {
      UnexpectedSourceText span -> stringAppend "unexpected-source@" (renderSpan sourceFile span);
      ExpectedCompleteModule span -> stringAppend "expected-complete-module@" (renderSpan sourceFile span);
      ExpectedEquals span -> stringAppend "expected-equals@" (renderSpan sourceFile span);
      ExpectedImportSemicolon span -> stringAppend "expected-import-semicolon@" (renderSpan sourceFile span);
      ExpectedDefSemicolon span -> stringAppend "expected-def-semicolon@" (renderSpan sourceFile span);
      ExpectedLetIn span -> stringAppend "expected-let-in@" (renderSpan sourceFile span);
      ExpectedLetAnnotationType span -> stringAppend "expected-let-annotation-type@" (renderSpan sourceFile span);
      ExpectedConstructorColon span -> stringAppend "expected-constructor-colon@" (renderSpan sourceFile span);
      ExpectedCaseBranchArrow span -> stringAppend "expected-case-branch-arrow@" (renderSpan sourceFile span);
      ExpectedInstanceMethodEquals span -> stringAppend "expected-instance-method-equals@" (renderSpan sourceFile span)
    };
}
