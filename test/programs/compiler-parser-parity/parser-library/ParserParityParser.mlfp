  def parseRecursiveGadtBody : ParserValue -> Parser ParserValue =
    λ(_openModule : ParserValue)
      parserBind (labelUnexpectedSource recursiveGadtNatDataSpan (parseNatRecursiveDataDeclaration ValueUnit))
        parseRecursiveGadtExprData;

  def parseRecursiveGadtExprData : ParserValue -> Parser ParserValue =
    λ(_natData : ParserValue)
      parserBind (labelUnexpectedSource recursiveGadtExprDataSpan (parseExprRecursiveDataDeclaration ValueUnit))
        parseRecursiveGadtDoneNowDefinition;

  def parseRecursiveGadtDoneNowDefinition : ParserValue -> Parser ParserValue =
