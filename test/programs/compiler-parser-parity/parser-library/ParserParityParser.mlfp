  def parseRecursiveAdtExprExportComma : ParserValue -> Parser ParserValue =
    λ(_exprExport : ParserValue)
      parserBind (expectText ",")
        parseRecursiveAdtExportTail;

  def parseRecursiveAdtExportTail : ParserValue -> Parser ParserValue =
    λ(_comma : ParserValue)
      parserChoice
        (parseExistentialValueExports ValueUnit)
        (parseRecursiveGadtValueExports ValueUnit);

  def parseTypeWithConstructorsExport : String -> ParserValue -> Parser ParserValue =
    λ(typeName : String) λ(_start : ParserValue)
