      parserBind (expectText "(")
        parseRecursiveAdtNatExport;

  def parseRecursiveAdtNatExport : ParserValue -> Parser ParserValue =
    λ(_openExport : ParserValue)
      parserBind (parseTypeWithConstructorsExport "Nat" ValueUnit)
        parseRecursiveAdtNatExportComma;

  def parseRecursiveAdtNatExportComma : ParserValue -> Parser ParserValue =
    λ(_natExport : ParserValue)
      parserBind (expectText ",")
