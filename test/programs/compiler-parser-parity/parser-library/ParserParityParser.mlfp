              (dataRows sourceFile "Nat" (spanFromStartToCoordinate dataStart dataEnd))
              (appendLine
                (constructorRows sourceFile "Zero" "Nat" zeroSpan)
                (constructorRows sourceFile "Succ" "Nat -> Nat" (spanFromStartToTokenStart succStart semicolonToken)))));

