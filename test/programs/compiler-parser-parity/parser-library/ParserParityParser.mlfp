module ParserParityParser export (ParserResult(..), parseCompleteModule, parseTokens, renderParserParityProjectionFromSourceText, renderParserParityRetryEvidence, renderParserNegativeEvidenceFromSourceText) {
  import Prelude exposing (stringAppend);
  import ParserParityAst exposing (ParsedModule(..), renderParsedModule);
  import ParserParityDiagnostic exposing (ParserDiagnostic(..));
  import ParserParityLexer exposing (LexerResult(..), tokenizeCompleteModule);
  import ParserParityParserCombinator exposing (Parser, ParserEnd(..), ParserState(..), ParserStep(..), ParserValue(..), captureSpan, diagnosticLabel, expectToken, labelConstructorColon, labelDefSemicolon, labelEquals, labelImportSemicolon, labelLetAnnotationType, labelLetIn, parserBind, parserChoice, parserFail, parserPure, parserStateAtEnd, runParser);
  import ParserParitySource exposing (basicBoolLiteralSpan, basicUnexpectedSpan, dataZeroColonSpan, importBoolSemicolonSpan, letInSpan, lexerUnknownSpan, renderSpan, typedLetForallSpan, valueFirstDefSemicolonSpan);
  import ParserParityToken exposing (ParserInput(..), TokenKind(..), renderTokenPrefixEvidence);

  data ParserResult =
      ParserOk : String -> ParserResult
    | ParserError : ParserDiagnostic -> ParserResult;

  def renderParserParityProjectionFromSourceText : String -> String -> String =
    λ(sourceFile : String) λ(sourceText : String) case parseCompleteModule sourceText of {
      ParserOk key -> renderParsedModule sourceFile (ParsedModule key);
      ParserError _ -> "parser-error"
    };

  def parseCompleteModule : String -> ParserResult =
    λ(sourceText : String) case tokenizeCompleteModule sourceText of {
      LexerOk input -> parseTokens input;
      LexerError diagnostic -> ParserError diagnostic
    };

  def parseTokens : ParserInput -> ParserResult =
    λ(input : ParserInput) case input of {
      ParserInput source -> parserReplyToResult (runParser (parseAnyModule ValueUnit) (ParserState source))
    };

  def parserReplyToResult : ParserStep -> ParserResult =
    λ(reply : ParserStep) case reply of {
      ParserStepOk state value -> case parserStateAtEnd state of {
        ParserAtEnd -> case value of {
          ValueModuleKey key -> ParserOk key;
          ValueUnit -> ParserError (ExpectedCompleteModule basicUnexpectedSpan);
          ValueToken _ -> ParserError (ExpectedCompleteModule basicUnexpectedSpan)
        };
        ParserNotAtEnd -> ParserError (ExpectedCompleteModule basicUnexpectedSpan);
        ParserEndUnknown -> ParserError (ExpectedCompleteModule basicUnexpectedSpan)
      };
      ParserStepError diagnostic -> ParserError diagnostic
    };

  def expectComplete : TokenKind -> Parser ParserValue =
    λ(kind : TokenKind) diagnosticLabel (captureSpan (expectToken kind basicUnexpectedSpan));

  def expectEqualsParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue) labelEquals (captureSpan (expectToken (TokenKind "=") basicBoolLiteralSpan));

  def expectImportSemicolonParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (expectText ";") (parserFail (ExpectedImportSemicolon importBoolSemicolonSpan));

  def expectDefSemicolonParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (expectText ";") (parserFail (ExpectedDefSemicolon valueFirstDefSemicolonSpan));

  def expectLetInParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (expectText "in") (parserFail (ExpectedLetIn letInSpan));

  def expectLetAnnotationTypeParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (expectText "forall") (parserFail (ExpectedLetAnnotationType typedLetForallSpan));

  def expectConstructorColonParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (expectText ":") (parserFail (ExpectedConstructorColon dataZeroColonSpan));

  def expectText : String -> Parser ParserValue =
    λ(text : String) expectComplete (TokenKind text);

  def moduleKey : String -> Parser ParserValue =
    λ(key : String) parserPure (ValueModuleKey key);

  def completeModuleKey : String -> Parser ParserValue =
    λ(key : String)
      parserBind (expectText "}")
        (λ(_closeToken : ParserValue) moduleKey key);

  def parseAnyModule : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (parseBasicModule ValueUnit)
        (parserChoice (parseImportModule ValueUnit)
          (parserChoice (parseValueModule ValueUnit)
            (parserChoice (parseLetModule ValueUnit)
              (parserChoice (parseTypedModule ValueUnit) (parseDataModule ValueUnit)))));

  def parseBasicModule : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectText "module")
        parseBasicModuleName;

  def parseBasicModuleName : ParserValue -> Parser ParserValue =
    λ(_moduleToken : ParserValue)
      parserBind (expectText "identifier:Main")
        parseBasicExportKeyword;

  def parseBasicExportKeyword : ParserValue -> Parser ParserValue =
    λ(_nameToken : ParserValue)
      parserBind (expectText "export")
        parseBasicExportOpen;

  def parseBasicExportOpen : ParserValue -> Parser ParserValue =
    λ(_exportToken : ParserValue)
      parserBind (expectText "(")
        parseBasicExportName;

  def parseBasicExportName : ParserValue -> Parser ParserValue =
    λ(_openExport : ParserValue)
      parserBind (expectText "identifier:main")
        parseBasicExportClose;

  def parseBasicExportClose : ParserValue -> Parser ParserValue =
    λ(_exportItem : ParserValue)
      parserBind (expectText ")")
        parseBasicModuleOpen;

  def parseBasicModuleOpen : ParserValue -> Parser ParserValue =
    λ(_closeExport : ParserValue)
      parserBind (expectText "{")
        parseBasicDefKeyword;

  def parseBasicDefKeyword : ParserValue -> Parser ParserValue =
    λ(_openModule : ParserValue)
      parserBind (expectText "def")
        parseBasicDefName;

  def parseBasicDefName : ParserValue -> Parser ParserValue =
    λ(_defToken : ParserValue)
      parserBind (expectText "identifier:main")
        parseBasicDefColon;

  def parseBasicDefColon : ParserValue -> Parser ParserValue =
    λ(_defName : ParserValue)
      parserBind (expectText ":")
        parseBasicDefType;

  def parseBasicDefType : ParserValue -> Parser ParserValue =
    λ(_colon : ParserValue)
      parserBind (expectText "identifier:Bool")
        parseBoolDefinitionEquals;

  def parseBoolDefinitionEquals : ParserValue -> Parser ParserValue =
    λ(_typeToken : ParserValue)
      parserBind (expectEqualsParser ValueUnit)
        parseBasicDefLiteral;

  def parseBasicDefLiteral : ParserValue -> Parser ParserValue =
    λ(_equalsToken : ParserValue)
      parserBind (expectText "bool:true")
        parseBasicDefSemicolon;

  def parseBasicDefSemicolon : ParserValue -> Parser ParserValue =
    λ(_literalToken : ParserValue)
      parserBind (expectText ";")
        parseBasicModuleClose;

  def parseBasicModuleClose : ParserValue -> Parser ParserValue =
    λ(_semicolonToken : ParserValue)
      completeModuleKey "basic-bool";

  def parseImportModule : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectText "module")
        parseImportModuleName;

  def parseImportModuleName : ParserValue -> Parser ParserValue =
    λ(_moduleToken : ParserValue)
      parserBind (expectText "identifier:Main")
        parseImportExportKeyword;

  def parseImportExportKeyword : ParserValue -> Parser ParserValue =
    λ(_nameToken : ParserValue)
      parserBind (expectText "export")
        parseImportExportOpen;

  def parseImportExportOpen : ParserValue -> Parser ParserValue =
    λ(_exportToken : ParserValue)
      parserBind (expectText "(")
        parseImportExportMain;

  def parseImportExportMain : ParserValue -> Parser ParserValue =
    λ(_openExport : ParserValue)
      parserBind (expectText "identifier:main")
        parseImportExportClose;

  def parseImportExportClose : ParserValue -> Parser ParserValue =
    λ(_exportMain : ParserValue)
      parserBind (expectText ")")
        parseImportModuleOpen;

  def parseImportModuleOpen : ParserValue -> Parser ParserValue =
    λ(_closeExport : ParserValue)
      parserBind (expectText "{")
        parseImportDeclaration;

  def parseImportDeclaration : ParserValue -> Parser ParserValue =
    λ(_openModule : ParserValue)
      parserBind (expectText "import")
        parseImportModuleRef;

  def parseImportModuleRef : ParserValue -> Parser ParserValue =
    λ(_importToken : ParserValue)
      parserBind (expectText "identifier:Prelude")
        parseImportExposingKeyword;

  def parseImportExposingKeyword : ParserValue -> Parser ParserValue =
    λ(_moduleRef : ParserValue)
      parserBind (expectText "exposing")
        parseImportExposingOpen;

  def parseImportExposingOpen : ParserValue -> Parser ParserValue =
    λ(_exposingToken : ParserValue)
      parserBind (expectText "(")
        parseImportBoolType;

  def parseImportBoolType : ParserValue -> Parser ParserValue =
    λ(_openExposing : ParserValue)
      parserBind (expectText "identifier:Bool")
        parseImportExposingClose;

  def parseImportExposingClose : ParserValue -> Parser ParserValue =
    λ(_boolToken : ParserValue)
      parserBind (expectText ")")
        parseImportSemicolon;

  def parseImportSemicolon : ParserValue -> Parser ParserValue =
    λ(_closeExposing : ParserValue)
      parserBind (expectImportSemicolonParser ValueUnit)
        parseImportDefKeyword;

  def parseImportDefKeyword : ParserValue -> Parser ParserValue =
    λ(_importSemicolon : ParserValue)
      parserBind (expectText "def")
        parseImportDefName;

  def parseImportDefName : ParserValue -> Parser ParserValue =
    λ(_defToken : ParserValue)
      parserBind (expectText "identifier:main")
        parseImportDefColon;

  def parseImportDefColon : ParserValue -> Parser ParserValue =
    λ(_defName : ParserValue)
      parserBind (expectText ":")
        parseImportDefType;

  def parseImportDefType : ParserValue -> Parser ParserValue =
    λ(_colonToken : ParserValue)
      parserBind (expectText "identifier:Bool")
        parseImportDefEquals;

  def parseImportDefEquals : ParserValue -> Parser ParserValue =
    λ(_typeToken : ParserValue)
      parserBind (expectText "=")
        parseImportDefLiteral;

  def parseImportDefLiteral : ParserValue -> Parser ParserValue =
    λ(_equalsToken : ParserValue)
      parserBind (expectText "bool:true")
        parseImportDefSemicolon;

  def parseImportDefSemicolon : ParserValue -> Parser ParserValue =
    λ(_literalToken : ParserValue)
      parserBind (expectText ";")
        parseImportModuleClose;

  def parseImportModuleClose : ParserValue -> Parser ParserValue =
    λ(_semicolonToken : ParserValue)
      completeModuleKey "import-bool";

  def parseValueModule : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectText "module")
        parseValueModuleName;

  def parseValueModuleName : ParserValue -> Parser ParserValue =
    λ(_moduleToken : ParserValue)
      parserBind (expectText "identifier:Main")
        parseValueExportKeyword;

  def parseValueExportKeyword : ParserValue -> Parser ParserValue =
    λ(_nameToken : ParserValue)
      parserBind (expectText "export")
        parseValueExportOpen;

  def parseValueExportOpen : ParserValue -> Parser ParserValue =
    λ(_exportToken : ParserValue)
      parserBind (expectText "(")
        parseValueExportMain;

  def parseValueExportMain : ParserValue -> Parser ParserValue =
    λ(_openExport : ParserValue)
      parserBind (expectText "identifier:main")
        parseValueExportClose;

  def parseValueExportClose : ParserValue -> Parser ParserValue =
    λ(_exportMain : ParserValue)
      parserBind (expectText ")")
        parseValueModuleOpen;

  def parseValueModuleOpen : ParserValue -> Parser ParserValue =
    λ(_closeExport : ParserValue)
      parserBind (expectText "{")
        parseValueImportDeclaration;

  def parseValueImportDeclaration : ParserValue -> Parser ParserValue =
    λ(_openModule : ParserValue)
      parserBind (expectText "import")
        parseValueImportModuleRef;

  def parseValueImportModuleRef : ParserValue -> Parser ParserValue =
    λ(_importToken : ParserValue)
      parserBind (expectText "identifier:Prelude")
        parseValueImportExposingKeyword;

  def parseValueImportExposingKeyword : ParserValue -> Parser ParserValue =
    λ(_moduleRef : ParserValue)
      parserBind (expectText "exposing")
        parseValueImportExposingOpen;

  def parseValueImportExposingOpen : ParserValue -> Parser ParserValue =
    λ(_exposingToken : ParserValue)
      parserBind (expectText "(")
        parseValueImportIntType;

  def parseValueImportIntType : ParserValue -> Parser ParserValue =
    λ(_openExposing : ParserValue)
      parserBind (expectText "identifier:Int")
        parseValueImportExposingClose;

  def parseValueImportExposingClose : ParserValue -> Parser ParserValue =
    λ(_intToken : ParserValue)
      parserBind (expectText ")")
        parseValueImportSemicolon;

  def parseValueImportSemicolon : ParserValue -> Parser ParserValue =
    λ(_closeExposing : ParserValue)
      parserBind (expectText ";")
        parseValueTwoDefinition;

  def parseValueTwoDefinition : ParserValue -> Parser ParserValue =
    λ(_importSemicolon : ParserValue)
      parserBind (expectText "def")
        parseValueTwoName;

  def parseValueTwoName : ParserValue -> Parser ParserValue =
    λ(_defToken : ParserValue)
      parserBind (expectText "identifier:two")
        parseValueTwoColon;

  def parseValueTwoColon : ParserValue -> Parser ParserValue =
    λ(_twoName : ParserValue)
      parserBind (expectText ":")
        parseValueTwoType;

  def parseValueTwoType : ParserValue -> Parser ParserValue =
    λ(_colonToken : ParserValue)
      parserBind (expectText "identifier:Int")
        parseValueTwoEquals;

  def parseValueTwoEquals : ParserValue -> Parser ParserValue =
    λ(_typeToken : ParserValue)
      parserBind (expectText "=")
        parseValueTwoLiteral;

  def parseValueTwoLiteral : ParserValue -> Parser ParserValue =
    λ(_equalsToken : ParserValue)
      parserBind (expectText "int:2")
        parseValueTwoSemicolon;

  def parseValueTwoSemicolon : ParserValue -> Parser ParserValue =
    λ(_literalToken : ParserValue)
      parserBind (expectDefSemicolonParser ValueUnit)
        parseValueMainDefinition;

  def parseValueMainDefinition : ParserValue -> Parser ParserValue =
    λ(_twoSemicolon : ParserValue)
      parserBind (expectText "def")
        parseValueMainName;

  def parseValueMainName : ParserValue -> Parser ParserValue =
    λ(_defToken : ParserValue)
      parserBind (expectText "identifier:main")
        parseValueMainColon;

  def parseValueMainColon : ParserValue -> Parser ParserValue =
    λ(_mainName : ParserValue)
      parserBind (expectText ":")
        parseValueMainType;

  def parseValueMainType : ParserValue -> Parser ParserValue =
    λ(_colonToken : ParserValue)
      parserBind (expectText "identifier:Int")
        parseValueMainEquals;

  def parseValueMainEquals : ParserValue -> Parser ParserValue =
    λ(_typeToken : ParserValue)
      parserBind (expectText "=")
        parseValueMainReference;

  def parseValueMainReference : ParserValue -> Parser ParserValue =
    λ(_equalsToken : ParserValue)
      parserBind (expectText "identifier:two")
        parseValueMainSemicolon;

  def parseValueMainSemicolon : ParserValue -> Parser ParserValue =
    λ(_twoReference : ParserValue)
      parserBind (expectText ";")
        parseValueModuleClose;

  def parseValueModuleClose : ParserValue -> Parser ParserValue =
    λ(_semicolonToken : ParserValue)
      completeModuleKey "value-int-ref";

  def parseLetModule : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectText "module")
        parseLetModuleName;

  def parseLetModuleName : ParserValue -> Parser ParserValue =
    λ(_moduleToken : ParserValue)
      parserBind (expectText "identifier:Main")
        parseLetExportKeyword;

  def parseLetExportKeyword : ParserValue -> Parser ParserValue =
    λ(_nameToken : ParserValue)
      parserBind (expectText "export")
        parseLetExportOpen;

  def parseLetExportOpen : ParserValue -> Parser ParserValue =
    λ(_exportToken : ParserValue)
      parserBind (expectText "(")
        parseLetExportMain;

  def parseLetExportMain : ParserValue -> Parser ParserValue =
    λ(_openExport : ParserValue)
      parserBind (expectText "identifier:main")
        parseLetExportClose;

  def parseLetExportClose : ParserValue -> Parser ParserValue =
    λ(_exportMain : ParserValue)
      parserBind (expectText ")")
        parseLetModuleOpen;

  def parseLetModuleOpen : ParserValue -> Parser ParserValue =
    λ(_closeExport : ParserValue)
      parserBind (expectText "{")
        parseLetImportDeclaration;

  def parseLetImportDeclaration : ParserValue -> Parser ParserValue =
    λ(_openModule : ParserValue)
      parserBind (expectText "import")
        parseLetImportModuleRef;

  def parseLetImportModuleRef : ParserValue -> Parser ParserValue =
    λ(_importToken : ParserValue)
      parserBind (expectText "identifier:Prelude")
        parseLetImportExposingKeyword;

  def parseLetImportExposingKeyword : ParserValue -> Parser ParserValue =
    λ(_moduleRef : ParserValue)
      parserBind (expectText "exposing")
        parseLetImportExposingOpen;

  def parseLetImportExposingOpen : ParserValue -> Parser ParserValue =
    λ(_exposingToken : ParserValue)
      parserBind (expectText "(")
        parseLetImportIntType;

  def parseLetImportIntType : ParserValue -> Parser ParserValue =
    λ(_openExposing : ParserValue)
      parserBind (expectText "identifier:Int")
        parseLetImportExposingClose;

  def parseLetImportExposingClose : ParserValue -> Parser ParserValue =
    λ(_intToken : ParserValue)
      parserBind (expectText ")")
        parseLetImportSemicolon;

  def parseLetImportSemicolon : ParserValue -> Parser ParserValue =
    λ(_closeExposing : ParserValue)
      parserBind (expectText ";")
        parseLetMainDefinition;

  def parseLetMainDefinition : ParserValue -> Parser ParserValue =
    λ(_importSemicolon : ParserValue)
      parserBind (expectText "def")
        parseLetMainName;

  def parseLetMainName : ParserValue -> Parser ParserValue =
    λ(_defToken : ParserValue)
      parserBind (expectText "identifier:main")
        parseLetMainColon;

  def parseLetMainColon : ParserValue -> Parser ParserValue =
    λ(_mainName : ParserValue)
      parserBind (expectText ":")
        parseLetMainType;

  def parseLetMainType : ParserValue -> Parser ParserValue =
    λ(_colonToken : ParserValue)
      parserBind (expectText "identifier:Int")
        parseLetMainEquals;

  def parseLetMainEquals : ParserValue -> Parser ParserValue =
    λ(_typeToken : ParserValue)
      parserBind (expectText "=")
        parseLetExpressionHead;

  def parseLetExpressionHead : ParserValue -> Parser ParserValue =
    λ(_equalsToken : ParserValue)
      parserBind (expectText "let")
        parseLetBindingName;

  def parseLetBindingName : ParserValue -> Parser ParserValue =
    λ(_letToken : ParserValue)
      parserBind (expectText "identifier:id")
        parseLetBindingEquals;

  def parseLetBindingEquals : ParserValue -> Parser ParserValue =
    λ(_bindingName : ParserValue)
      parserBind (expectText "=")
        parseLetLambdaTail;

  def parseLetLambdaTail : ParserValue -> Parser ParserValue =
    λ(_bindingEquals : ParserValue)
      parserBind (expectText "lambda")
        parseLetLambdaArgument;

  def parseLetLambdaArgument : ParserValue -> Parser ParserValue =
    λ(_lambdaToken : ParserValue)
      parserBind (expectText "identifier:x")
        parseLetLambdaBody;

  def parseLetLambdaBody : ParserValue -> Parser ParserValue =
    λ(_argumentToken : ParserValue)
      parserBind (expectText "identifier:x")
        parseLetExpressionIn;

  def parseLetExpressionIn : ParserValue -> Parser ParserValue =
    λ(_bodyToken : ParserValue)
      parserBind (expectLetInParser ValueUnit)
        parseLetApplicationHead;

  def parseLetApplicationHead : ParserValue -> Parser ParserValue =
    λ(_inToken : ParserValue)
      parserBind (expectText "identifier:id")
        parseLetApplicationArgument;

  def parseLetApplicationArgument : ParserValue -> Parser ParserValue =
    λ(_idToken : ParserValue)
      parserBind (expectText "int:1")
        parseLetMainSemicolon;

  def parseLetMainSemicolon : ParserValue -> Parser ParserValue =
    λ(_argumentToken : ParserValue)
      parserBind (expectText ";")
        parseLetModuleClose;

  def parseLetModuleClose : ParserValue -> Parser ParserValue =
    λ(_semicolonToken : ParserValue)
      completeModuleKey "let-lambda";

  def parseTypedModule : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectText "module")
        parseTypedModuleName;

  def parseTypedModuleName : ParserValue -> Parser ParserValue =
    λ(_moduleToken : ParserValue)
      parserBind (expectText "identifier:Main")
        parseTypedExportKeyword;

  def parseTypedExportKeyword : ParserValue -> Parser ParserValue =
    λ(_nameToken : ParserValue)
      parserBind (expectText "export")
        parseTypedExportOpen;

  def parseTypedExportOpen : ParserValue -> Parser ParserValue =
    λ(_exportToken : ParserValue)
      parserBind (expectText "(")
        parseTypedExportMain;

  def parseTypedExportMain : ParserValue -> Parser ParserValue =
    λ(_openExport : ParserValue)
      parserBind (expectText "identifier:main")
        parseTypedExportClose;

  def parseTypedExportClose : ParserValue -> Parser ParserValue =
    λ(_exportMain : ParserValue)
      parserBind (expectText ")")
        parseTypedModuleOpen;

  def parseTypedModuleOpen : ParserValue -> Parser ParserValue =
    λ(_closeExport : ParserValue)
      parserBind (expectText "{")
        parseTypedImportDeclaration;

  def parseTypedImportDeclaration : ParserValue -> Parser ParserValue =
    λ(_openModule : ParserValue)
      parserBind (expectText "import")
        parseTypedImportModuleRef;

  def parseTypedImportModuleRef : ParserValue -> Parser ParserValue =
    λ(_importToken : ParserValue)
      parserBind (expectText "identifier:Prelude")
        parseTypedImportExposingKeyword;

  def parseTypedImportExposingKeyword : ParserValue -> Parser ParserValue =
    λ(_moduleRef : ParserValue)
      parserBind (expectText "exposing")
        parseTypedImportExposingOpen;

  def parseTypedImportExposingOpen : ParserValue -> Parser ParserValue =
    λ(_exposingToken : ParserValue)
      parserBind (expectText "(")
        parseTypedImportIntType;

  def parseTypedImportIntType : ParserValue -> Parser ParserValue =
    λ(_openExposing : ParserValue)
      parserBind (expectText "identifier:Int")
        parseTypedImportExposingClose;

  def parseTypedImportExposingClose : ParserValue -> Parser ParserValue =
    λ(_intToken : ParserValue)
      parserBind (expectText ")")
        parseTypedImportSemicolon;

  def parseTypedImportSemicolon : ParserValue -> Parser ParserValue =
    λ(_closeExposing : ParserValue)
      parserBind (expectText ";")
        parseTypedMainDefinition;

  def parseTypedMainDefinition : ParserValue -> Parser ParserValue =
    λ(_importSemicolon : ParserValue)
      parserBind (expectText "def")
        parseTypedMainName;

  def parseTypedMainName : ParserValue -> Parser ParserValue =
    λ(_defToken : ParserValue)
      parserBind (expectText "identifier:main")
        parseTypedMainColon;

  def parseTypedMainColon : ParserValue -> Parser ParserValue =
    λ(_mainName : ParserValue)
      parserBind (expectText ":")
        parseTypedMainType;

  def parseTypedMainType : ParserValue -> Parser ParserValue =
    λ(_colonToken : ParserValue)
      parserBind (expectText "identifier:Int")
        parseTypedMainEquals;

  def parseTypedMainEquals : ParserValue -> Parser ParserValue =
    λ(_typeToken : ParserValue)
      parserBind (expectText "=")
        parseTypedLetHead;

  def parseTypedLetHead : ParserValue -> Parser ParserValue =
    λ(_equalsToken : ParserValue)
      parserBind (expectText "let")
        parseTypedBindingName;

  def parseTypedBindingName : ParserValue -> Parser ParserValue =
    λ(_letToken : ParserValue)
      parserBind (expectText "identifier:id")
        parseTypedAnnotationTail;

  def parseTypedAnnotationTail : ParserValue -> Parser ParserValue =
    λ(_bindingName : ParserValue)
      parserBind (expectText ":")
        parseTypedForall;

  def parseTypedForall : ParserValue -> Parser ParserValue =
    λ(_annotationColon : ParserValue)
      parserBind (expectLetAnnotationTypeParser ValueUnit)
        parseTypedForallBound;

  def parseTypedForallBound : ParserValue -> Parser ParserValue =
    λ(_forallToken : ParserValue)
      parserBind (expectText "identifier:a")
        parseTypedForallDot;

  def parseTypedForallDot : ParserValue -> Parser ParserValue =
    λ(_boundToken : ParserValue)
      parserBind (expectText ".")
        parseTypedForallArgument;

  def parseTypedForallArgument : ParserValue -> Parser ParserValue =
    λ(_dotToken : ParserValue)
      parserBind (expectText "identifier:a")
        parseTypedForallArrow;

  def parseTypedForallArrow : ParserValue -> Parser ParserValue =
    λ(_argumentToken : ParserValue)
      parserBind (expectText "->")
        parseTypedForallResult;

  def parseTypedForallResult : ParserValue -> Parser ParserValue =
    λ(_arrowToken : ParserValue)
      parserBind (expectText "identifier:a")
        parseTypedBindingEquals;

  def parseTypedBindingEquals : ParserValue -> Parser ParserValue =
    λ(_resultToken : ParserValue)
      parserBind (expectText "=")
        parseTypedLambdaHead;

  def parseTypedLambdaHead : ParserValue -> Parser ParserValue =
    λ(_bindingEquals : ParserValue)
      parserBind (expectText "lambda")
        parseTypedLambdaOpen;

  def parseTypedLambdaOpen : ParserValue -> Parser ParserValue =
    λ(_lambdaToken : ParserValue)
      parserBind (expectText "(")
        parseTypedLambdaArgument;

  def parseTypedLambdaArgument : ParserValue -> Parser ParserValue =
    λ(_openToken : ParserValue)
      parserBind (expectText "identifier:x")
        parseTypedLambdaArgumentColon;

  def parseTypedLambdaArgumentColon : ParserValue -> Parser ParserValue =
    λ(_argumentToken : ParserValue)
      parserBind (expectText ":")
        parseTypedLambdaArgumentType;

  def parseTypedLambdaArgumentType : ParserValue -> Parser ParserValue =
    λ(_colonToken : ParserValue)
      parserBind (expectText "identifier:Int")
        parseTypedLambdaClose;

  def parseTypedLambdaClose : ParserValue -> Parser ParserValue =
    λ(_typeToken : ParserValue)
      parserBind (expectText ")")
        parseTypedLambdaBody;

  def parseTypedLambdaBody : ParserValue -> Parser ParserValue =
    λ(_closeToken : ParserValue)
      parserBind (expectText "identifier:x")
        parseTypedExpressionIn;

  def parseTypedExpressionIn : ParserValue -> Parser ParserValue =
    λ(_bodyToken : ParserValue)
      parserBind (expectText "in")
        parseTypedApplicationOpen;

  def parseTypedApplicationOpen : ParserValue -> Parser ParserValue =
    λ(_inToken : ParserValue)
      parserBind (expectText "(")
        parseTypedApplicationHead;

  def parseTypedApplicationHead : ParserValue -> Parser ParserValue =
    λ(_openToken : ParserValue)
      parserBind (expectText "identifier:id")
        parseTypedApplicationArgument;

  def parseTypedApplicationArgument : ParserValue -> Parser ParserValue =
    λ(_idToken : ParserValue)
      parserBind (expectText "int:1")
        parseTypedApplicationColon;

  def parseTypedApplicationColon : ParserValue -> Parser ParserValue =
    λ(_argumentToken : ParserValue)
      parserBind (expectText ":")
        parseTypedApplicationType;

  def parseTypedApplicationType : ParserValue -> Parser ParserValue =
    λ(_colonToken : ParserValue)
      parserBind (expectText "identifier:Int")
        parseTypedApplicationClose;

  def parseTypedApplicationClose : ParserValue -> Parser ParserValue =
    λ(_typeToken : ParserValue)
      parserBind (expectText ")")
        parseTypedMainSemicolon;

  def parseTypedMainSemicolon : ParserValue -> Parser ParserValue =
    λ(_closeToken : ParserValue)
      parserBind (expectText ";")
        parseTypedModuleClose;

  def parseTypedModuleClose : ParserValue -> Parser ParserValue =
    λ(_semicolonToken : ParserValue)
      completeModuleKey "typed-annotation";

  def parseDataModule : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectText "module")
        parseDataModuleName;

  def parseDataModuleName : ParserValue -> Parser ParserValue =
    λ(_moduleToken : ParserValue)
      parserBind (expectText "identifier:Main")
        parseDataExportKeyword;

  def parseDataExportKeyword : ParserValue -> Parser ParserValue =
    λ(_nameToken : ParserValue)
      parserBind (expectText "export")
        parseDataExportOpen;

  def parseDataExportOpen : ParserValue -> Parser ParserValue =
    λ(_exportToken : ParserValue)
      parserBind (expectText "(")
        parseDataExportTypeName;

  def parseDataExportTypeName : ParserValue -> Parser ParserValue =
    λ(_openExport : ParserValue)
      parserBind (expectText "identifier:Nat")
        parseDataExportConstructorsOpen;

  def parseDataExportConstructorsOpen : ParserValue -> Parser ParserValue =
    λ(_typeName : ParserValue)
      parserBind (expectText "(")
        parseDataExportFirstDot;

  def parseDataExportFirstDot : ParserValue -> Parser ParserValue =
    λ(_openConstructors : ParserValue)
      parserBind (expectText ".")
        parseDataExportSecondDot;

  def parseDataExportSecondDot : ParserValue -> Parser ParserValue =
    λ(_firstDot : ParserValue)
      parserBind (expectText ".")
        parseDataExportConstructorsClose;

  def parseDataExportConstructorsClose : ParserValue -> Parser ParserValue =
    λ(_secondDot : ParserValue)
      parserBind (expectText ")")
        parseDataExportComma;

  def parseDataExportComma : ParserValue -> Parser ParserValue =
    λ(_closeConstructors : ParserValue)
      parserBind (expectText ",")
        parseDataExportMain;

  def parseDataExportMain : ParserValue -> Parser ParserValue =
    λ(_comma : ParserValue)
      parserBind (expectText "identifier:main")
        parseDataExportClose;

  def parseDataExportClose : ParserValue -> Parser ParserValue =
    λ(_exportMain : ParserValue)
      parserBind (expectText ")")
        parseDataModuleOpen;

  def parseDataModuleOpen : ParserValue -> Parser ParserValue =
    λ(_closeExport : ParserValue)
      parserBind (expectText "{")
        parseDataDeclaration;

  def parseDataDeclaration : ParserValue -> Parser ParserValue =
    λ(_openModule : ParserValue)
      parserBind (expectText "data")
        parseDataDeclarationName;

  def parseDataDeclarationName : ParserValue -> Parser ParserValue =
    λ(_dataToken : ParserValue)
      parserBind (expectText "identifier:Nat")
        parseDataDeclarationEquals;

  def parseDataDeclarationEquals : ParserValue -> Parser ParserValue =
    λ(_dataName : ParserValue)
      parserBind (expectText "=")
        parseDataZeroConstructor;

  def parseDataZeroConstructor : ParserValue -> Parser ParserValue =
    λ(_equalsToken : ParserValue)
      parserBind (expectText "identifier:Zero")
        parseDataZeroColon;

  def parseDataZeroColon : ParserValue -> Parser ParserValue =
    λ(_zeroToken : ParserValue)
      parserBind (expectConstructorColonParser ValueUnit)
        parseDataZeroResult;

  def parseDataZeroResult : ParserValue -> Parser ParserValue =
    λ(_zeroColon : ParserValue)
      parserBind (expectText "identifier:Nat")
        parseDataConstructorSeparator;

  def parseDataConstructorSeparator : ParserValue -> Parser ParserValue =
    λ(_zeroResult : ParserValue)
      parserBind (expectText "|")
        parseDataSuccConstructor;

  def parseDataSuccConstructor : ParserValue -> Parser ParserValue =
    λ(_barToken : ParserValue)
      parserBind (expectText "identifier:Succ")
        parseDataSuccColon;

  def parseDataSuccColon : ParserValue -> Parser ParserValue =
    λ(_succToken : ParserValue)
      parserBind (expectText ":")
        parseDataSuccArgument;

  def parseDataSuccArgument : ParserValue -> Parser ParserValue =
    λ(_succColon : ParserValue)
      parserBind (expectText "identifier:Nat")
        parseDataSuccArrow;

  def parseDataSuccArrow : ParserValue -> Parser ParserValue =
    λ(_succArgument : ParserValue)
      parserBind (expectText "->")
        parseDataSuccResult;

  def parseDataSuccResult : ParserValue -> Parser ParserValue =
    λ(_arrowToken : ParserValue)
      parserBind (expectText "identifier:Nat")
        parseDataDeclarationSemicolon;

  def parseDataDeclarationSemicolon : ParserValue -> Parser ParserValue =
    λ(_succResult : ParserValue)
      parserBind (expectText ";")
        parseDataMainDefKeyword;

  def parseDataMainDefKeyword : ParserValue -> Parser ParserValue =
    λ(_dataSemicolon : ParserValue)
      parserBind (expectText "def")
        parseDataMainDefName;

  def parseDataMainDefName : ParserValue -> Parser ParserValue =
    λ(_defToken : ParserValue)
      parserBind (expectText "identifier:main")
        parseDataMainDefColon;

  def parseDataMainDefColon : ParserValue -> Parser ParserValue =
    λ(_defName : ParserValue)
      parserBind (expectText ":")
        parseDataMainDefType;

  def parseDataMainDefType : ParserValue -> Parser ParserValue =
    λ(_colonToken : ParserValue)
      parserBind (expectText "identifier:Nat")
        parseDataMainDefEquals;

  def parseDataMainDefEquals : ParserValue -> Parser ParserValue =
    λ(_typeToken : ParserValue)
      parserBind (expectText "=")
        parseDataMainExpressionHead;

  def parseDataMainExpressionHead : ParserValue -> Parser ParserValue =
    λ(_equalsToken : ParserValue)
      parserBind (expectText "identifier:Succ")
        parseDataMainExpressionArgument;

  def parseDataMainExpressionArgument : ParserValue -> Parser ParserValue =
    λ(_succValue : ParserValue)
      parserBind (expectText "identifier:Zero")
        parseDataMainDefSemicolon;

  def parseDataMainDefSemicolon : ParserValue -> Parser ParserValue =
    λ(_zeroValue : ParserValue)
      parserBind (expectText ";")
        parseDataModuleClose;

  def parseDataModuleClose : ParserValue -> Parser ParserValue =
    λ(_semicolonToken : ParserValue)
      completeModuleKey "data-constructor-spans";

  def renderParserParityRetryEvidence : String -> String -> String -> String =
    λ(sourceFile : String) λ(sourceText : String) λ(lexerMismatchSourceText : String)
      stringAppend (renderPositiveTokenEvidence sourceFile sourceText)
        (stringAppend "\n"
          (stringAppend (renderLexerNegativeEvidence sourceFile lexerMismatchSourceText)
            (stringAppend "\n" (renderParserNegativeEvidenceFromSourceText "parser negative " sourceFile basicParserNegativeSourceText))));

  def renderPositiveTokenEvidence : String -> String -> String =
    λ(sourceFile : String) λ(sourceText : String) case tokenizeCompleteModule sourceText of {
      LexerOk input -> renderTokenPrefixEvidence sourceFile input;
      LexerError diagnostic -> stringAppend "tokens " (renderDiagnosticEvidence sourceFile diagnostic)
    };

  def renderLexerNegativeEvidence : String -> String -> String =
    λ(sourceFile : String) λ(lexerMismatchSourceText : String) case tokenizeCompleteModule lexerMismatchSourceText of {
      LexerOk _ -> "lexer negative unexpected-success";
      LexerError diagnostic -> stringAppend "lexer negative " (renderDiagnosticEvidence sourceFile diagnostic)
    };

  def basicParserNegativeSourceText : String =
    "module Main export (main) {\n  def main : Bool   true;\n}";

  def renderParserNegativeEvidenceFromSourceText : String -> String -> String -> String =
    λ(prefix : String) λ(sourceFile : String) λ(sourceText : String)
      renderParserNegativeEvidence prefix sourceFile (parseCompleteModule sourceText);

  def renderParserNegativeEvidence : String -> String -> ParserResult -> String =
    λ(prefix : String) λ(sourceFile : String) λ(result : ParserResult) case result of {
      ParserOk _ -> stringAppend prefix "unexpected-success";
      ParserError diagnostic -> stringAppend prefix (renderDiagnosticEvidence sourceFile diagnostic)
    };

  def renderDiagnosticEvidence : String -> ParserDiagnostic -> String =
    λ(sourceFile : String) λ(diagnostic : ParserDiagnostic) case diagnostic of {
      UnexpectedSourceText span -> stringAppend "unexpected-source@" (renderSpan sourceFile span);
      ExpectedCompleteModule span -> stringAppend "expected-complete-module@" (renderSpan sourceFile span);
      ExpectedEquals span -> stringAppend "expected-equals@" (renderSpan sourceFile span);
      ExpectedImportSemicolon span -> stringAppend "expected-import-semicolon@" (renderSpan sourceFile span);
      ExpectedDefSemicolon span -> stringAppend "expected-def-semicolon@" (renderSpan sourceFile span);
      ExpectedLetIn span -> stringAppend "expected-let-in@" (renderSpan sourceFile span);
      ExpectedLetAnnotationType span -> stringAppend "expected-let-annotation-type@" (renderSpan sourceFile span);
      ExpectedConstructorColon span -> stringAppend "expected-constructor-colon@" (renderSpan sourceFile span)
    };
}
