      parserFail (ExpectedCompleteModule basicUnexpectedSpan);

  def parseImportLedBodyRows : String -> String -> String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleStart : String) λ(moduleName : String) λ(exportRows : String) λ(_start : ParserValue)
      parserBind (parseImportProjectionRows sourceFile ValueUnit)
        (parseImportedMainDefinition sourceFile moduleStart moduleName exportRows);

  def parseImportProjectionRows : String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(_start : ParserValue)
      parserBind (expectText "import")
        (parseImportProjectionModuleName sourceFile);

  def parseImportProjectionModuleName : String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(_importToken : ParserValue)
      parserBind expectAnyIdentifier
        (parseImportProjectionExposingKeyword sourceFile);

  def parseImportProjectionExposingKeyword : String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleNameToken : ParserValue)
      parserBind (expectText "exposing")
        (parseImportProjectionOpen sourceFile moduleNameToken);

  def parseImportProjectionOpen : String -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleNameToken : ParserValue) λ(exposingToken : ParserValue)
      parserBind (expectText "(")
        (parseImportProjectionList sourceFile moduleNameToken exposingToken);

  def parseImportProjectionList : String -> ParserValue -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleNameToken : ParserValue) λ(exposingToken : ParserValue) λ(_openImport : ParserValue)
      parserBind (parseImportProjectionItem sourceFile ValueUnit)
        (prependImportModuleRows sourceFile moduleNameToken exposingToken);

  def prependImportModuleRows : String -> ParserValue -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleNameToken : ParserValue) λ(exposingToken : ParserValue) λ(itemRows : ParserValue) case moduleNameToken of {
      ValueToken _ -> case itemRows of {
        ValueProjectionRows rows ->
          parseImportProjectionMoreOrClose sourceFile moduleNameToken
            (ValueProjectionRows
              (appendLine (importModuleRows sourceFile (moduleNameFromValue moduleNameToken) (spanFromTokenStartToTokenStart moduleNameToken exposingToken)) rows));
        ValueModuleKey _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
        ValueToken _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
        ValueUnit -> parserFail (ExpectedCompleteModule basicUnexpectedSpan)
      };
      ValueProjectionRows _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueModuleKey _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueUnit -> parserFail (ExpectedCompleteModule basicUnexpectedSpan)
    };

  def parseImportProjectionMoreOrClose : String -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleNameToken : ParserValue) λ(itemRows : ParserValue)
      parseImportProjectionMoreOrClose3 sourceFile moduleNameToken itemRows;

  def parseImportProjectionMoreOrClose3 : String -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleNameToken : ParserValue) λ(itemRows : ParserValue)
      parserChoice
        (parserBind (expectText ",") (parseImportProjectionNextItem3 sourceFile moduleNameToken itemRows))
        (parserChoice
          (parserBind (expectText ")") (parseImportProjectionSemicolon itemRows))
          parserFailExpectedImportExposingSeparatorAtCurrent);

  def parseImportProjectionNextItem3 : String -> ParserValue -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleNameToken : ParserValue) λ(rowsValue : ParserValue) λ(_comma : ParserValue)
      parserBind (parseImportProjectionItem sourceFile ValueUnit)
        (appendImportProjectionRowsAndContinue2 sourceFile moduleNameToken rowsValue);

  def parseImportProjectionSemicolon : ParserValue -> ParserValue -> Parser ParserValue =
    λ(itemsRows : ParserValue) λ(_closeImport : ParserValue)
      parserBind expectImportSemicolonAtCurrent
        (λ(_semicolon : ParserValue) parserPure itemsRows);

  def appendImportProjectionRowsAndContinue2 : String -> ParserValue -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleNameToken : ParserValue) λ(existingRows : ParserValue) λ(nextRows : ParserValue)
      parserBind (appendProjectionValues existingRows nextRows) (parseImportProjectionMoreOrClose2 sourceFile moduleNameToken);

  def parseImportProjectionMoreOrClose2 : String -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleNameToken : ParserValue) λ(itemRows : ParserValue)
      parserChoice
        (parserBind (expectText ",") (parseImportProjectionNextItem2 sourceFile moduleNameToken itemRows))
        (parserChoice
          (parserBind (expectText ")") (parseImportProjectionSemicolon itemRows))
          parserFailExpectedImportExposingSeparatorAtCurrent);

