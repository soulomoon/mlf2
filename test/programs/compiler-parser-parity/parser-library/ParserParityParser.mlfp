      parserBind (expectText "}")
        recursiveGadtModuleValue;

  def recursiveGadtModuleValue : ParserValue -> Parser ParserValue =
    λ(_closeModule : ParserValue)
      moduleKey recursiveGadtProjectionKey;

  def parseExistentialBody : ParserValue -> Parser ParserValue =
