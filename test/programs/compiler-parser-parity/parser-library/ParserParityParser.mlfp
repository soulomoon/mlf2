module ParserParityParser export (ParserResult(..), parseCompleteProgram, parseCompleteModule, parseTokens, renderParserParityProjectionFromSourceText, renderParserParityRetryEvidence, renderParserNegativeEvidenceFromSourceText) {
  import Prelude exposing (Option(..), stringAppend, stringCharAtOption, stringDrop, stringFromChar, stringIndexOf, stringTake);
  import ParserParityAst exposing (ParsedModule(..), renderParsedModule);
  import ParserParityDiagnostic exposing (ParserDiagnostic(..));
  import ParserParityLexer exposing (LexerResult(..), nextLineNumber, tokenizeCompleteModule);
  import ParserParityParserCombinator exposing (Parser, ParserEnd(..), ParserState(..), ParserStep(..), ParserValue(..), captureSpan, diagnosticLabel, expectIdentifierToken, expectToken, expectTokenPrefix, labelCaseBranchArrow, labelConstructorColon, labelConstructorForallDot, labelDefSemicolon, labelEquals, labelFunctionalDependencyArrow, labelImportAlias, labelImportSemicolon, labelInstanceMethodEquals, labelLetAnnotationType, labelLetIn, labelTypeFamilyEquationEquals, labelUnexpectedSource, parserBind, parserChoice, parserCurrentTokenStartOr, parserFail, parserFailExpectedConstructorForallDotAtCurrent, parserFailExpectedExpressionCloseParenAtCurrent, parserFailExpectedImportExposingSeparatorAtCurrent, parserFailExpectedImportSemicolonAtCurrent, parserPure, parserReturnAtEndOr, parserStateAtEnd, runParser);
  import ParserParitySource exposing (basicBoolLiteralSpan, basicUnexpectedSpan, caseBranchArrowSpan, constructorForallDotSpan, dataZeroColonSpan, existentialForallExprDataSpan, existentialForallMainDefSpan, existentialForallModuleSpan, existentialForallNatDataSpan, existentialForallSomeExprDataSpan, existentialForallUnwrapSomeDefSpan, importBoolSemicolonSpan, letInSpan, lexerUnknownSpan, multiparamFundepArrowSpan, qualifiedImportAliasDiagnosticSpan, recursiveGadtDoneNowDefSpan, recursiveGadtExprDataSpan, recursiveGadtMainDefSpan, recursiveGadtModuleSpan, recursiveGadtNatDataSpan, renderSpan, typedLetForallSpan, typeFamilyEquationEqualsSpan, typeclassInstanceMethodEqualsSpan, valueFirstDefSemicolonSpan);
  import ParserParityToken exposing (ParserInput(..), TokenKind(..), renderTokenPrefixEvidence, tokenEnd, tokenSpan, tokenStart, tokenText);

  data ParserResult =
      ParserOk : String -> ParserResult
    | ParserError : ParserDiagnostic -> ParserResult;

  def renderParserParityProjectionFromSourceText : String -> String -> String =
    λ(sourceFile : String) λ(sourceText : String) case parseCompleteProgramWithSourceFile sourceFile sourceText of {
      ParserOk key -> renderParsedModuleOrProjection sourceFile key;
      ParserError _ -> "parser-error"
    };

  def parseCompleteProgram : String -> ParserResult =
    λ(sourceText : String) parseCompleteProgramWithSourceFile "" sourceText;

  def parseCompleteProgramWithSourceFile : String -> String -> ParserResult =
    λ(sourceFile : String)
    λ(sourceText : String) case tokenizeCompleteModule sourceText of {
      LexerOk input -> parseTokensWithSourceFile sourceFile input;
      LexerError diagnostic -> ParserError diagnostic
    };

  def parseCompleteModule : String -> ParserResult =
    λ(sourceText : String) parseCompleteProgram sourceText;

  def parseTokens : ParserInput -> ParserResult =
    λ(input : ParserInput) parseTokensWithSourceFile "" input;

  def parseTokensWithSourceFile : String -> ParserInput -> ParserResult =
    λ(sourceFile : String)
    λ(input : ParserInput) case input of {
      ParserInput source -> parserReplyToResult (runParser (parseAnyProgram sourceFile ValueUnit) (ParserState source))
    };

  def parserReplyToResult : ParserStep -> ParserResult =
    λ(reply : ParserStep) case reply of {
      ParserStepOk state value -> case parserStateAtEnd state of {
        ParserAtEnd -> case value of {
          ValueModuleKey key -> ParserOk key;
          ValueProjectionRows rows -> ParserOk rows;
          ValueUnit -> ParserError (ExpectedCompleteModule basicUnexpectedSpan);
          ValueToken _ -> ParserError (ExpectedCompleteModule basicUnexpectedSpan)
        };
        ParserNotAtEnd -> ParserError (ExpectedCompleteModule basicUnexpectedSpan);
        ParserEndUnknown -> ParserError (ExpectedCompleteModule basicUnexpectedSpan)
      };
      ParserStepError diagnostic -> ParserError diagnostic
    };

  def expectComplete : TokenKind -> Parser ParserValue =
    λ(kind : TokenKind) diagnosticLabel (captureSpan (expectToken kind basicUnexpectedSpan));

  def expectEqualsParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue) labelEquals (captureSpan (expectToken (TokenKind "=") basicBoolLiteralSpan));

  def expectImportSemicolonParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (expectText ";") (parserFail (ExpectedImportSemicolon importBoolSemicolonSpan));

  def expectImportAliasParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      labelImportAlias
        (parserChoice (expectText "identifier:C") (parserFail (ExpectedImportAlias qualifiedImportAliasDiagnosticSpan)));

  def expectDefSemicolonParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (expectText ";") (parserFail (ExpectedDefSemicolon valueFirstDefSemicolonSpan));

  def expectLetInParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (expectText "in") (parserFail (ExpectedLetIn letInSpan));

  def expectLetAnnotationTypeParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (expectText "forall") (parserFail (ExpectedLetAnnotationType typedLetForallSpan));

  def expectConstructorColonParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (expectText ":") (parserFail (ExpectedConstructorColon dataZeroColonSpan));

  def expectCaseBranchArrowParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (expectText "->") (parserFail (ExpectedCaseBranchArrow caseBranchArrowSpan));

  def expectInstanceMethodEqualsParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      labelInstanceMethodEquals
        (parserChoice (expectText "=") (parserFail (ExpectedInstanceMethodEquals typeclassInstanceMethodEqualsSpan)));

  def expectFunctionalDependencyArrowParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      labelFunctionalDependencyArrow
        (parserChoice (expectText "→") (parserFail (ExpectedFunctionalDependencyArrow multiparamFundepArrowSpan)));

  def expectTypeFamilyEquationEqualsParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      labelTypeFamilyEquationEquals
        (parserChoice (expectText "=") (parserFail (ExpectedTypeFamilyEquationEquals typeFamilyEquationEqualsSpan)));

  def expectConstructorForallDotParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      labelConstructorForallDot
        (parserChoice (expectText ".") (parserFail (ExpectedConstructorForallDot constructorForallDotSpan)));

  def expectForallDotParser : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (expectText ".") parserFailExpectedConstructorForallDotAtCurrent;

  def expectText : String -> Parser ParserValue =
    λ(text : String) expectComplete (TokenKind text);

  def expectCharLiteralToken : Parser ParserValue =
    expectTokenPrefix "char-literal:" basicUnexpectedSpan;

  def expectStringLiteralToken : Parser ParserValue =
    expectTokenPrefix "string-literal:" basicUnexpectedSpan;

  def expectImportSemicolonAtCurrent : Parser ParserValue =
    parserChoice (expectText ";") parserFailExpectedImportSemicolonAtCurrent;

  def moduleKey : String -> Parser ParserValue =
    λ(key : String) parserPure (ValueModuleKey key);

  def completeModuleKey : String -> Parser ParserValue =
    λ(key : String)
      parserBind (expectText "}")
        (λ(_closeToken : ParserValue) moduleKey key);

  def renderParsedModuleOrProjection : String -> String -> String =
    λ(sourceFile : String) λ(key : String) case stringIndexOf key "module " of {
      Some _ -> key;
      None -> renderParsedModule sourceFile (ParsedModule key)
    };

  def expectAnyIdentifier : Parser ParserValue =
    expectIdentifierToken basicUnexpectedSpan;

  def identifierNameFromTokenText : String -> String =
    λ(text : String) stringDrop text 11;

  def identifierNameFromValue : ParserValue -> String =
    λ(value : ParserValue) case value of {
      ValueToken token -> identifierNameFromTokenText (tokenText token);
      ValueProjectionRows _ -> "unknown";
      ValueModuleKey _ -> "unknown";
      ValueUnit -> "unknown"
    };

  def charLiteralTextFromValue : ParserValue -> String =
    λ(value : ParserValue) case value of {
      ValueToken token -> stringDrop (tokenText token) 13;
      ValueProjectionRows _ -> "unknown";
      ValueModuleKey _ -> "unknown";
      ValueUnit -> "unknown"
    };

  def stringLiteralTextFromValue : ParserValue -> String =
    λ(value : ParserValue) case value of {
      ValueToken token -> stringDrop (tokenText token) 15;
      ValueProjectionRows _ -> "unknown";
      ValueModuleKey _ -> "unknown";
      ValueUnit -> "unknown"
    };

  def projectionExportKindPrefix : String -> String =
    λ(name : String) case stringCharAtOption name 0 of {
      None -> "export value ";
      Some firstChar -> case stringIndexOf "ABCDEFGHIJKLMNOPQRSTUVWXYZ" (stringFromChar firstChar) of {
        None -> "export value ";
        Some _ -> "export type "
      }
    };

  def projectionImportKindPrefix : String -> String =
    λ(name : String) case stringCharAtOption name 0 of {
      None -> "import exposing value ";
      Some firstChar -> case stringIndexOf "ABCDEFGHIJKLMNOPQRSTUVWXYZ" (stringFromChar firstChar) of {
        None -> "import exposing value ";
        Some _ -> "import exposing type "
      }
    };

  def spanFromTokenBounds : ParserValue -> ParserValue -> String =
    λ(startValue : ParserValue) λ(endValue : ParserValue) case startValue of {
      ValueToken startToken -> case endValue of {
        ValueToken endToken -> stringAppend (tokenStart startToken) (stringAppend "-" (tokenEnd endToken));
        ValueProjectionRows _ -> basicUnexpectedSpan;
        ValueModuleKey _ -> basicUnexpectedSpan;
        ValueUnit -> basicUnexpectedSpan
      };
      ValueProjectionRows _ -> basicUnexpectedSpan;
      ValueModuleKey _ -> basicUnexpectedSpan;
      ValueUnit -> basicUnexpectedSpan
    };

  def spanFromTokenStartToTokenStart : ParserValue -> ParserValue -> String =
    λ(startValue : ParserValue) λ(endValue : ParserValue) case startValue of {
      ValueToken startToken -> case endValue of {
        ValueToken endToken -> stringAppend (tokenStart startToken) (stringAppend "-" (tokenStart endToken));
        ValueProjectionRows _ -> basicUnexpectedSpan;
        ValueModuleKey _ -> basicUnexpectedSpan;
        ValueUnit -> basicUnexpectedSpan
      };
      ValueProjectionRows _ -> basicUnexpectedSpan;
      ValueModuleKey _ -> basicUnexpectedSpan;
      ValueUnit -> basicUnexpectedSpan
    };

  def coordinateFromValue : ParserValue -> String =
    λ(value : ParserValue) case value of {
      ValueModuleKey coordinate -> coordinate;
      ValueToken token -> tokenStart token;
      ValueProjectionRows _ -> basicUnexpectedSpan;
      ValueUnit -> basicUnexpectedSpan
    };

  def tokenStartCoordinate : ParserValue -> String =
    λ(value : ParserValue) case value of {
      ValueToken token -> tokenStart token;
      ValueModuleKey coordinate -> coordinate;
      ValueProjectionRows _ -> basicUnexpectedSpan;
      ValueUnit -> basicUnexpectedSpan
    };

  def tokenEndCoordinate : ParserValue -> String =
    λ(value : ParserValue) case value of {
      ValueToken token -> tokenEnd token;
      ValueModuleKey coordinate -> coordinate;
      ValueProjectionRows _ -> basicUnexpectedSpan;
      ValueUnit -> basicUnexpectedSpan
    };

  def parserTextFromValue : ParserValue -> String =
    λ(value : ParserValue) case value of {
      ValueProjectionRows text -> text;
      ValueToken token -> tokenText token;
      ValueModuleKey _ -> "unknown";
      ValueUnit -> "unknown"
    };

  def parserTextValue : String -> Parser ParserValue =
    λ(text : String) parserPure (ValueProjectionRows text);

  def intLiteralTextFromValue : ParserValue -> String =
    λ(value : ParserValue) case value of {
      ValueToken token -> stringDrop (tokenText token) 4;
      ValueModuleKey _ -> "unknown";
      ValueProjectionRows _ -> "unknown";
      ValueUnit -> "unknown"
    };

  def spanFromStartToCoordinate : String -> ParserValue -> String =
    λ(startCoordinate : String) λ(endCoordinate : ParserValue)
      stringAppend startCoordinate (stringAppend "-" (coordinateFromValue endCoordinate));

  def lineStartAfterColumnOne : String -> String =
    λ(coordinate : String) case stringIndexOf coordinate ":1" of {
      None -> coordinate;
      Some colonIndex -> stringAppend (nextLineNumber (stringTake coordinate colonIndex)) ":1"
    };

  def spanFromStartToTokenStart : String -> ParserValue -> String =
    λ(startCoordinate : String) λ(endValue : ParserValue)
      stringAppend startCoordinate (stringAppend "-" (tokenStartCoordinate endValue));

  def appendLine : String -> String -> String =
    λ(line : String) λ(rest : String)
      stringAppend line (stringAppend "\n" rest);

  def spanText : String -> String -> String =
    λ(sourceFile : String) λ(coordinates : String)
      renderSpan sourceFile coordinates;

  def projectionText : String -> Parser ParserValue =
    λ(rows : String) parserPure (ValueProjectionRows rows);

  def projectionLine : String -> String -> String -> String =
    λ(sourceFile : String) λ(prefix : String) λ(coordinates : String)
      stringAppend prefix (spanText sourceFile coordinates);

  def moduleRows : String -> String -> String -> String -> String =
    λ(sourceFile : String) λ(moduleName : String) λ(coordinates : String) λ(bodyRows : String)
      appendLine (projectionLine sourceFile (stringAppend (stringAppend "module " moduleName) " span=") coordinates) bodyRows;

  def exportTypeRows : String -> String -> String -> String =
    λ(sourceFile : String) λ(name : String) λ(coordinates : String)
      projectionLine sourceFile (stringAppend (stringAppend "export type " name) " span=") coordinates;

  def exportTypeWithConstructorsRows : String -> String -> String -> String =
    λ(sourceFile : String) λ(name : String) λ(coordinates : String)
      projectionLine sourceFile (stringAppend (stringAppend "export type-with-constructors " name) " span=") coordinates;

  def exportValueRows : String -> String -> String -> String =
    λ(sourceFile : String) λ(name : String) λ(coordinates : String)
      projectionLine sourceFile (stringAppend (stringAppend "export value " name) " span=") coordinates;

  def importModuleRows : String -> String -> String -> String =
    λ(sourceFile : String) λ(name : String) λ(coordinates : String)
      projectionLine sourceFile (stringAppend (stringAppend "import " name) " span=") coordinates;

  def importExposingTypeRows : String -> String -> String -> String =
    λ(sourceFile : String) λ(name : String) λ(coordinates : String)
      projectionLine sourceFile (stringAppend (stringAppend "import exposing type " name) " span=") coordinates;

  def importExposingTypeWithConstructorsRows : String -> String -> String -> String =
    λ(sourceFile : String) λ(name : String) λ(coordinates : String)
      projectionLine sourceFile (stringAppend (stringAppend "import exposing type-with-constructors " name) " span=") coordinates;

  def importExposingValueRows : String -> String -> String -> String =
    λ(sourceFile : String) λ(name : String) λ(coordinates : String)
      projectionLine sourceFile (stringAppend (stringAppend "import exposing value " name) " span=") coordinates;

  def dataRows : String -> String -> String -> String =
    λ(sourceFile : String) λ(name : String) λ(coordinates : String)
      projectionLine sourceFile (stringAppend (stringAppend "data " name) " span=") coordinates;

  def dataParamRows : String -> String -> String -> String -> String =
    λ(sourceFile : String) λ(name : String) λ(params : String) λ(coordinates : String)
      projectionLine sourceFile (stringAppend (stringAppend (stringAppend "data " name) (stringAppend " params=" params)) " span=") coordinates;

  def constructorRows : String -> String -> String -> String -> String =
    λ(sourceFile : String) λ(name : String) λ(ty : String) λ(coordinates : String)
      projectionLine sourceFile (stringAppend (stringAppend (stringAppend "constructor " name) (stringAppend " type=" ty)) " span=") coordinates;

  def classRows : String -> String -> String -> String -> String =
    λ(sourceFile : String) λ(name : String) λ(params : String) λ(coordinates : String)
      projectionLine sourceFile (stringAppend (stringAppend (stringAppend "class " name) (stringAppend " params=" params)) " span=") coordinates;

  def methodSignatureRows : String -> String -> String -> String -> String =
    λ(sourceFile : String) λ(name : String) λ(ty : String) λ(coordinates : String)
      projectionLine sourceFile (stringAppend (stringAppend (stringAppend "method-signature " name) (stringAppend " type=" ty)) " span=") coordinates;

  def defRows : String -> String -> String -> String -> String -> String =
    λ(sourceFile : String) λ(name : String) λ(ty : String) λ(expr : String) λ(coordinates : String)
      projectionLine sourceFile (stringAppend (stringAppend (stringAppend (stringAppend "def " name) (stringAppend " type=" ty)) (stringAppend " expr=" expr)) " span=") coordinates;

  def projectionLineFromSpan : String -> String -> String -> Parser ParserValue =
    λ(sourceFile : String) λ(prefix : String) λ(coordinates : String)
      projectionText (projectionLine sourceFile prefix coordinates);

  def projectionLineFromToken : String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(prefix : String) λ(value : ParserValue) case value of {
      ValueToken token -> projectionLineFromSpan sourceFile prefix (tokenSpan token);
      ValueProjectionRows _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueModuleKey _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueUnit -> parserFail (ExpectedCompleteModule basicUnexpectedSpan)
    };

  def appendProjectionValues : ParserValue -> ParserValue -> Parser ParserValue =
    λ(firstValue : ParserValue) λ(secondValue : ParserValue) case firstValue of {
      ValueProjectionRows firstRows -> case secondValue of {
        ValueProjectionRows secondRows -> projectionText (appendLine firstRows secondRows);
        ValueModuleKey _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
        ValueToken _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
        ValueUnit -> parserFail (ExpectedCompleteModule basicUnexpectedSpan)
      };
      ValueModuleKey _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueToken _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueUnit -> parserFail (ExpectedCompleteModule basicUnexpectedSpan)
    };

  def appendDeclarationSecondRows : String -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(existingRows : ParserValue) λ(nextRows : ParserValue)
      parserBind (appendProjectionValues existingRows nextRows) (parseDeclarationThirdOrDone sourceFile);

  def appendDeclarationThirdRows : String -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(existingRows : ParserValue) λ(nextRows : ParserValue)
      parserBind (appendProjectionValues existingRows nextRows) (parseDeclarationFourthOrDone sourceFile);

  def appendDeclarationFourthRows : ParserValue -> ParserValue -> Parser ParserValue =
    λ(existingRows : ParserValue) λ(nextRows : ParserValue)
      appendProjectionValues existingRows nextRows;

  def parseAnyProgram : String -> ParserValue -> Parser ParserValue =
    λ(_sourceFile : String) λ(_start : ParserValue)
      parserChoice (parseCompleteMultiModuleProgram _sourceFile ValueUnit) (parseAnyModule ValueUnit);

  def parseCompleteMultiModuleProgram : String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(_start : ParserValue)
      parserBind (parseSharedProgramModule sourceFile ValueUnit)
        (parseCompleteProgramTail sourceFile);

  def parseCompleteProgramTail : String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleValue : ParserValue) case moduleValue of {
      ValueProjectionRows rows -> parseProgramSecondModuleOrDone sourceFile rows;
      ValueModuleKey _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueToken _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueUnit -> parserFail (ExpectedCompleteModule basicUnexpectedSpan)
    };

  def parseProgramSecondModuleOrDone : String -> String -> Parser ParserValue =
    λ(sourceFile : String) λ(rows : String)
      parserReturnAtEndOr (ValueProjectionRows rows)
        (parserBind (parseSharedProgramModule sourceFile ValueUnit) (appendSecondProgramModuleRows sourceFile rows));

  def appendSecondProgramModuleRows : String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(existingRows : String) λ(moduleValue : ParserValue) case moduleValue of {
      ValueProjectionRows moduleRows -> parseProgramThirdModuleOrDone sourceFile (appendLine existingRows moduleRows);
      ValueModuleKey _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueToken _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueUnit -> parserFail (ExpectedCompleteModule basicUnexpectedSpan)
    };

  def parseProgramThirdModuleOrDone : String -> String -> Parser ParserValue =
    λ(sourceFile : String) λ(rows : String)
      parserReturnAtEndOr (ValueProjectionRows rows)
        (parserBind (parseSharedProgramModule sourceFile ValueUnit) (appendThirdProgramModuleRows sourceFile rows));

  def appendThirdProgramModuleRows : String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(existingRows : String) λ(moduleValue : ParserValue) case moduleValue of {
      ValueProjectionRows moduleRows -> parseProgramFourthModuleOrDone sourceFile (appendLine existingRows moduleRows);
      ValueModuleKey _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueToken _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueUnit -> parserFail (ExpectedCompleteModule basicUnexpectedSpan)
    };

  def parseProgramFourthModuleOrDone : String -> String -> Parser ParserValue =
    λ(sourceFile : String) λ(rows : String)
      parserReturnAtEndOr (ValueProjectionRows rows)
        (parserBind (parseSharedProgramModule sourceFile ValueUnit) (appendFourthProgramModuleRows rows));

  def appendFourthProgramModuleRows : String -> ParserValue -> Parser ParserValue =
    λ(existingRows : String) λ(moduleValue : ParserValue) case moduleValue of {
      ValueProjectionRows moduleRows -> parserPure (ValueProjectionRows (appendLine existingRows moduleRows));
      ValueModuleKey _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueToken _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueUnit -> parserFail (ExpectedCompleteModule basicUnexpectedSpan)
    };

  def parseAnyModule : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserChoice (parseBasicModule ValueUnit)
        (parserChoice (parseImportModule ValueUnit)
          (parserChoice (parseQualifiedImportSyntax ValueUnit)
            (parserChoice (parseValueModule ValueUnit)
            (parserChoice (parseLetModule ValueUnit)
              (parserChoice (parseTypedModule ValueUnit)
                (parserChoice (parseDataModule ValueUnit)
                  (parserChoice (parseCaseModule ValueUnit)
                    (parserChoice (parseTypeclassModule ValueUnit)
                      (parserChoice (parseKindedConstraintModule ValueUnit)
                      (parserChoice (parseClosedTypeFamilySyntax ValueUnit) (parseRecursiveAdtSyntax ValueUnit)))))))))));

  def parseSharedProgramModule : String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(_start : ParserValue)
      parserBind (expectText "module")
        (parseSharedModuleName sourceFile);

  def parseSharedModuleName : String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleToken : ParserValue)
      parserBind expectAnyIdentifier
        (parseProgramModuleExportKeyword sourceFile (tokenStartCoordinate moduleToken));

  def parseProgramModuleExportKeyword : String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleStart : String) λ(moduleNameToken : ParserValue)
      parserBind (expectText "export")
        (parseProgramModuleExportOpen sourceFile moduleStart moduleNameToken);

  def parseProgramModuleExportOpen : String -> String -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleStart : String) λ(moduleNameToken : ParserValue) λ(_exportToken : ParserValue)
      parserBind (expectText "(")
        (parseProgramModuleExportRows sourceFile moduleStart moduleNameToken);

  def parseProgramModuleExportRows : String -> String -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleStart : String) λ(moduleNameToken : ParserValue) λ(_openExport : ParserValue)
      parserBind (parseProjectionExportList sourceFile ValueUnit)
        (parseProgramModuleExportClose sourceFile moduleStart moduleNameToken);

  def parseProgramModuleExportClose : String -> String -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleStart : String) λ(moduleNameToken : ParserValue) λ(exportRowsValue : ParserValue) case exportRowsValue of {
      ValueProjectionRows exportRows ->
        parserBind (expectText ")")
          (parseProgramModuleBodyOpen sourceFile moduleStart (moduleNameFromValue moduleNameToken) exportRows);
      ValueModuleKey _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueToken _ -> parserFail (ExpectedCompleteModule basicUnexpectedSpan);
      ValueUnit -> parserFail (ExpectedCompleteModule basicUnexpectedSpan)
    };

  def moduleNameFromValue : ParserValue -> String =
    λ(value : ParserValue) case value of {
      ValueToken token -> moduleNameFromTokenText (tokenText token);
      ValueProjectionRows _ -> "unknown";
      ValueModuleKey _ -> "unknown";
      ValueUnit -> "unknown"
    };

  def moduleNameFromTokenText : String -> String =
    λ(text : String) identifierNameFromTokenText text;

  def parseProgramModuleBodyOpen : String -> String -> String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleStart : String) λ(moduleName : String) λ(exportRows : String) λ(_closeExport : ParserValue)
      parserBind (expectText "{")
        (parseProgramModuleBodyRows sourceFile moduleStart moduleName exportRows);

  def parseProgramModuleBodyRows : String -> String -> String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleStart : String) λ(moduleName : String) λ(exportRows : String) λ(_openModule : ParserValue)
      parserChoice (parseDeclarationLedBodyRows sourceFile moduleStart moduleName exportRows ValueUnit)
        (parserChoice
          (parseImportLedBodyRows sourceFile moduleStart moduleName exportRows ValueUnit)
          (parseDefinitionLedBodyRows sourceFile moduleStart moduleName exportRows ValueUnit));

  def parseDefinitionLedBodyRows : String -> String -> String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleStart : String) λ(moduleName : String) λ(exportRows : String) λ(_start : ParserValue)
      parserBind (parseSourceDefinitionRows sourceFile ValueUnit)
        (parseSecondSourceDefinitionRows sourceFile moduleStart moduleName exportRows);

  def parseSecondSourceDefinitionRows : String -> String -> String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleStart : String) λ(moduleName : String) λ(exportRows : String) λ(firstRows : ParserValue)
      parserBind (parseSourceDefinitionRows sourceFile ValueUnit)
        (appendFirstSecondSourceDefinitionRows sourceFile moduleStart moduleName exportRows firstRows);

  def appendFirstSecondSourceDefinitionRows : String -> String -> String -> String -> ParserValue -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleStart : String) λ(moduleName : String) λ(exportRows : String) λ(firstRows : ParserValue) λ(secondRows : ParserValue)
      parserBind (appendProjectionValues firstRows secondRows)
        (parseThirdSourceDefinitionRows sourceFile moduleStart moduleName exportRows);

  def parseThirdSourceDefinitionRows : String -> String -> String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(moduleStart : String) λ(moduleName : String) λ(exportRows : String) λ(firstTwoRows : ParserValue)
      parserBind (parseSourceDefinitionRows sourceFile ValueUnit)
        (finishExactModuleBodyRows sourceFile moduleStart moduleName exportRows firstTwoRows);

  def parseSourceDefinitionRows : String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(_start : ParserValue)
      parserBind (expectText "def")
        (parseSourceDefinitionName sourceFile);

  def parseSourceDefinitionName : String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(defToken : ParserValue)
      parserBind expectAnyIdentifier
        (parseSourceDefinitionColon sourceFile (tokenStartCoordinate defToken));

  def parseSourceDefinitionColon : String -> String -> ParserValue -> Parser ParserValue =
    λ(sourceFile : String) λ(defStart : String) λ(nameToken : ParserValue)
      parserBind (expectText ":")
        (parseSourceDefinitionType sourceFile defStart nameToken);

  def parseSourceDefinitionType : String -> String -> ParserValue -> ParserValue -> Parser ParserValue =
