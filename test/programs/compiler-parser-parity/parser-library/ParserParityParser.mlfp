  def parseExprAType : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectIdentifier "Expr")
        parseExprATypeArgument;

  def parseExprATypeArgument : ParserValue -> Parser ParserValue =
    λ(_typeHead : ParserValue)
      parserBind (expectIdentifier "a")
        parsedUnit;

  def parseExprNatType : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectIdentifier "Expr")
        parseExprNatTypeArgument;

  def parseExprNatTypeArgument : ParserValue -> Parser ParserValue =
    λ(_typeHead : ParserValue)
      parserBind (expectIdentifier "Nat")
        parsedUnit;

  def parseDoneNowDefinition : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectText "def")
        parseDoneNowDefinitionName;

  def parseDoneNowDefinitionName : ParserValue -> Parser ParserValue =
    λ(_defToken : ParserValue)
      parserBind (expectIdentifier "doneNow")
        parseDoneNowDefinitionColon;

  def parseDoneNowDefinitionColon : ParserValue -> Parser ParserValue =
    λ(_defName : ParserValue)
      parserBind (expectText ":")
        parseDoneNowDefinitionArgumentType;

  def parseDoneNowDefinitionArgumentType : ParserValue -> Parser ParserValue =
    λ(_colon : ParserValue)
      parserBind (parseExprAType ValueUnit)
        parseDoneNowDefinitionTypeArrow;

  def parseDoneNowDefinitionTypeArrow : ParserValue -> Parser ParserValue =
    λ(_argumentType : ParserValue)
      parserBind (expectText "->")
        parseDoneNowDefinitionResultType;

  def parseDoneNowDefinitionResultType : ParserValue -> Parser ParserValue =
    λ(_arrow : ParserValue)
      parserBind (expectIdentifier "Bool")
        parseDoneNowDefinitionEquals;

  def parseDoneNowDefinitionEquals : ParserValue -> Parser ParserValue =
    λ(_resultType : ParserValue)
      parserBind (expectEqualsParser ValueUnit)
        parseDoneNowLambda;

  def parseDoneNowLambda : ParserValue -> Parser ParserValue =
    λ(_equals : ParserValue)
      parserBind (parsePlainLambdaParameter "expr" ValueUnit)
        parseDoneNowCaseExpression;

  def parseDoneNowCaseExpression : ParserValue -> Parser ParserValue =
    λ(_lambda : ParserValue)
      parserBind (expectText "case")
        parseDoneNowCaseScrutinee;

  def parseDoneNowCaseScrutinee : ParserValue -> Parser ParserValue =
    λ(_caseToken : ParserValue)
      parserBind (expectIdentifier "expr")
        parseDoneNowCaseOf;

  def parseDoneNowCaseOf : ParserValue -> Parser ParserValue =
    λ(_scrutinee : ParserValue)
      parserBind (expectText "of")
        parseDoneNowCaseBranchesOpen;

  def parseDoneNowCaseBranchesOpen : ParserValue -> Parser ParserValue =
    λ(_ofToken : ParserValue)
      parserBind (expectText "{")
        parseDoneNatWildcardBoolBranch;

  def parseDoneNatWildcardBoolBranch : ParserValue -> Parser ParserValue =
    λ(_openBranches : ParserValue)
      parserBind (expectIdentifier "DoneNat")
        parseDoneNatWildcardPatternArgument;

  def parseDoneNatWildcardPatternArgument : ParserValue -> Parser ParserValue =
    λ(_constructor : ParserValue)
      parserBind (expectText "_")
        parseDoneNatWildcardBranchArrow;

  def parseDoneNatWildcardBranchArrow : ParserValue -> Parser ParserValue =
    λ(_patternArgument : ParserValue)
      parserBind (expectCaseBranchArrowParser ValueUnit)
        parseDoneNatWildcardBranchBody;

  def parseDoneNatWildcardBranchBody : ParserValue -> Parser ParserValue =
    λ(_arrow : ParserValue)
      parserBind (expectText "bool:true")
        parseDoneNowBranchSeparator;

  def parseDoneNowBranchSeparator : ParserValue -> Parser ParserValue =
    λ(_body : ParserValue)
      parserBind (expectText ";")
        parseStepNextRecursiveBranch;

  def parseStepNextRecursiveBranch : ParserValue -> Parser ParserValue =
    λ(_separator : ParserValue)
      parserBind (expectIdentifier "Step")
        parseStepNextPatternArgument;

  def parseStepNextPatternArgument : ParserValue -> Parser ParserValue =
    λ(_constructor : ParserValue)
      parserBind (expectIdentifier "next")
        parseStepNextBranchArrow;

  def parseStepNextBranchArrow : ParserValue -> Parser ParserValue =
    λ(_patternArgument : ParserValue)
      parserBind (expectCaseBranchArrowParser ValueUnit)
        parseDoneNowRecursiveCall;

  def parseDoneNowRecursiveCall : ParserValue -> Parser ParserValue =
    λ(_arrow : ParserValue)
      parserBind (expectIdentifier "doneNow")
        parseDoneNowRecursiveArgument;

  def parseDoneNowRecursiveArgument : ParserValue -> Parser ParserValue =
    λ(_functionName : ParserValue)
      parserBind (expectIdentifier "next")
        parseDoneNowCaseBranchesClose;

  def parseDoneNowCaseBranchesClose : ParserValue -> Parser ParserValue =
    λ(_argument : ParserValue)
      parserBind (expectText "}")
        parseDoneNowDefinitionSemicolon;

  def parseDoneNowDefinitionSemicolon : ParserValue -> Parser ParserValue =
    λ(_closeBranches : ParserValue)
      parserBind (expectText ";")
        parsedUnit;

  def parseUnwrapSomeDefinition : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectText "def")
        parseUnwrapSomeDefinitionName;

  def parseUnwrapSomeDefinitionName : ParserValue -> Parser ParserValue =
    λ(_defToken : ParserValue)
      parserBind (expectIdentifier "unwrapSome")
        parseUnwrapSomeDefinitionColon;

  def parseUnwrapSomeDefinitionColon : ParserValue -> Parser ParserValue =
    λ(_defName : ParserValue)
      parserBind (expectText ":")
        parseUnwrapSomeDefinitionArgumentType;

  def parseUnwrapSomeDefinitionArgumentType : ParserValue -> Parser ParserValue =
    λ(_colon : ParserValue)
      parserBind (expectIdentifier "SomeExpr")
        parseUnwrapSomeDefinitionTypeArrow;

  def parseUnwrapSomeDefinitionTypeArrow : ParserValue -> Parser ParserValue =
    λ(_argumentType : ParserValue)
      parserBind (expectText "->")
        parseUnwrapSomeDefinitionResultType;

  def parseUnwrapSomeDefinitionResultType : ParserValue -> Parser ParserValue =
    λ(_arrow : ParserValue)
      parserBind (expectIdentifier "Bool")
        parseUnwrapSomeDefinitionEquals;

  def parseUnwrapSomeDefinitionEquals : ParserValue -> Parser ParserValue =
    λ(_resultType : ParserValue)
      parserBind (expectEqualsParser ValueUnit)
        parseUnwrapSomeLambda;

  def parseUnwrapSomeLambda : ParserValue -> Parser ParserValue =
    λ(_equals : ParserValue)
      parserBind (parsePlainLambdaParameter "boxed" ValueUnit)
        parseUnwrapSomeOuterCase;

  def parseUnwrapSomeOuterCase : ParserValue -> Parser ParserValue =
    λ(_lambda : ParserValue)
      parserBind (expectText "case")
        parseUnwrapSomeOuterScrutinee;

  def parseUnwrapSomeOuterScrutinee : ParserValue -> Parser ParserValue =
    λ(_caseToken : ParserValue)
      parserBind (expectIdentifier "boxed")
        parseUnwrapSomeOuterOf;

  def parseUnwrapSomeOuterOf : ParserValue -> Parser ParserValue =
    λ(_scrutinee : ParserValue)
      parserBind (expectText "of")
        parseUnwrapSomeOuterBranchesOpen;

  def parseUnwrapSomeOuterBranchesOpen : ParserValue -> Parser ParserValue =
    λ(_ofToken : ParserValue)
      parserBind (expectText "{")
        parseUnwrapSomeOuterPatternConstructor;

  def parseUnwrapSomeOuterPatternConstructor : ParserValue -> Parser ParserValue =
    λ(_openBranches : ParserValue)
      parserBind (expectIdentifier "SomeExpr")
        parseUnwrapSomeOuterPatternArgument;

  def parseUnwrapSomeOuterPatternArgument : ParserValue -> Parser ParserValue =
    λ(_constructor : ParserValue)
      parserBind (expectIdentifier "expr")
        parseUnwrapSomeOuterBranchArrow;

  def parseUnwrapSomeOuterBranchArrow : ParserValue -> Parser ParserValue =
    λ(_patternArgument : ParserValue)
      parserBind (expectCaseBranchArrowParser ValueUnit)
        parseUnwrapSomeInnerCase;

  def parseUnwrapSomeInnerCase : ParserValue -> Parser ParserValue =
    λ(_arrow : ParserValue)
      parserBind (expectText "case")
        parseUnwrapSomeInnerScrutinee;

  def parseUnwrapSomeInnerScrutinee : ParserValue -> Parser ParserValue =
    λ(_caseToken : ParserValue)
      parserBind (expectIdentifier "expr")
        parseUnwrapSomeInnerOf;

  def parseUnwrapSomeInnerOf : ParserValue -> Parser ParserValue =
    λ(_scrutinee : ParserValue)
      parserBind (expectText "of")
        parseUnwrapSomeInnerBranchesOpen;

  def parseUnwrapSomeInnerBranchesOpen : ParserValue -> Parser ParserValue =
    λ(_ofToken : ParserValue)
      parserBind (expectText "{")
        parseUnwrapSomeDoneNatBranch;

  def parseUnwrapSomeDoneNatBranch : ParserValue -> Parser ParserValue =
    λ(_openBranches : ParserValue)
      parserBind (expectIdentifier "DoneNat")
        parseUnwrapSomeDoneNatWildcard;

  def parseUnwrapSomeDoneNatWildcard : ParserValue -> Parser ParserValue =
    λ(_constructor : ParserValue)
      parserBind (expectText "_")
        parseUnwrapSomeDoneNatArrow;

  def parseUnwrapSomeDoneNatArrow : ParserValue -> Parser ParserValue =
    λ(_wildcard : ParserValue)
      parserBind (expectCaseBranchArrowParser ValueUnit)
        parseUnwrapSomeDoneNatBody;

  def parseUnwrapSomeDoneNatBody : ParserValue -> Parser ParserValue =
    λ(_arrow : ParserValue)
      parserBind (expectText "bool:true")
        parseUnwrapSomeInnerBranchSeparator;

  def parseUnwrapSomeInnerBranchSeparator : ParserValue -> Parser ParserValue =
    λ(_body : ParserValue)
      parserBind (expectText ";")
        parseUnwrapSomeStepBranch;

  def parseUnwrapSomeStepBranch : ParserValue -> Parser ParserValue =
    λ(_separator : ParserValue)
      parserBind (expectIdentifier "Step")
        parseUnwrapSomeStepPatternArgument;

  def parseUnwrapSomeStepPatternArgument : ParserValue -> Parser ParserValue =
    λ(_constructor : ParserValue)
      parserBind (expectIdentifier "next")
        parseUnwrapSomeStepArrow;

  def parseUnwrapSomeStepArrow : ParserValue -> Parser ParserValue =
    λ(_patternArgument : ParserValue)
      parserBind (expectCaseBranchArrowParser ValueUnit)
        parseUnwrapSomeRecursiveCall;

  def parseUnwrapSomeRecursiveCall : ParserValue -> Parser ParserValue =
    λ(_arrow : ParserValue)
      parserBind (expectIdentifier "unwrapSome")
        parseUnwrapSomeRecursiveArgumentOpen;

  def parseUnwrapSomeRecursiveArgumentOpen : ParserValue -> Parser ParserValue =
    λ(_functionName : ParserValue)
      parserBind (expectText "(")
        parseUnwrapSomeRecursiveSomeExpr;

  def parseUnwrapSomeRecursiveSomeExpr : ParserValue -> Parser ParserValue =
    λ(_openArgument : ParserValue)
      parserBind (expectIdentifier "SomeExpr")
        parseUnwrapSomeRecursiveNext;

  def parseUnwrapSomeRecursiveNext : ParserValue -> Parser ParserValue =
    λ(_constructor : ParserValue)
      parserBind (expectIdentifier "next")
        parseUnwrapSomeRecursiveArgumentClose;

  def parseUnwrapSomeRecursiveArgumentClose : ParserValue -> Parser ParserValue =
    λ(_argument : ParserValue)
      parserBind (expectText ")")
        parseUnwrapSomeInnerBranchesClose;

  def parseUnwrapSomeInnerBranchesClose : ParserValue -> Parser ParserValue =
    λ(_closeArgument : ParserValue)
      parserBind (expectText "}")
        parseUnwrapSomeOuterBranchesClose;

  def parseUnwrapSomeOuterBranchesClose : ParserValue -> Parser ParserValue =
    λ(_closeInner : ParserValue)
      parserBind (expectText "}")
        parseUnwrapSomeDefinitionSemicolon;

  def parseUnwrapSomeDefinitionSemicolon : ParserValue -> Parser ParserValue =
    λ(_closeOuter : ParserValue)
      parserBind (expectText ";")
        parsedUnit;

  def parsePlainLambdaParameter : String -> ParserValue -> Parser ParserValue =
    λ(parameterName : String) λ(_start : ParserValue)
      parserBind (expectText "lambda")
        parsePlainLambdaOpen;

  def parsePlainLambdaOpen : ParserValue -> Parser ParserValue =
    λ(_lambda : ParserValue)
      parserBind (expectText "(")
        parsePlainLambdaParameterName;

  def parsePlainLambdaParameterName : ParserValue -> Parser ParserValue =
    λ(_openParameter : ParserValue)
      parserChoice
        (parsePlainExprParameter ValueUnit)
        (parsePlainBoxedParameter ValueUnit);

  def parsePlainExprParameter : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectIdentifier "expr")
        parsePlainLambdaClose;

  def parsePlainBoxedParameter : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectIdentifier "boxed")
        parsePlainLambdaClose;

  def parsePlainLambdaClose : ParserValue -> Parser ParserValue =
    λ(_parameter : ParserValue)
      parserBind (expectText ")")
        parsedUnit;

  def parseRecursiveGadtMainDef : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectText "def")
        parseRecursiveGadtMainName;

  def parseRecursiveGadtMainName : ParserValue -> Parser ParserValue =
    λ(_defToken : ParserValue)
      parserBind (expectIdentifier "main")
        parseBoolMainColon;

  def parseBoolMainColon : ParserValue -> Parser ParserValue =
    λ(_mainName : ParserValue)
      parserBind (expectText ":")
        parseBoolMainType;

  def parseBoolMainType : ParserValue -> Parser ParserValue =
    λ(_colon : ParserValue)
      parserBind (expectIdentifier "Bool")
        parseRecursiveGadtMainEquals;

  def parseRecursiveGadtMainEquals : ParserValue -> Parser ParserValue =
    λ(_type : ParserValue)
      parserBind (expectEqualsParser ValueUnit)
        parseDoneNowCallExpression;

  def parseDoneNowCallExpression : ParserValue -> Parser ParserValue =
    λ(_equals : ParserValue)
      parserBind (expectIdentifier "doneNow")
        parseDoneNowCallArgumentOpen;

  def parseDoneNowCallArgumentOpen : ParserValue -> Parser ParserValue =
    λ(_functionName : ParserValue)
      parserBind (expectText "(")
        parseDoneNowCallStepArgument;

  def parseDoneNowCallStepArgument : ParserValue -> Parser ParserValue =
    λ(_openArgument : ParserValue)
      parserBind (parseStepDoneNatZeroExpression ValueUnit)
        parseDoneNowCallArgumentClose;

  def parseStepDoneNatZeroExpression : ParserValue -> Parser ParserValue =
    λ(_openArgument : ParserValue)
      parserBind (expectIdentifier "Step")
        parseStepDoneNatArgumentOpen;

  def parseStepDoneNatArgumentOpen : ParserValue -> Parser ParserValue =
    λ(_stepConstructor : ParserValue)
      parserBind (expectText "(")
        parseDoneNatZeroExpression;

  def parseDoneNatZeroExpression : ParserValue -> Parser ParserValue =
    λ(_openArgument : ParserValue)
      parserBind (expectIdentifier "DoneNat")
        parseDoneNatZeroArgument;

  def parseDoneNatZeroArgument : ParserValue -> Parser ParserValue =
    λ(_doneNatConstructor : ParserValue)
      parserBind (expectIdentifier "Zero")
        parseDoneNatZeroClose;

  def parseDoneNatZeroClose : ParserValue -> Parser ParserValue =
    λ(_zero : ParserValue)
      parserBind (expectText ")")
        parseStepDoneNatClose;

  def parseStepDoneNatClose : ParserValue -> Parser ParserValue =
    λ(_closeDoneNat : ParserValue)
      parserPure ValueUnit;

  def parseDoneNowCallArgumentClose : ParserValue -> Parser ParserValue =
    λ(_closeStep : ParserValue)
      parserBind (expectText ")")
        parseBoolMainSemicolon;

  def parseBoolMainSemicolon : ParserValue -> Parser ParserValue =
    λ(_closeArgument : ParserValue)
      parserBind (expectText ";")
        parsedUnit;

  def parseExistentialMainDef : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (expectText "def")
        parseExistentialMainName;

  def parseExistentialMainName : ParserValue -> Parser ParserValue =
    λ(_defToken : ParserValue)
      parserBind (expectIdentifier "main")
        parseExistentialMainColon;

  def parseExistentialMainColon : ParserValue -> Parser ParserValue =
    λ(_mainName : ParserValue)
      parserBind (expectText ":")
        parseExistentialMainType;

  def parseExistentialMainType : ParserValue -> Parser ParserValue =
    λ(_colon : ParserValue)
      parserBind (expectIdentifier "Bool")
        parseExistentialMainEquals;

  def parseExistentialMainEquals : ParserValue -> Parser ParserValue =
    λ(_type : ParserValue)
      parserBind (expectEqualsParser ValueUnit)
        parseUnwrapSomeMainCall;

  def parseUnwrapSomeMainCall : ParserValue -> Parser ParserValue =
    λ(_equals : ParserValue)
      parserBind (expectIdentifier "unwrapSome")
        parseUnwrapSomeMainArgumentOpen;

  def parseUnwrapSomeMainArgumentOpen : ParserValue -> Parser ParserValue =
    λ(_functionName : ParserValue)
      parserBind (expectText "(")
        parseUnwrapSomeMainSomeExpr;

  def parseUnwrapSomeMainSomeExpr : ParserValue -> Parser ParserValue =
    λ(_openArgument : ParserValue)
      parserBind (expectIdentifier "SomeExpr")
        parseUnwrapSomeMainStepOpen;

  def parseUnwrapSomeMainStepOpen : ParserValue -> Parser ParserValue =
    λ(_constructor : ParserValue)
      parserBind (expectText "(")
        parseUnwrapSomeMainStepArgument;

  def parseUnwrapSomeMainStepArgument : ParserValue -> Parser ParserValue =
    λ(_openStep : ParserValue)
      parserBind (parseStepDoneNatZeroExpression ValueUnit)
        parseUnwrapSomeMainArgumentClose;

  def parseUnwrapSomeMainArgumentClose : ParserValue -> Parser ParserValue =
    λ(_stepArgument : ParserValue)
      parserBind (expectText ")")
        parseUnwrapSomeMainOuterArgumentClose;

  def parseUnwrapSomeMainOuterArgumentClose : ParserValue -> Parser ParserValue =
    λ(_someExprArgument : ParserValue)
      parserBind (expectText ")")
        parseBoolMainSemicolon;

  def renderParserParityRetryEvidence : String -> String -> String -> String =
    λ(sourceFile : String) λ(sourceText : String) λ(lexerMismatchSourceText : String)
      stringAppend (renderPositiveTokenEvidence sourceFile sourceText)
        (stringAppend "\n"
          (stringAppend (renderLexerNegativeEvidence sourceFile lexerMismatchSourceText)
            (stringAppend "\n" (renderParserNegativeEvidenceFromSourceText "parser negative " sourceFile basicParserNegativeSourceText))));

  def renderPositiveTokenEvidence : String -> String -> String =
    λ(sourceFile : String) λ(sourceText : String) case tokenizeCompleteModule sourceText of {
      LexerOk input -> renderTokenPrefixEvidence sourceFile input;
      LexerError diagnostic -> stringAppend "tokens " (renderDiagnosticEvidence sourceFile diagnostic)
    };

  def renderLexerNegativeEvidence : String -> String -> String =
    λ(sourceFile : String) λ(lexerMismatchSourceText : String) case tokenizeCompleteModule lexerMismatchSourceText of {
      LexerOk _ -> "lexer negative unexpected-success";
      LexerError diagnostic -> stringAppend "lexer negative " (renderDiagnosticEvidence sourceFile diagnostic)
    };

  def basicParserNegativeSourceText : String =
    "module Main export (main) {\n  def main : Bool   true;\n}";

  def renderParserNegativeEvidenceFromSourceText : String -> String -> String -> String =
    λ(prefix : String) λ(sourceFile : String) λ(sourceText : String)
      renderParserNegativeEvidence prefix sourceFile (parseCompleteModule sourceText);

  def renderParserNegativeEvidence : String -> String -> ParserResult -> String =
    λ(prefix : String) λ(sourceFile : String) λ(result : ParserResult) case result of {
      ParserOk _ -> stringAppend prefix "unexpected-success";
      ParserError diagnostic -> stringAppend prefix (renderDiagnosticEvidence sourceFile diagnostic)
    };

  def renderDiagnosticEvidence : String -> ParserDiagnostic -> String =
    λ(sourceFile : String) λ(diagnostic : ParserDiagnostic) case diagnostic of {
      UnexpectedSourceText span -> stringAppend "unexpected-source@" (renderSpan sourceFile span);
      ExpectedCompleteModule span -> stringAppend "expected-complete-module@" (renderSpan sourceFile span);
      ExpectedEquals span -> stringAppend "expected-equals@" (renderSpan sourceFile span);
      ExpectedImportSemicolon span -> stringAppend "expected-import-semicolon@" (renderSpan sourceFile span);
      ExpectedImportAlias span -> stringAppend "expected-import-alias@" (renderSpan sourceFile span);
      ExpectedImportExposingSeparator span -> stringAppend "expected-import-exposing-separator@" (renderSpan sourceFile span);
      ExpectedDefSemicolon span -> stringAppend "expected-def-semicolon@" (renderSpan sourceFile span);
      ExpectedLetIn span -> stringAppend "expected-let-in@" (renderSpan sourceFile span);
      ExpectedLetAnnotationType span -> stringAppend "expected-let-annotation-type@" (renderSpan sourceFile span);
      ExpectedConstructorColon span -> stringAppend "expected-constructor-colon@" (renderSpan sourceFile span);
      ExpectedCaseBranchArrow span -> stringAppend "expected-case-branch-arrow@" (renderSpan sourceFile span);
      ExpectedInstanceMethodEquals span -> stringAppend "expected-instance-method-equals@" (renderSpan sourceFile span);
      ExpectedFunctionalDependencyArrow span -> stringAppend "expected-functional-dependency-arrow@" (renderSpan sourceFile span);
      ExpectedTypeFamilyEquationEquals span -> stringAppend "expected-type-family-equation-equals@" (renderSpan sourceFile span);
      ExpectedConstructorForallDot span -> stringAppend "expected-constructor-forall-dot@" (renderSpan sourceFile span);
      ExpectedExpressionCloseParen span -> stringAppend "expected-expression-close-paren@" (renderSpan sourceFile span)
    };
}
