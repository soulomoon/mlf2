  def recursiveGadtProjectionKey : String =
    "recursive-gadt-projection";

  def existentialForallProjectionKey : String =
    "existential-forall-projection";

  def parseRecursiveAdtSyntax : ParserValue -> Parser ParserValue =
    λ(_start : ParserValue)
      parserBind (labelUnexpectedSource recursiveGadtModuleSpan (expectText "module"))
        parseRecursiveAdtModuleName;

  def parseRecursiveAdtModuleName : ParserValue -> Parser ParserValue =
