        parseConstructorExportClose;

  def parseConstructorExportClose : ParserValue -> Parser ParserValue =
    λ(_secondDot : ParserValue)
      parserBind (expectText ")")
        parsedUnit;

  def parseRecursiveGadtValueExports : ParserValue -> Parser ParserValue =
