module ParserParityDiagnostic export (ParserDiagnostic(..)) {
  data ParserDiagnostic =
      UnexpectedSourceText : String -> ParserDiagnostic
    | ExpectedCompleteModule : String -> ParserDiagnostic
    | ExpectedEquals : String -> ParserDiagnostic
    | ExpectedImportSemicolon : String -> ParserDiagnostic
    | ExpectedImportAlias : String -> ParserDiagnostic
    | ExpectedImportExposingSeparator : String -> ParserDiagnostic
    | ExpectedDefSemicolon : String -> ParserDiagnostic
    | ExpectedLetIn : String -> ParserDiagnostic
    | ExpectedLetAnnotationType : String -> ParserDiagnostic
    | ExpectedConstructorColon : String -> ParserDiagnostic
    | ExpectedCaseBranchArrow : String -> ParserDiagnostic
    | ExpectedInstanceMethodEquals : String -> ParserDiagnostic
    | ExpectedFunctionalDependencyArrow : String -> ParserDiagnostic
    | ExpectedTypeFamilyEquationEquals : String -> ParserDiagnostic
    | ExpectedConstructorForallDot : String -> ParserDiagnostic
    | ExpectedExpressionCloseParen : String -> ParserDiagnostic;
}
