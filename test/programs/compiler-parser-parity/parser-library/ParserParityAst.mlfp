module ParserParityAst export (ParsedModule(..), renderParsedModule, renderBasicModuleBool, renderImportExposingBool, renderValueDefListIntRef, renderLetLambdaApplication, renderTypedAnnotationTypes, renderDataDeclarationConstructorSpans, renderCaseExpressionConstructorPatterns, renderCaseExpressionNestedPatterns, renderTypeclassDerivingMethod, renderTypeclassInstanceNullaryMethod, renderHigherKindedClassDataParams, renderMultiparamSuperclassFundep, renderTypeFamilyKindLambda, renderTypeFamilyApplyAnnotation, renderRecursiveGadtResultConstructors, renderExistentialConstructorForall) {
  import Prelude exposing (Option(..), stringAppend, stringIndexOf);
  import ParserParitySource exposing (renderSpan, basicModuleSpan, basicExportMainSpan, basicMainDefSpan, importBoolModuleSpan, importBoolModuleNameRefSpan, importBoolTypeSpan, importBoolMainDefSpan, valueModuleSpan, valueExportMainSpan, valueImportModuleSpan, valueImportIntSpan, valueDefTwoSpan, valueDefMainSpan, letModuleSpan, letExportMainSpan, letImportModuleSpan, letImportIntSpan, letDefMainSpan, typedModuleSpan, typedExportMainSpan, typedImportModuleSpan, typedImportIntSpan, typedDefMainSpan, dataModuleSpan, dataExportNatSpan, dataExportMainSpan, dataDeclSpan, dataZeroConstructorSpan, dataSuccConstructorSpan, dataDefMainSpan, caseConstructorModuleSpan, caseConstructorDefMainSpan, caseNestedModuleSpan, caseNestedDefMainSpan, typeclassDerivingModuleSpan, typeclassDerivingExportEqSpan, typeclassDerivingExportNatSpan, typeclassDerivingExportEqMethodSpan, typeclassDerivingExportMainSpan, typeclassDerivingClassSpan, typeclassDerivingEqMethodSpan, typeclassDerivingDataSpan, typeclassDerivingZeroConstructorSpan, typeclassDerivingSuccConstructorSpan, typeclassDerivingEqSpan, typeclassDerivingDefMainSpan, typeclassInstanceModuleSpan, typeclassInstanceExportMonoidSpan, typeclassInstanceExportNatSpan, typeclassInstanceExportMemptySpan, typeclassInstanceExportAppendSpan, typeclassInstanceExportMainSpan, typeclassInstanceClassSpan, typeclassInstanceMemptySignatureSpan, typeclassInstanceAppendSignatureSpan, typeclassInstanceDataSpan, typeclassInstanceZeroConstructorSpan, typeclassInstanceSuccConstructorSpan, typeclassInstanceClassNameSpan, typeclassInstanceMemptyDefinitionSpan, typeclassInstanceAppendDefinitionSpan, typeclassInstanceDefMainSpan, higherKindedModuleSpan, higherKindedExportFunctorSpan, higherKindedExportHigherSpan, higherKindedClassSpan, higherKindedMapSignatureSpan, higherKindedDataSpan, higherKindedWrapConstructorSpan, multiparamModuleSpan, multiparamExportMonadSpan, multiparamClassSpan, multiparamSuperclassFunctorSpan, multiparamBindSignatureSpan, multiparamInstanceClassNameSpan, typeFamilyKindLambdaModuleSpan, typeFamilyKindLambdaDeclSpan, typeFamilyApplyAnnotationModuleSpan, typeFamilyApplyAnnotationExportMainSpan, typeFamilyApplyAnnotationDeclSpan, typeFamilyApplyAnnotationDefMainSpan, recursiveGadtModuleSpan, recursiveGadtExportNatSpan, recursiveGadtExportExprSpan, recursiveGadtExportDoneNowSpan, recursiveGadtExportMainSpan, recursiveGadtNatDataSpan, recursiveGadtZeroConstructorSpan, recursiveGadtSuccConstructorSpan, recursiveGadtExprDataSpan, recursiveGadtDoneNatConstructorSpan, recursiveGadtStepConstructorSpan, recursiveGadtDoneNowDefSpan, recursiveGadtMainDefSpan, existentialForallModuleSpan, existentialForallExportNatSpan, existentialForallExportExprSpan, existentialForallExportSomeExprSpan, existentialForallExportUnwrapSomeSpan, existentialForallExportMainSpan, existentialForallNatDataSpan, existentialForallZeroConstructorSpan, existentialForallSuccConstructorSpan, existentialForallExprDataSpan, existentialForallDoneNatConstructorSpan, existentialForallStepConstructorSpan, existentialForallSomeExprDataSpan, existentialForallSomeExprConstructorSpan, existentialForallUnwrapSomeDefSpan, existentialForallMainDefSpan);

  data ParsedModule =
      ParsedModule : String -> ParsedModule;

  data StringMatch =
      StringMatched : String -> StringMatch
    | StringMismatch : String -> StringMatch;

  def stringExactMatch : String -> String -> StringMatch =
    λ(expected : String) λ(actual : String) case stringIndexOf actual expected of {
      None -> StringMismatch actual;
      Some _ -> case stringIndexOf expected actual of {
        None -> StringMismatch actual;
        Some _ -> StringMatched actual
      }
    };

  def renderParsedModule : String -> ParsedModule -> String =
    λ(sourceFile : String) λ(parsed : ParsedModule) case parsed of {
      ParsedModule key -> renderParsedModuleKey sourceFile key
    };

  def renderParsedModuleKey : String -> String -> String =
    λ(sourceFile : String) λ(key : String) case stringExactMatch "basic-bool" key of {
      StringMatched _ -> renderBasicModuleBool sourceFile;
      StringMismatch _ -> case stringExactMatch "import-bool" key of {
        StringMatched _ -> renderImportExposingBool sourceFile;
        StringMismatch _ -> case stringExactMatch "value-int-ref" key of {
          StringMatched _ -> renderValueDefListIntRef sourceFile;
          StringMismatch _ -> case stringExactMatch "let-lambda" key of {
            StringMatched _ -> renderLetLambdaApplication sourceFile;
            StringMismatch _ -> case stringExactMatch "typed-annotation" key of {
              StringMatched _ -> renderTypedAnnotationTypes sourceFile;
              StringMismatch _ -> case stringExactMatch "data-constructor-spans" key of {
                StringMatched _ -> renderDataDeclarationConstructorSpans sourceFile;
                StringMismatch _ -> case stringExactMatch "case-constructor-patterns" key of {
                  StringMatched _ -> renderCaseExpressionConstructorPatterns sourceFile;
                  StringMismatch _ -> case stringExactMatch "case-nested-patterns" key of {
                    StringMatched _ -> renderCaseExpressionNestedPatterns sourceFile;
                    StringMismatch _ -> case stringExactMatch "typeclass-deriving-method" key of {
                      StringMatched _ -> renderTypeclassDerivingMethod sourceFile;
                      StringMismatch _ -> case stringExactMatch "typeclass-instance-nullary-method" key of {
                        StringMatched _ -> renderTypeclassInstanceNullaryMethod sourceFile;
                        StringMismatch _ -> case stringExactMatch "kinded-class-data-projection" key of {
                          StringMatched _ -> renderHigherKindedClassDataParams sourceFile;
                          StringMismatch _ -> case stringExactMatch "constrained-class-fundep-projection" key of {
                            StringMatched _ -> renderMultiparamSuperclassFundep sourceFile;
                            StringMismatch _ -> case stringExactMatch "closed-family-kind-lambda-projection" key of {
                              StringMatched _ -> renderTypeFamilyKindLambda sourceFile;
                              StringMismatch _ -> case stringExactMatch "closed-family-apply-annotation-projection" key of {
                                StringMatched _ -> renderTypeFamilyApplyAnnotation sourceFile;
                                StringMismatch _ -> case stringExactMatch "recursive-gadt-projection" key of {
                                  StringMatched _ -> renderRecursiveGadtResultConstructors sourceFile;
                                  StringMismatch _ -> case stringExactMatch "existential-forall-projection" key of {
                                    StringMatched _ -> renderExistentialConstructorForall sourceFile;
                                    StringMismatch _ -> "parser-error"
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    };

  def renderBasicModuleBool : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile basicModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export value main span=" (stringAppend (renderSpan sourceFile basicExportMainSpan) "\n"))
          (stringAppend "def main type=Bool expr=true span=" (renderSpan sourceFile basicMainDefSpan)));

  def renderImportExposingBool : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile importBoolModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export value main span=" (stringAppend (renderSpan sourceFile basicExportMainSpan) "\n"))
          (stringAppend
            (stringAppend "import Prelude span=" (stringAppend (renderSpan sourceFile importBoolModuleNameRefSpan) "\n"))
            (stringAppend
              (stringAppend "import exposing type Bool span=" (stringAppend (renderSpan sourceFile importBoolTypeSpan) "\n"))
              (stringAppend "def main type=Bool expr=true span=" (renderSpan sourceFile importBoolMainDefSpan)))));

  def renderValueDefListIntRef : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile valueModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export value main span=" (stringAppend (renderSpan sourceFile valueExportMainSpan) "\n"))
          (stringAppend
            (stringAppend "import Prelude span=" (stringAppend (renderSpan sourceFile valueImportModuleSpan) "\n"))
            (stringAppend
              (stringAppend "import exposing type Int span=" (stringAppend (renderSpan sourceFile valueImportIntSpan) "\n"))
              (stringAppend
                (stringAppend "def two type=Int expr=2 span=" (stringAppend (renderSpan sourceFile valueDefTwoSpan) "\n"))
                (stringAppend "def main type=Int expr=two span=" (renderSpan sourceFile valueDefMainSpan))))));

  def renderLetLambdaApplication : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile letModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export value main span=" (stringAppend (renderSpan sourceFile letExportMainSpan) "\n"))
          (stringAppend
            (stringAppend "import Prelude span=" (stringAppend (renderSpan sourceFile letImportModuleSpan) "\n"))
            (stringAppend
              (stringAppend "import exposing type Int span=" (stringAppend (renderSpan sourceFile letImportIntSpan) "\n"))
              (stringAppend "def main type=Int expr=let id = λx x in id 1 span=" (renderSpan sourceFile letDefMainSpan)))));

  def renderTypedAnnotationTypes : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile typedModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export value main span=" (stringAppend (renderSpan sourceFile typedExportMainSpan) "\n"))
          (stringAppend
            (stringAppend "import Prelude span=" (stringAppend (renderSpan sourceFile typedImportModuleSpan) "\n"))
            (stringAppend
              (stringAppend "import exposing type Int span=" (stringAppend (renderSpan sourceFile typedImportIntSpan) "\n"))
              (stringAppend "def main type=Int expr=let id : ∀a. a -> a = λ(x : Int) x in (id 1 : Int) span=" (renderSpan sourceFile typedDefMainSpan)))));

  def renderDataDeclarationConstructorSpans : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile dataModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export type-with-constructors Nat span=" (stringAppend (renderSpan sourceFile dataExportNatSpan) "\n"))
          (stringAppend
            (stringAppend "export value main span=" (stringAppend (renderSpan sourceFile dataExportMainSpan) "\n"))
            (stringAppend
              (stringAppend "data Nat span=" (stringAppend (renderSpan sourceFile dataDeclSpan) "\n"))
              (stringAppend
                (stringAppend "constructor Zero type=Nat span=" (stringAppend (renderSpan sourceFile dataZeroConstructorSpan) "\n"))
                (stringAppend
                  (stringAppend "constructor Succ type=Nat -> Nat span=" (stringAppend (renderSpan sourceFile dataSuccConstructorSpan) "\n"))
                  (stringAppend "def main type=Nat expr=Succ Zero span=" (renderSpan sourceFile dataDefMainSpan)))))));

  def renderCaseExpressionConstructorPatterns : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile caseConstructorModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export type-with-constructors Nat span=" (stringAppend (renderSpan sourceFile dataExportNatSpan) "\n"))
          (stringAppend
            (stringAppend "export value main span=" (stringAppend (renderSpan sourceFile dataExportMainSpan) "\n"))
            (stringAppend
              (stringAppend "data Nat span=" (stringAppend (renderSpan sourceFile dataDeclSpan) "\n"))
              (stringAppend
                (stringAppend "constructor Zero type=Nat span=" (stringAppend (renderSpan sourceFile dataZeroConstructorSpan) "\n"))
                (stringAppend
                  (stringAppend "constructor Succ type=Nat -> Nat span=" (stringAppend (renderSpan sourceFile dataSuccConstructorSpan) "\n"))
                  (stringAppend "def main type=Int expr=case Succ Zero of { Zero -> 0; Succ _ -> 1 } span=" (renderSpan sourceFile caseConstructorDefMainSpan)))))));

  def renderCaseExpressionNestedPatterns : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile caseNestedModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export type-with-constructors Nat span=" (stringAppend (renderSpan sourceFile dataExportNatSpan) "\n"))
          (stringAppend
            (stringAppend "export value main span=" (stringAppend (renderSpan sourceFile dataExportMainSpan) "\n"))
            (stringAppend
              (stringAppend "data Nat span=" (stringAppend (renderSpan sourceFile dataDeclSpan) "\n"))
              (stringAppend
                (stringAppend "constructor Zero type=Nat span=" (stringAppend (renderSpan sourceFile dataZeroConstructorSpan) "\n"))
                (stringAppend
                  (stringAppend "constructor Succ type=Nat -> Nat span=" (stringAppend (renderSpan sourceFile dataSuccConstructorSpan) "\n"))
                  (stringAppend "def main type=Bool expr=case Succ (Succ Zero) of { Succ Zero -> false; Succ (Succ n) -> true; _ -> false } span=" (renderSpan sourceFile caseNestedDefMainSpan)))))));

  def renderTypeclassDerivingMethod : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile typeclassDerivingModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export type Eq span=" (stringAppend (renderSpan sourceFile typeclassDerivingExportEqSpan) "\n"))
          (stringAppend
            (stringAppend "export type-with-constructors Nat span=" (stringAppend (renderSpan sourceFile typeclassDerivingExportNatSpan) "\n"))
            (stringAppend
              (stringAppend "export value eq span=" (stringAppend (renderSpan sourceFile typeclassDerivingExportEqMethodSpan) "\n"))
              (stringAppend
                (stringAppend "export value main span=" (stringAppend (renderSpan sourceFile typeclassDerivingExportMainSpan) "\n"))
                (stringAppend
                  (stringAppend "class Eq params=a span=" (stringAppend (renderSpan sourceFile typeclassDerivingClassSpan) "\n"))
                  (stringAppend
                    (stringAppend "method-signature eq type=a -> a -> Bool span=" (stringAppend (renderSpan sourceFile typeclassDerivingEqMethodSpan) "\n"))
                    (stringAppend
                      (stringAppend "data Nat span=" (stringAppend (renderSpan sourceFile typeclassDerivingDataSpan) "\n"))
                      (stringAppend
                        (stringAppend "constructor Zero type=Nat span=" (stringAppend (renderSpan sourceFile typeclassDerivingZeroConstructorSpan) "\n"))
                        (stringAppend
                          (stringAppend "constructor Succ type=Nat -> Nat span=" (stringAppend (renderSpan sourceFile typeclassDerivingSuccConstructorSpan) "\n"))
                          (stringAppend
                            (stringAppend "deriving Eq span=" (stringAppend (renderSpan sourceFile typeclassDerivingEqSpan) "\n"))
                            (stringAppend "def main type=Bool expr=eq (Succ Zero) (Succ Zero) span=" (renderSpan sourceFile typeclassDerivingDefMainSpan))))))))))));

  def renderTypeclassInstanceNullaryMethod : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile typeclassInstanceModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export type Monoid span=" (stringAppend (renderSpan sourceFile typeclassInstanceExportMonoidSpan) "\n"))
          (stringAppend
            (stringAppend "export type-with-constructors Nat span=" (stringAppend (renderSpan sourceFile typeclassInstanceExportNatSpan) "\n"))
            (stringAppend
              (stringAppend "export value mempty span=" (stringAppend (renderSpan sourceFile typeclassInstanceExportMemptySpan) "\n"))
              (stringAppend
                (stringAppend "export value append span=" (stringAppend (renderSpan sourceFile typeclassInstanceExportAppendSpan) "\n"))
                (stringAppend
                  (stringAppend "export value main span=" (stringAppend (renderSpan sourceFile typeclassInstanceExportMainSpan) "\n"))
                  (stringAppend
                    (stringAppend "class Monoid params=a span=" (stringAppend (renderSpan sourceFile typeclassInstanceClassSpan) "\n"))
                    (stringAppend
                      (stringAppend "method-signature mempty type=a span=" (stringAppend (renderSpan sourceFile typeclassInstanceMemptySignatureSpan) "\n"))
                      (stringAppend
                        (stringAppend "method-signature append type=a -> a -> a span=" (stringAppend (renderSpan sourceFile typeclassInstanceAppendSignatureSpan) "\n"))
                        (stringAppend
                          (stringAppend "data Nat span=" (stringAppend (renderSpan sourceFile typeclassInstanceDataSpan) "\n"))
                          (stringAppend
                            (stringAppend "constructor Zero type=Nat span=" (stringAppend (renderSpan sourceFile typeclassInstanceZeroConstructorSpan) "\n"))
                            (stringAppend
                              (stringAppend "constructor Succ type=Nat -> Nat span=" (stringAppend (renderSpan sourceFile typeclassInstanceSuccConstructorSpan) "\n"))
                              (stringAppend
                                (stringAppend "instance Monoid types=Nat span=" (stringAppend (renderSpan sourceFile typeclassInstanceClassNameSpan) "\n"))
                                (stringAppend
                                  (stringAppend "method-definition mempty expr=Zero span=" (stringAppend (renderSpan sourceFile typeclassInstanceMemptyDefinitionSpan) "\n"))
                                  (stringAppend
                                    (stringAppend "method-definition append expr=λleft λright left span=" (stringAppend (renderSpan sourceFile typeclassInstanceAppendDefinitionSpan) "\n"))
                                    (stringAppend "def main type=Nat expr=append (mempty : Nat) Zero span=" (renderSpan sourceFile typeclassInstanceDefMainSpan))))))))))))))));

  def renderHigherKindedClassDataParams : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile higherKindedModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export type Functor span=" (stringAppend (renderSpan sourceFile higherKindedExportFunctorSpan) "\n"))
          (stringAppend
            (stringAppend "export type-with-constructors Higher span=" (stringAppend (renderSpan sourceFile higherKindedExportHigherSpan) "\n"))
            (stringAppend
              (stringAppend "class Functor params=f::* -> * span=" (stringAppend (renderSpan sourceFile higherKindedClassSpan) "\n"))
              (stringAppend
                (stringAppend "method-signature map type=∀a b. (a -> b) -> f a -> f b span=" (stringAppend (renderSpan sourceFile higherKindedMapSignatureSpan) "\n"))
                (stringAppend
                  (stringAppend "data Higher params=f::* -> *,a span=" (stringAppend (renderSpan sourceFile higherKindedDataSpan) "\n"))
                  (stringAppend "constructor Wrap type=f a -> Higher f a span=" (renderSpan sourceFile higherKindedWrapConstructorSpan)))))));

  def renderMultiparamSuperclassFundep : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile multiparamModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export type Monad span=" (stringAppend (renderSpan sourceFile multiparamExportMonadSpan) "\n"))
          (stringAppend
            (stringAppend "class Monad params=m::* -> *,f::* -> * span=" (stringAppend (renderSpan sourceFile multiparamClassSpan) "\n"))
            (stringAppend
              (stringAppend "superclass Functor types=f span=" (stringAppend (renderSpan sourceFile multiparamSuperclassFunctorSpan) "\n"))
              (stringAppend
                (stringAppend "fundep m -> f span=" (stringAppend (renderSpan sourceFile multiparamClassSpan) "\n"))
                (stringAppend
                  (stringAppend "method-signature bind type=∀a b. m a -> (a -> m b) -> m b span=" (stringAppend (renderSpan sourceFile multiparamBindSignatureSpan) "\n"))
                  (stringAppend "instance Monad types=IO,IO span=" (renderSpan sourceFile multiparamInstanceClassNameSpan)))))));

  def renderTypeFamilyKindLambda : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile typeFamilyKindLambdaModuleSpan) "\n"))
        (stringAppend
          (stringAppend "type-family Normalize params=a::k result=k span=" (stringAppend (renderSpan sourceFile typeFamilyKindLambdaDeclSpan) "\n"))
          (stringAppend
            "family-equation Normalize patterns=Int rhs=Int\n"
            (stringAppend
              "family-equation Normalize patterns=Box a rhs=a\n"
              "family-equation Normalize patterns=a rhs=(Λx. x) a")));

  def renderTypeFamilyApplyAnnotation : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile typeFamilyApplyAnnotationModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export value main span=" (stringAppend (renderSpan sourceFile typeFamilyApplyAnnotationExportMainSpan) "\n"))
          (stringAppend
            (stringAppend "type-family Apply params=f::* -> *,a result=* span=" (stringAppend (renderSpan sourceFile typeFamilyApplyAnnotationDeclSpan) "\n"))
            (stringAppend
              "family-equation Apply patterns=f,a rhs=f a\n"
              (stringAppend "def main type=Apply (Λx. x) Int expr=1 span=" (renderSpan sourceFile typeFamilyApplyAnnotationDefMainSpan)))));

  def renderRecursiveGadtResultConstructors : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile recursiveGadtModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export type-with-constructors Nat span=" (stringAppend (renderSpan sourceFile recursiveGadtExportNatSpan) "\n"))
          (stringAppend
            (stringAppend "export type-with-constructors Expr span=" (stringAppend (renderSpan sourceFile recursiveGadtExportExprSpan) "\n"))
            (stringAppend
              (stringAppend "export value doneNow span=" (stringAppend (renderSpan sourceFile recursiveGadtExportDoneNowSpan) "\n"))
              (stringAppend
                (stringAppend "export value main span=" (stringAppend (renderSpan sourceFile recursiveGadtExportMainSpan) "\n"))
                (stringAppend
                  (stringAppend "data Nat span=" (stringAppend (renderSpan sourceFile recursiveGadtNatDataSpan) "\n"))
                  (stringAppend
                    (stringAppend "constructor Zero type=Nat span=" (stringAppend (renderSpan sourceFile recursiveGadtZeroConstructorSpan) "\n"))
                    (stringAppend
                      (stringAppend "constructor Succ type=Nat -> Nat span=" (stringAppend (renderSpan sourceFile recursiveGadtSuccConstructorSpan) "\n"))
                      (stringAppend
                        (stringAppend "data Expr params=a span=" (stringAppend (renderSpan sourceFile recursiveGadtExprDataSpan) "\n"))
                        (stringAppend
                          (stringAppend "constructor DoneNat type=Nat -> Expr Nat span=" (stringAppend (renderSpan sourceFile recursiveGadtDoneNatConstructorSpan) "\n"))
                          (stringAppend
                            (stringAppend "constructor Step type=Expr a -> Expr a span=" (stringAppend (renderSpan sourceFile recursiveGadtStepConstructorSpan) "\n"))
                            (stringAppend
                              (stringAppend "def doneNow type=Expr a -> Bool expr=λexpr case expr of { DoneNat _ -> true; Step next -> doneNow next } span=" (stringAppend (renderSpan sourceFile recursiveGadtDoneNowDefSpan) "\n"))
                              (stringAppend "def main type=Bool expr=doneNow (Step (DoneNat Zero)) span=" (renderSpan sourceFile recursiveGadtMainDefSpan)))))))))))));

  def renderExistentialConstructorForall : String -> String =
    λ(sourceFile : String)
      stringAppend
        (stringAppend "module Main span=" (stringAppend (renderSpan sourceFile existentialForallModuleSpan) "\n"))
        (stringAppend
          (stringAppend "export type-with-constructors Nat span=" (stringAppend (renderSpan sourceFile existentialForallExportNatSpan) "\n"))
          (stringAppend
            (stringAppend "export type-with-constructors Expr span=" (stringAppend (renderSpan sourceFile existentialForallExportExprSpan) "\n"))
            (stringAppend
              (stringAppend "export type-with-constructors SomeExpr span=" (stringAppend (renderSpan sourceFile existentialForallExportSomeExprSpan) "\n"))
              (stringAppend
                (stringAppend "export value unwrapSome span=" (stringAppend (renderSpan sourceFile existentialForallExportUnwrapSomeSpan) "\n"))
                (stringAppend
                  (stringAppend "export value main span=" (stringAppend (renderSpan sourceFile existentialForallExportMainSpan) "\n"))
                  (stringAppend
                    (stringAppend "data Nat span=" (stringAppend (renderSpan sourceFile existentialForallNatDataSpan) "\n"))
                    (stringAppend
                      (stringAppend "constructor Zero type=Nat span=" (stringAppend (renderSpan sourceFile existentialForallZeroConstructorSpan) "\n"))
                      (stringAppend
                        (stringAppend "constructor Succ type=Nat -> Nat span=" (stringAppend (renderSpan sourceFile existentialForallSuccConstructorSpan) "\n"))
                        (stringAppend
                          (stringAppend "data Expr params=a span=" (stringAppend (renderSpan sourceFile existentialForallExprDataSpan) "\n"))
                          (stringAppend
                            (stringAppend "constructor DoneNat type=Nat -> Expr Nat span=" (stringAppend (renderSpan sourceFile existentialForallDoneNatConstructorSpan) "\n"))
                            (stringAppend
                              (stringAppend "constructor Step type=Expr a -> Expr a span=" (stringAppend (renderSpan sourceFile existentialForallStepConstructorSpan) "\n"))
                              (stringAppend
                                (stringAppend "data SomeExpr span=" (stringAppend (renderSpan sourceFile existentialForallSomeExprDataSpan) "\n"))
                                (stringAppend
                                  (stringAppend "constructor SomeExpr type=∀a. Expr a -> SomeExpr span=" (stringAppend (renderSpan sourceFile existentialForallSomeExprConstructorSpan) "\n"))
                                  (stringAppend
                                    (stringAppend "def unwrapSome type=SomeExpr -> Bool expr=λboxed case boxed of { SomeExpr expr -> case expr of { DoneNat _ -> true; Step next -> unwrapSome (SomeExpr next) } } span=" (stringAppend (renderSpan sourceFile existentialForallUnwrapSomeDefSpan) "\n"))
                                    (stringAppend "def main type=Bool expr=unwrapSome (SomeExpr (Step (DoneNat Zero))) span=" (renderSpan sourceFile existentialForallMainDefSpan))))))))))))))));
}
