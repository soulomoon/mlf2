module ParserParitySource export (ParserSourceSymbol(..), ParserSourceInput(..), sourceInputNil, sourceInputCons, renderSpan, basicModuleSpan, basicModuleKeywordSpan, basicModuleNameSpan, basicExportKeywordSpan, basicExportLeftParenSpan, basicExportMainSpan, basicExportRightParenSpan, basicModuleLeftBraceSpan, basicDefKeywordSpan, basicDefNameSpan, basicDefColonSpan, basicBoolTypeSpan, basicDefEqualsSpan, basicBoolLiteralSpan, basicDefSemicolonSpan, basicModuleRightBraceSpan, basicMainDefSpan, basicUnexpectedSpan, lexerUnknownSpan, importBoolModuleSpan, importBoolModuleNameRefSpan, importBoolExportMainSpan, importBoolTypeSpan, importBoolMainDefSpan, importBoolSemicolonSpan, importBoolDefEqualsSpan, valueModuleSpan, valueExportMainSpan, valueImportModuleSpan, valueImportIntSpan, valueFirstDefSemicolonSpan, valueDefTwoSpan, valueDefMainSpan, letModuleSpan, letExportMainSpan, letImportModuleSpan, letImportIntSpan, letInSpan, letDefMainSpan, typedModuleSpan, typedExportMainSpan, typedImportModuleSpan, typedImportIntSpan, typedLetForallSpan, typedDefMainSpan, dataModuleSpan, dataExportNatSpan, dataExportMainSpan, dataDeclSpan, dataZeroConstructorSpan, dataSuccConstructorSpan, dataDefMainSpan, dataZeroColonSpan) {
