  def scanKnownZeroInt : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "0" "int:0" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownOne cursor
    };

  def scanKnownOne : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "1" "int:1" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownTwo cursor
    };

  def scanKnownTwo : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "2" "int:2" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownForall cursor
    };

  def scanKnownForall : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "∀" "forall" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownTypeLambda cursor
    };

  def scanKnownTypeLambda : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Λ" "type-lambda" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownLambda cursor
    };

  def scanKnownLambda : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "λ" "lambda" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownLeftParen cursor
    };

  def scanKnownLeftParen : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "(" "(" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownRightParen cursor
    };

  def scanKnownRightParen : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken ")" ")" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownLeftBrace cursor
    };

  def scanKnownLeftBrace : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "{" "{" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownRightBrace cursor
    };

  def scanKnownRightBrace : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "}" "}" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownDoubleColon cursor
    };

  def scanKnownDoubleColon : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "::" "::" 2 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownColon cursor
    };

  def scanKnownColon : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken ":" ":" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownStar cursor
    };

  def scanKnownStar : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "*" "*" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownEquals cursor
    };

  def scanKnownEquals : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "=" "=" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownSemicolon cursor
    };

  def scanKnownSemicolon : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken ";" ";" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownComma cursor
    };

  def scanKnownComma : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "," "," 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownDot cursor
    };

  def scanKnownDot : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "." "." 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownBar cursor
    };

  def scanKnownBar : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "|" "|" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownWildcard cursor
    };

  def scanKnownWildcard : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "_" "_" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownUnknown cursor
    };

  def scanKnownUnknown : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) scanIdentifierToken cursor;

  def scanIdentifierToken : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case cursor of {
      SourceCursor sourceText lineNumber linePrefix -> case stringCharAtOption sourceText 0 of {
        None -> LexStepError (UnexpectedSourceText lexerUnknownSpan);
        Some _ -> case sourceCharIn identifierStartCharacters sourceText of {
          StringMatched ->
            finishIdentifierScan
              (scanIdentifierMany64
                (IdentifierScanState lineNumber linePrefix "" cursor));
          StringMismatch -> scanCharLiteralToken cursor
        }
      }
    };

  def scanIdentifierMany64 : IdentifierScanState -> IdentifierScanState =
    λ(state : IdentifierScanState) scanIdentifierMany32 (scanIdentifierMany32 state);

  def scanIdentifierMany32 : IdentifierScanState -> IdentifierScanState =
    λ(state : IdentifierScanState) scanIdentifierMany16 (scanIdentifierMany16 state);

  def scanIdentifierMany16 : IdentifierScanState -> IdentifierScanState =
    λ(state : IdentifierScanState) scanIdentifierMany8 (scanIdentifierMany8 state);

  def scanIdentifierMany8 : IdentifierScanState -> IdentifierScanState =
    λ(state : IdentifierScanState) scanIdentifierMany4 (scanIdentifierMany4 state);

  def scanIdentifierMany4 : IdentifierScanState -> IdentifierScanState =
    λ(state : IdentifierScanState) scanIdentifierMany2 (scanIdentifierMany2 state);

  def scanIdentifierMany2 : IdentifierScanState -> IdentifierScanState =
    λ(state : IdentifierScanState) scanIdentifierStep (scanIdentifierStep state);

  def scanIdentifierStep : IdentifierScanState -> IdentifierScanState =
    λ(state : IdentifierScanState) case state of {
      IdentifierScanDone token cursor -> IdentifierScanDone token cursor;
      IdentifierScanState startLine startPrefix lexeme cursor -> case cursor of {
        SourceCursor sourceText lineNumber linePrefix -> case sourceCharIn identifierContinueCharacters sourceText of {
          StringMatched ->
            IdentifierScanState startLine startPrefix
              (stringAppend lexeme (stringTake sourceText 1))
              (SourceCursor (stringDrop sourceText 1) lineNumber (stringAppend linePrefix (stringTake sourceText 1)));
          StringMismatch ->
            IdentifierScanDone
              (SourceSymbol
                (cursorStart startLine startPrefix)
                (cursorEnd startLine startPrefix lexeme)
                (stringAppend "identifier:" lexeme))
              cursor
        }
      }
    };

  def finishIdentifierScan : IdentifierScanState -> LexStep =
    λ(state : IdentifierScanState) case state of {
      IdentifierScanDone token cursor -> LexStepOk token cursor;
      IdentifierScanState startLine startPrefix lexeme cursor ->
        LexStepOk
          (SourceSymbol
            (cursorStart startLine startPrefix)
            (cursorEnd startLine startPrefix lexeme)
            (stringAppend "identifier:" lexeme))
          cursor
    };

  def scanCharLiteralToken : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case cursor of {
      SourceCursor sourceText lineNumber linePrefix -> case sourceStartsWith "'" sourceText of {
        StringMatched -> scanCharLiteralBody lineNumber linePrefix (SourceCursor (stringDrop sourceText 1) lineNumber (stringAppend linePrefix "'"));
        StringMismatch -> scanStringLiteralToken cursor
      }
    };

  def scanCharLiteralBody : String -> String -> SourceCursor -> LexStep =
    λ(startLine : String) λ(startPrefix : String) λ(cursor : SourceCursor) case cursor of {
      SourceCursor sourceText lineNumber linePrefix -> case stringCharAtOption sourceText 0 of {
        None -> LexStepError (UnexpectedSourceText (cursorStart lineNumber linePrefix));
        Some _ -> case sourceStartsWith "'" sourceText of {
          StringMatched -> LexStepError (UnexpectedSourceText (cursorStart lineNumber linePrefix));
          StringMismatch -> case sourceStartsWith "\n" sourceText of {
            StringMatched -> LexStepError (UnexpectedSourceText (cursorStart lineNumber linePrefix));
            StringMismatch ->
              scanCharLiteralClose startLine startPrefix (stringTake sourceText 1)
                (SourceCursor (stringDrop sourceText 1) lineNumber (stringAppend linePrefix (stringTake sourceText 1)))
          }
        }
      }
    };

  def scanCharLiteralClose : String -> String -> String -> SourceCursor -> LexStep =
    λ(startLine : String) λ(startPrefix : String) λ(charText : String) λ(cursor : SourceCursor) case cursor of {
      SourceCursor sourceText lineNumber linePrefix -> case sourceStartsWith "'" sourceText of {
        StringMatched ->
          LexStepOk
            (SourceSymbol
              (cursorStart startLine startPrefix)
              (cursorEnd lineNumber linePrefix "'")
              (stringAppend "char-literal:" (stringAppend (stringAppend "'" charText) "'")))
            (SourceCursor (stringDrop sourceText 1) lineNumber (stringAppend linePrefix "'"));
        StringMismatch -> LexStepError (UnexpectedSourceText (cursorStart lineNumber linePrefix))
      }
    };

  def scanStringLiteralToken : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case cursor of {
      SourceCursor sourceText lineNumber linePrefix -> case sourceStartsWith "\"" sourceText of {
        StringMatched ->
          finishStringLiteralScan
            (scanStringLiteralMany64
              (StringLiteralScanState lineNumber linePrefix "\"" (SourceCursor (stringDrop sourceText 1) lineNumber (stringAppend linePrefix "\""))));
        StringMismatch -> LexStepError (UnexpectedSourceText lexerUnknownSpan)
      }
    };

  def scanStringLiteralMany64 : StringLiteralScanState -> StringLiteralScanState =
    λ(state : StringLiteralScanState) scanStringLiteralMany32 (scanStringLiteralMany32 state);

  def scanStringLiteralMany32 : StringLiteralScanState -> StringLiteralScanState =
    λ(state : StringLiteralScanState) scanStringLiteralMany16 (scanStringLiteralMany16 state);

  def scanStringLiteralMany16 : StringLiteralScanState -> StringLiteralScanState =
    λ(state : StringLiteralScanState) scanStringLiteralMany8 (scanStringLiteralMany8 state);

  def scanStringLiteralMany8 : StringLiteralScanState -> StringLiteralScanState =
    λ(state : StringLiteralScanState) scanStringLiteralMany4 (scanStringLiteralMany4 state);

  def scanStringLiteralMany4 : StringLiteralScanState -> StringLiteralScanState =
    λ(state : StringLiteralScanState) scanStringLiteralMany2 (scanStringLiteralMany2 state);

  def scanStringLiteralMany2 : StringLiteralScanState -> StringLiteralScanState =
    λ(state : StringLiteralScanState) scanStringLiteralStep (scanStringLiteralStep state);

  def scanStringLiteralStep : StringLiteralScanState -> StringLiteralScanState =
    λ(state : StringLiteralScanState) case state of {
      StringLiteralScanDone token cursor -> StringLiteralScanDone token cursor;
      StringLiteralScanError diagnostic -> StringLiteralScanError diagnostic;
      StringLiteralScanState startLine startPrefix lexeme cursor -> case cursor of {
        SourceCursor sourceText lineNumber linePrefix -> case stringCharAtOption sourceText 0 of {
          None -> StringLiteralScanError (UnexpectedSourceText (cursorStart lineNumber linePrefix));
          Some _ -> case sourceStartsWith "\"" sourceText of {
            StringMatched ->
              StringLiteralScanDone
                (SourceSymbol
                  (cursorStart startLine startPrefix)
                  (cursorEnd lineNumber linePrefix "\"")
                  (stringAppend "string-literal:" (stringAppend lexeme "\"")))
                (SourceCursor (stringDrop sourceText 1) lineNumber (stringAppend linePrefix "\""));
            StringMismatch -> case sourceStartsWith "\n" sourceText of {
              StringMatched -> StringLiteralScanError (UnexpectedSourceText (cursorStart lineNumber linePrefix));
              StringMismatch ->
                StringLiteralScanState startLine startPrefix
                  (stringAppend lexeme (stringTake sourceText 1))
                  (SourceCursor (stringDrop sourceText 1) lineNumber (stringAppend linePrefix (stringTake sourceText 1)))
            }
          }
        }
      }
    };

  def finishStringLiteralScan : StringLiteralScanState -> LexStep =
    λ(state : StringLiteralScanState) case state of {
      StringLiteralScanDone token cursor -> LexStepOk token cursor;
      StringLiteralScanError diagnostic -> LexStepError diagnostic;
      StringLiteralScanState _ _ _ cursor -> case cursor of {
        SourceCursor _ lineNumber linePrefix -> LexStepError (UnexpectedSourceText (cursorStart lineNumber linePrefix))
      }
    };

  def identifierStartCharacters : String =
    "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz_";

  def identifierContinueCharacters : String =
    "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz_0123456789";

  def sourceCharIn : String -> String -> StringMatch =
    λ(characters : String) λ(sourceText : String) case stringCharAtOption sourceText 0 of {
      None -> StringMismatch;
      Some _ -> case stringIndexOf characters (stringTake sourceText 1) of {
        None -> StringMismatch;
        Some _ -> StringMatched
      }
    };

  def scanSourceToken : String -> String -> Int -> SourceCursor -> LexStep =
    λ(sourceLexeme : String) λ(tokenText : String) λ(width : Int) λ(cursor : SourceCursor)
      case cursor of {
        SourceCursor sourceText lineNumber linePrefix -> case sourceStartsWith sourceLexeme sourceText of {
          StringMatched ->
            LexStepOk
              (SourceSymbol (cursorStart lineNumber linePrefix) (cursorEnd lineNumber linePrefix sourceLexeme) tokenText)
              (SourceCursor (stringDrop sourceText width) lineNumber (stringAppend linePrefix sourceLexeme));
          StringMismatch -> LexStepError (UnexpectedSourceText lexerUnknownSpan)
        }
      };

  def cursorStart : String -> String -> String =
    λ(lineNumber : String) λ(linePrefix : String)
      stringAppend lineNumber (stringAppend ":" (stringFromInt (stringLength (stringAppend " " linePrefix))));

  def cursorEnd : String -> String -> String -> String =
    λ(lineNumber : String) λ(linePrefix : String) λ(sourceLexeme : String)
      stringAppend lineNumber
        (stringAppend ":"
          (stringFromInt (stringLength (stringAppend (stringAppend " " linePrefix) sourceLexeme))));

  def advanceTrivia : SourceCursor -> SourceCursor =
    λ(cursor : SourceCursor) skipTrivia64 cursor;

  def skipTrivia64 : SourceCursor -> SourceCursor =
    λ(cursor : SourceCursor) skipTrivia32 (skipTrivia32 cursor);

  def skipTrivia32 : SourceCursor -> SourceCursor =
    λ(cursor : SourceCursor) skipTrivia16 (skipTrivia16 cursor);

  def skipTrivia16 : SourceCursor -> SourceCursor =
    λ(cursor : SourceCursor) skipTrivia8 (skipTrivia8 cursor);

  def skipTrivia8 : SourceCursor -> SourceCursor =
    λ(cursor : SourceCursor) skipTrivia4 (skipTrivia4 cursor);

  def skipTrivia4 : SourceCursor -> SourceCursor =
    λ(cursor : SourceCursor) skipTrivia2 (skipTrivia2 cursor);

  def skipTrivia2 : SourceCursor -> SourceCursor =
    λ(cursor : SourceCursor) skipTriviaStep (skipTriviaStep cursor);

  def skipTriviaStep : SourceCursor -> SourceCursor =
    λ(cursor : SourceCursor) case cursor of {
      SourceCursor sourceText lineNumber linePrefix -> case sourceStartsWith " " sourceText of {
        StringMatched -> SourceCursor (stringDrop sourceText 1) lineNumber (stringAppend linePrefix " ");
        StringMismatch -> case sourceStartsWith "\n" sourceText of {
          StringMatched -> SourceCursor (stringDrop sourceText 1) (nextLineNumber lineNumber) "";
          StringMismatch -> case sourceStartsWith "\t" sourceText of {
            StringMatched -> SourceCursor (stringDrop sourceText 1) lineNumber (stringAppend linePrefix "\t");
            StringMismatch -> cursor
          }
        }
      }
    };

  def nextLineNumber : String -> String =
    λ(lineNumber : String) case stringExactMatch "1" lineNumber of {
      StringMatched -> "2";
      StringMismatch -> case stringExactMatch "2" lineNumber of {
        StringMatched -> "3";
        StringMismatch -> case stringExactMatch "3" lineNumber of {
          StringMatched -> "4";
          StringMismatch -> case stringExactMatch "4" lineNumber of {
            StringMatched -> "5";
            StringMismatch -> case stringExactMatch "5" lineNumber of {
              StringMatched -> "6";
              StringMismatch -> case stringExactMatch "6" lineNumber of {
                StringMatched -> "7";
                StringMismatch -> case stringExactMatch "7" lineNumber of {
                  StringMatched -> "8";
                  StringMismatch -> case stringExactMatch "8" lineNumber of {
                    StringMatched -> "9";
                    StringMismatch -> case stringExactMatch "9" lineNumber of {
                      StringMatched -> "10";
                      StringMismatch -> case stringExactMatch "10" lineNumber of {
                        StringMatched -> "11";
                        StringMismatch -> case stringExactMatch "11" lineNumber of {
                          StringMatched -> "12";
                          StringMismatch -> case stringExactMatch "12" lineNumber of {
                            StringMatched -> "13";
                            StringMismatch -> case stringExactMatch "13" lineNumber of {
                              StringMatched -> "14";
                              StringMismatch -> case stringExactMatch "14" lineNumber of {
                                StringMatched -> "15";
                                StringMismatch -> case stringExactMatch "15" lineNumber of {
                                  StringMatched -> "16";
                                  StringMismatch -> case stringExactMatch "16" lineNumber of {
                                    StringMatched -> "17";
                                    StringMismatch -> case stringExactMatch "17" lineNumber of {
                                      StringMatched -> "18";
                                      StringMismatch -> case stringExactMatch "18" lineNumber of {
                                        StringMatched -> "19";
                                        StringMismatch -> case stringExactMatch "19" lineNumber of {
                                          StringMatched -> "20";
                                          StringMismatch -> case stringExactMatch "20" lineNumber of {
                                            StringMatched -> "21";
                                            StringMismatch -> case stringExactMatch "21" lineNumber of {
                                              StringMatched -> "22";
                                              StringMismatch -> case stringExactMatch "22" lineNumber of {
                                                StringMatched -> "23";
                                                StringMismatch -> case stringExactMatch "23" lineNumber of {
                                                  StringMatched -> "24";
                                                  StringMismatch -> case stringExactMatch "24" lineNumber of {
                                                    StringMatched -> "25";
                                                    StringMismatch -> case stringExactMatch "25" lineNumber of {
                                                      StringMatched -> "26";
                                                      StringMismatch -> case stringExactMatch "26" lineNumber of {
                                                        StringMatched -> "27";
                                                        StringMismatch -> case stringExactMatch "27" lineNumber of {
                                                          StringMatched -> "28";
                                                          StringMismatch -> case stringExactMatch "28" lineNumber of {
                                                            StringMatched -> "29";
                                                            StringMismatch -> case stringExactMatch "29" lineNumber of {
                                                              StringMatched -> "30";
                                                              StringMismatch -> case stringExactMatch "30" lineNumber of {
                                                                StringMatched -> "31";
                                                                StringMismatch -> case stringExactMatch "31" lineNumber of {
                                                                  StringMatched -> "32";
                                                                  StringMismatch -> lineNumber
                                                                }
                                                              }
                                                            }
                                                          }
                                                        }
                                                      }
                                                    }
                                                  }
                                                }
                                              }
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    };

  def sourceStartsWith : String -> String -> StringMatch =
    λ(prefix : String) λ(sourceText : String)
      stringExactMatch prefix (stringTake sourceText (stringLength prefix));

  def stringExactMatch : String -> String -> StringMatch =
    λ(expected : String) λ(actual : String) case stringIndexOf actual expected of {
      None -> StringMismatch;
      Some _ -> case stringIndexOf expected actual of {
        None -> StringMismatch;
        Some _ -> StringMatched
      }
    };
}
