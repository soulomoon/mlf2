module ParserParityLexer export (LexerResult(..), tokenizeCompleteModule, nextLineNumber) {
  import Prelude exposing (Option(..), stringAppend, stringCharAtOption, stringDrop, stringFromInt, stringIndexOf, stringLength, stringTake);
  import ParserParityDiagnostic exposing (ParserDiagnostic(..));
  import ParserParitySource exposing (ParserSourceInput(..), ParserSourceSymbol(..), lexerUnknownSpan, sourceInputCons, sourceInputNil);
  import ParserParityToken exposing (ParserInput(..));

  data LexerResult =
      LexerOk : ParserInput -> LexerResult
    | LexerError : ParserDiagnostic -> LexerResult;

  data SourceCursor =
      SourceCursor : String -> String -> String -> SourceCursor;

  data LexStep =
      LexStepOk : ParserSourceSymbol -> SourceCursor -> LexStep
    | LexStepError : ParserDiagnostic -> LexStep;

  data LexerScanState =
      LexerScanState : ParserSourceInput -> SourceCursor -> LexerScanState
    | LexerScanDone : ParserSourceInput -> LexerScanState
    | LexerScanError : ParserDiagnostic -> LexerScanState;

  data IdentifierScanState =
      IdentifierScanState : String -> String -> String -> SourceCursor -> IdentifierScanState
    | IdentifierScanDone : ParserSourceSymbol -> SourceCursor -> IdentifierScanState;

  data StringLiteralScanState =
      StringLiteralScanState : String -> String -> String -> SourceCursor -> StringLiteralScanState
    | StringLiteralScanDone : ParserSourceSymbol -> SourceCursor -> StringLiteralScanState
    | StringLiteralScanError : ParserDiagnostic -> StringLiteralScanState;

  data ReverseState =
      ReverseState : ParserSourceInput -> ParserSourceInput -> ReverseState;

  data StringMatch =
      StringMatched : StringMatch
    | StringMismatch : StringMatch;

  def tokenizeCompleteModule : String -> LexerResult =
    λ(sourceText : String)
      finishScannedInput (scanMany256 (initialScanState sourceText));

  def initialSourceCursor : String -> SourceCursor =
    λ(sourceText : String) SourceCursor sourceText "1" "";

  def initialScanState : String -> LexerScanState =
    λ(sourceText : String)
      LexerScanState sourceInputNil (initialSourceCursor sourceText);

  def finishScannedInput : LexerScanState -> LexerResult =
    λ(state : LexerScanState) case state of {
      LexerScanDone reverseInput -> reverseScannedInput reverseInput;
      LexerScanError diagnostic -> LexerError diagnostic;
      LexerScanState _ _ -> LexerError (UnexpectedSourceText lexerUnknownSpan)
    };

  def reverseScannedInput : ParserSourceInput -> LexerResult =
    λ(reverseInput : ParserSourceInput)
      finishReverseInput (reverseMany256 (ReverseState reverseInput sourceInputNil));

  def finishReverseInput : ReverseState -> LexerResult =
    λ(state : ReverseState) case state of {
      ReverseState remainingInput forwardInput -> case remainingInput of {
        SourceInputNil -> LexerOk (ParserInput forwardInput);
        SourceInputCons _ _ -> LexerError (UnexpectedSourceText lexerUnknownSpan)
      }
    };

  def reverseMany256 : ReverseState -> ReverseState =
    λ(state : ReverseState) reverseMany128 (reverseMany128 state);

  def reverseMany128 : ReverseState -> ReverseState =
    λ(state : ReverseState) reverseMany64 (reverseMany64 state);

  def reverseMany64 : ReverseState -> ReverseState =
    λ(state : ReverseState) reverseMany32 (reverseMany32 state);

  def reverseMany32 : ReverseState -> ReverseState =
    λ(state : ReverseState) reverseMany16 (reverseMany16 state);

  def reverseMany16 : ReverseState -> ReverseState =
    λ(state : ReverseState) reverseMany8 (reverseMany8 state);

  def reverseMany8 : ReverseState -> ReverseState =
    λ(state : ReverseState) reverseMany4 (reverseMany4 state);

  def reverseMany4 : ReverseState -> ReverseState =
    λ(state : ReverseState) reverseMany2 (reverseMany2 state);

  def reverseMany2 : ReverseState -> ReverseState =
    λ(state : ReverseState) reverseStep (reverseStep state);

  def reverseStep : ReverseState -> ReverseState =
    λ(state : ReverseState) case state of {
      ReverseState remainingInput forwardInput -> case remainingInput of {
        SourceInputNil -> ReverseState remainingInput forwardInput;
        SourceInputCons token rest -> ReverseState rest (sourceInputCons token forwardInput)
      }
    };

  def scanMany256 : LexerScanState -> LexerScanState =
    λ(state : LexerScanState) scanMany128 (scanMany128 state);

  def scanMany128 : LexerScanState -> LexerScanState =
    λ(state : LexerScanState) scanMany64 (scanMany64 state);

  def scanMany64 : LexerScanState -> LexerScanState =
    λ(state : LexerScanState) scanMany32 (scanMany32 state);

  def scanMany32 : LexerScanState -> LexerScanState =
    λ(state : LexerScanState) scanMany16 (scanMany16 state);

  def scanMany16 : LexerScanState -> LexerScanState =
    λ(state : LexerScanState) scanMany8 (scanMany8 state);

  def scanMany8 : LexerScanState -> LexerScanState =
    λ(state : LexerScanState) scanMany4 (scanMany4 state);

  def scanMany4 : LexerScanState -> LexerScanState =
    λ(state : LexerScanState) scanMany2 (scanMany2 state);

  def scanMany2 : LexerScanState -> LexerScanState =
    λ(state : LexerScanState) scanStep (scanStep state);

  def scanStep : LexerScanState -> LexerScanState =
    λ(state : LexerScanState) case state of {
      LexerScanDone reverseInput -> LexerScanDone reverseInput;
      LexerScanError diagnostic -> LexerScanError diagnostic;
      LexerScanState reverseInput cursor -> scanActiveSource reverseInput (advanceTrivia cursor)
    };

  def scanActiveSource : ParserSourceInput -> SourceCursor -> LexerScanState =
    λ(reverseInput : ParserSourceInput) λ(cursor : SourceCursor)
      case cursor of {
        SourceCursor sourceText _ _ -> case stringCharAtOption sourceText 0 of {
          None -> LexerScanDone reverseInput;
          Some _ -> case scanKnownToken cursor of {
            LexStepOk token nextCursor -> LexerScanState (sourceInputCons token reverseInput) nextCursor;
            LexStepError diagnostic -> LexerScanError diagnostic
          }
        }
      };

  def scanKnownToken : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) scanKnownModule cursor;

  def scanKnownModule : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "module" "module" 6 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownExport cursor
    };

  def scanKnownExport : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "export" "export" 6 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownDef cursor
    };

  def scanKnownDef : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "def" "def" 3 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownType cursor
    };

  def scanKnownType : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "type" "type" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownFamily cursor
    };

  def scanKnownFamily : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "family" "family" 6 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownData cursor
    };

  def scanKnownData : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "data" "data" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownClass cursor
    };

  def scanKnownClass : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "class" "class" 5 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownDeriving cursor
    };

  def scanKnownDeriving : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "deriving" "deriving" 8 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownImport cursor
    };

  def scanKnownImport : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "import" "import" 6 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownExposing cursor
    };

  def scanKnownExposing : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "exposing" "exposing" 8 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownLet cursor
    };

  def scanKnownLet : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "let" "let" 3 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownInstance cursor
    };

  def scanKnownInstance : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "instance" "instance" 8 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownIn cursor
    };

  def scanKnownIn : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "in" "in" 2 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownCase cursor
    };

  def scanKnownCase : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "case" "case" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownOf cursor
    };

  def scanKnownOf : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "of" "of" 2 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownWhere cursor
    };

  def scanKnownWhere : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "where" "where" 5 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownTrue cursor
    };

  def scanKnownTrue : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "true" "bool:true" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownFalse cursor
    };

  def scanKnownFalse : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "false" "bool:false" 5 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownArrow cursor
    };

  def scanKnownArrow : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "->" "->" 2 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownConstraintArrow cursor
    };

  def scanKnownConstraintArrow : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "=>" "=>" 2 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownFundepArrow cursor
    };

  def scanKnownFundepArrow : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "→" "→" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownMainModule cursor
    };

  def scanKnownMainModule : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Main" "identifier:Main" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownPrelude cursor
    };

  def scanKnownPrelude : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Prelude" "identifier:Prelude" 7 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownCore cursor
    };

  def scanKnownCore : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Core" "identifier:Core" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownUserModule cursor
    };

  def scanKnownUserModule : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "User" "identifier:User" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownCharType cursor
    };

  def scanKnownCharType : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Char" "identifier:Char" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownStringType cursor
    };

  def scanKnownStringType : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "String" "identifier:String" 6 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownModuleAliasC cursor
    };

  def scanKnownModuleAliasC : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "C" "identifier:C" 1 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownTokenType cursor
    };

  def scanKnownTokenType : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Token" "identifier:Token" 5 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownBool cursor
    };

  def scanKnownBool : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Bool" "identifier:Bool" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownBox cursor
    };

  def scanKnownBox : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Box" "identifier:Box" 3 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownEqType cursor
    };

  def scanKnownEqType : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Eq" "identifier:Eq" 2 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownMonoid cursor
    };

  def scanKnownMonoid : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Monoid" "identifier:Monoid" 6 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownFunctor cursor
    };

  def scanKnownFunctor : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Functor" "identifier:Functor" 7 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownHigher cursor
    };

  def scanKnownHigher : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Higher" "identifier:Higher" 6 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownMonad cursor
    };

  def scanKnownMonad : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Monad" "identifier:Monad" 5 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownIO cursor
    };

  def scanKnownIO : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "IO" "identifier:IO" 2 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownNormalize cursor
    };

  def scanKnownNormalize : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Normalize" "identifier:Normalize" 9 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownApplyType cursor
    };

  def scanKnownApplyType : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Apply" "identifier:Apply" 5 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownInt cursor
    };

  def scanKnownInt : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Int" "identifier:Int" 3 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownNat cursor
    };

  def scanKnownNat : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Nat" "identifier:Nat" 3 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownZero cursor
    };

  def scanKnownZero : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Zero" "identifier:Zero" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownSucc cursor
    };

  def scanKnownSucc : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Succ" "identifier:Succ" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownExpr cursor
    };

  def scanKnownExpr : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Expr" "identifier:Expr" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownSomeExpr cursor
    };

  def scanKnownSomeExpr : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "SomeExpr" "identifier:SomeExpr" 8 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownDoneNat cursor
    };

  def scanKnownDoneNat : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "DoneNat" "identifier:DoneNat" 7 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownStep cursor
    };

  def scanKnownStep : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Step" "identifier:Step" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownZeroValue cursor
    };

  def scanKnownZeroValue : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "zero" "identifier:zero" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownSuccValue cursor
    };

  def scanKnownSuccValue : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "succ" "identifier:succ" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownMainValue cursor
    };

  def scanKnownMainValue : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "main" "identifier:main" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownDoneNow cursor
    };

  def scanKnownDoneNow : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "doneNow" "identifier:doneNow" 7 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownUnwrapSome cursor
    };

  def scanKnownUnwrapSome : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "unwrapSome" "identifier:unwrapSome" 10 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownExprValue cursor
    };

  def scanKnownExprValue : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "expr" "identifier:expr" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownId cursor
    };

  def scanKnownId : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "id" "identifier:id" 2 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownTwoName cursor
    };

  def scanKnownTwoName : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "two" "identifier:two" 3 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownAnswer cursor
    };

  def scanKnownAnswer : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "answer" "identifier:answer" 6 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownEqMethod cursor
    };

  def scanKnownEqMethod : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "eq" "identifier:eq" 2 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownMempty cursor
    };

  def scanKnownMempty : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "mempty" "identifier:mempty" 6 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownAppend cursor
    };

  def scanKnownAppend : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "append" "identifier:append" 6 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownMap cursor
    };

  def scanKnownMap : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "map" "identifier:map" 3 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownBind cursor
    };

  def scanKnownBind : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "bind" "identifier:bind" 4 cursor of {
      LexStepOk token nextCursor -> LexStepOk token nextCursor;
      LexStepError _ -> scanKnownWrap cursor
    };

  def scanKnownWrap : SourceCursor -> LexStep =
    λ(cursor : SourceCursor) case scanSourceToken "Wrap" "identifier:Wrap" 4 cursor of {
