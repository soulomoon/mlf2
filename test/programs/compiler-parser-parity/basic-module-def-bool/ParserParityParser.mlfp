module ParserParityParser export (ParserDiagnosticKind(..), ParserDiagnostic(..), ParserResult(..), parseBasicModuleDefinition, renderParserParityEvidence, renderParserParityRetryEvidence) {
  import Prelude exposing (stringAppend);
  import ParserParityAst exposing (ParsedProgram(..), ParsedModule(..), ParsedExport(..), ParsedDef(..), ParsedType(..), ParsedExpr(..), renderParsedProgram);
  import ParserParitySource exposing (SourceSpan, basicModuleSourceFile, basicModuleSourceText, lexerMismatchSourceText, moduleSpan, moduleKeywordSpan, moduleNameSpan, exportKeywordSpan, exportLeftParenSpan, exportMainSpan, exportRightParenSpan, moduleLeftBraceSpan, defKeywordSpan, defNameSpan, defColonSpan, boolTypeSpan, boolLiteralSpan, defSemicolonSpan, moduleRightBraceSpan, defMainSpan, renderSpan);
  import ParserParityToken exposing (ModuleKeywordToken(..), ModuleNameToken(..), ExportKeywordToken(..), ExportLeftParenToken(..), ExportMainToken(..), ExportRightParenToken(..), ModuleLeftBraceToken(..), DefKeywordToken(..), DefNameToken(..), DefColonToken(..), BoolTypeToken(..), EqualsToken(..), BoolLiteralToken(..), DefSemicolonToken(..), ModuleRightBraceToken(..), HeaderPrefixTokens(..), HeaderSuffixTokens(..), DefPrefixTokens(..), DefSuffixTokens(..), TokenStream(..), LexerResult(..), LexerDiagnostic(..), LexerDiagnosticKind(..), tokenizeBasicModuleDefinition, renderTokenPrefixEvidence);

  data ParserDiagnosticKind =
      ExpectedBasicModule : ParserDiagnosticKind
    | ExpectedEquals : ParserDiagnosticKind;

  data ParserDiagnostic =
      ParserDiagnostic : SourceSpan -> ParserDiagnosticKind -> ParserDiagnostic;

  data ParserResult =
      ParserOk : ParsedProgram -> ParserResult
    | ParserError : ParserDiagnostic -> ParserResult;

  data ParserStep =
      ParserStepOk : ParserStep
    | ParserStepError : ParserDiagnostic -> ParserStep;

  def parseBasicModuleDefinition : String -> ParserResult =
    λ(source : String) case tokenizeBasicModuleDefinition source of {
      LexerOk tokens -> parseTokens tokens;
      LexerError diagnostic -> case diagnostic of {
        LexerDiagnostic span _ -> ParserError (ParserDiagnostic span ExpectedBasicModule)
      }
    };

  def parseTokens : TokenStream -> ParserResult =
    λ(tokens : TokenStream) case tokens of {
      TokenStream headerPrefix headerSuffix defPrefix defSuffix finalToken ->
        case parseHeaderPrefix headerPrefix of {
          ParserStepOk -> case parseHeaderSuffix headerSuffix of {
            ParserStepOk -> case parseDefPrefix defPrefix of {
              ParserStepOk -> case parseDefSuffix defSuffix of {
                ParserStepOk -> parseFinalToken finalToken;
                ParserStepError err -> ParserError err
              };
              ParserStepError err -> ParserError err
            };
            ParserStepError err -> ParserError err
          };
          ParserStepError err -> ParserError err
        }
    };

  def parseHeaderPrefix : HeaderPrefixTokens -> ParserStep =
    λ(tokens : HeaderPrefixTokens) case tokens of {
      HeaderPrefixTokens moduleToken moduleNameToken exportToken ->
        case moduleToken of {
          ModuleKeywordTok _ -> case moduleNameToken of {
            ModuleNameTok _ -> case exportToken of {
              ExportKeywordTok _ -> ParserStepOk
            }
          }
        }
    };

  def parseHeaderSuffix : HeaderSuffixTokens -> ParserStep =
    λ(tokens : HeaderSuffixTokens) case tokens of {
      HeaderSuffixTokens leftParenToken exportMainToken rightParenToken leftBraceToken ->
        case leftParenToken of {
          ExportLeftParenTok _ -> case exportMainToken of {
            ExportMainTok _ -> case rightParenToken of {
              ExportRightParenTok _ -> case leftBraceToken of {
                ModuleLeftBraceTok _ -> ParserStepOk
              }
            }
          }
        }
    };

  def parseDefPrefix : DefPrefixTokens -> ParserStep =
    λ(tokens : DefPrefixTokens) case tokens of {
      DefPrefixTokens defToken defNameToken colonToken boolToken ->
        case defToken of {
          DefKeywordTok _ -> case defNameToken of {
            DefNameTok _ -> case colonToken of {
              DefColonTok _ -> case boolToken of {
                BoolTypeTok _ -> ParserStepOk
              }
            }
          }
        }
    };

  def parseDefSuffix : DefSuffixTokens -> ParserStep =
    λ(tokens : DefSuffixTokens) case tokens of {
      DefSuffixTokens equalsToken boolLiteralToken semicolonToken ->
        case equalsToken of {
          EqualsTok _ -> case boolLiteralToken of {
            BoolLiteralTok _ -> case semicolonToken of {
              DefSemicolonTok _ -> ParserStepOk
            }
          };
          UnexpectedTrueInEqualsSlot span -> ParserStepError (ParserDiagnostic span ExpectedEquals)
        }
    };

  def parseFinalToken : ModuleRightBraceToken -> ParserResult =
    λ(token : ModuleRightBraceToken) case token of {
      ModuleRightBraceTok _ -> parsedBasicModule
    };

  def parsedBasicModule : ParserResult =
    ParserOk
      (ParsedProgram
        (ParsedModule "Main" moduleSpan
          (ParsedExportValue "main" exportMainSpan)
          (ParsedDef "main" ParsedTypeBool ParsedExprTrue defMainSpan)));

  def parserMismatchTokens : TokenStream =
    TokenStream
      (HeaderPrefixTokens
        (ModuleKeywordTok moduleKeywordSpan)
        (ModuleNameTok moduleNameSpan)
        (ExportKeywordTok exportKeywordSpan))
      (HeaderSuffixTokens
        (ExportLeftParenTok exportLeftParenSpan)
        (ExportMainTok exportMainSpan)
        (ExportRightParenTok exportRightParenSpan)
        (ModuleLeftBraceTok moduleLeftBraceSpan))
      (DefPrefixTokens
        (DefKeywordTok defKeywordSpan)
        (DefNameTok defNameSpan)
        (DefColonTok defColonSpan)
        (BoolTypeTok boolTypeSpan))
      (DefSuffixTokens
        (UnexpectedTrueInEqualsSlot boolLiteralSpan)
        (BoolLiteralTok boolLiteralSpan)
        (DefSemicolonTok defSemicolonSpan))
      (ModuleRightBraceTok moduleRightBraceSpan);

  def renderParserParityEvidence : String =
    case parseBasicModuleDefinition basicModuleSourceText of {
      ParserOk program -> renderParsedProgram basicModuleSourceFile program;
      ParserError _ -> "parser-error"
    };

  def renderParserParityRetryEvidence : String =
    stringAppend renderPositiveTokenEvidence
      (stringAppend "\n"
        (stringAppend renderLexerNegativeEvidence
          (stringAppend "\n" renderParserNegativeEvidence)));

  def renderPositiveTokenEvidence : String =
    case tokenizeBasicModuleDefinition basicModuleSourceText of {
      LexerOk tokens -> renderTokenPrefixEvidence tokens;
      LexerError _ -> "tokens mismatch"
    };

  def renderLexerNegativeEvidence : String =
    case tokenizeBasicModuleDefinition lexerMismatchSourceText of {
      LexerOk _ -> "lexer negative mismatch";
      LexerError diagnostic -> case diagnostic of {
        LexerDiagnostic span kind -> case kind of {
          UnexpectedSourceText -> stringAppend "lexer negative unexpected-source@" (renderSpan basicModuleSourceFile span)
        }
      }
    };

  def renderParserNegativeEvidence : String =
    case parseTokens parserMismatchTokens of {
      ParserOk _ -> "parser negative mismatch";
      ParserError diagnostic -> case diagnostic of {
        ParserDiagnostic span kind -> case kind of {
          ExpectedEquals -> stringAppend "parser negative expected-equals@" (renderSpan basicModuleSourceFile span);
          ExpectedBasicModule -> "parser negative mismatch"
        }
      }
    };
}
