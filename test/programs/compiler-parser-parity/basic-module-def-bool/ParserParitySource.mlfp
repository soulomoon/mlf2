module ParserParitySource export (SourceSpan(..), SourceCursor(..), basicModuleSourceFile, basicModuleSourceText, lexerMismatchSourceText, moduleSpan, moduleKeywordSpan, moduleNameSpan, exportKeywordSpan, exportLeftParenSpan, exportMainSpan, exportRightParenSpan, moduleLeftBraceSpan, defKeywordSpan, defNameSpan, defColonSpan, boolTypeSpan, defEqualsSpan, boolLiteralSpan, defSemicolonSpan, moduleRightBraceSpan, defMainSpan, unexpectedSpan, renderSpan) {
  import Prelude exposing (stringAppend);

  data SourceSpan =
      SourceSpan : String -> SourceSpan;

  data SourceCursor =
      SourceCursor : String -> SourceCursor;

  def basicModuleSourceFile : String =
    "test/conformance/mlfp/parser-parity/basic-module-def-bool/src/Main.mlfp";

  def basicModuleSourceText : String =
    "module Main export (main) {\n  def main : Bool = true;\n}\n";

  def lexerMismatchSourceText : String =
    "module Main exxort (main) {\n  def main : Bool = true;\n}\n";

  def moduleSpan : SourceSpan =
    SourceSpan "1:1-4:1";

  def moduleKeywordSpan : SourceSpan =
    SourceSpan "1:1-1:7";

  def moduleNameSpan : SourceSpan =
    SourceSpan "1:8-1:12";

  def exportKeywordSpan : SourceSpan =
    SourceSpan "1:13-1:19";

  def exportLeftParenSpan : SourceSpan =
    SourceSpan "1:20-1:21";

  def exportMainSpan : SourceSpan =
    SourceSpan "1:21-1:25";

  def exportRightParenSpan : SourceSpan =
    SourceSpan "1:25-1:26";

  def moduleLeftBraceSpan : SourceSpan =
    SourceSpan "1:27-1:28";

  def defKeywordSpan : SourceSpan =
    SourceSpan "2:3-2:6";

  def defNameSpan : SourceSpan =
    SourceSpan "2:7-2:11";

  def defColonSpan : SourceSpan =
    SourceSpan "2:12-2:13";

  def boolTypeSpan : SourceSpan =
    SourceSpan "2:14-2:18";

  def defEqualsSpan : SourceSpan =
    SourceSpan "2:19-2:20";

  def boolLiteralSpan : SourceSpan =
    SourceSpan "2:21-2:25";

  def defSemicolonSpan : SourceSpan =
    SourceSpan "2:25-2:26";

  def moduleRightBraceSpan : SourceSpan =
    SourceSpan "3:1-3:2";

  def defMainSpan : SourceSpan =
    SourceSpan "2:3-3:1";

  def unexpectedSpan : SourceSpan =
    SourceSpan "1:1-1:1";

  def renderSpan : String -> SourceSpan -> String =
    λ(file : String) λ(span : SourceSpan) case span of {
      SourceSpan coordinates -> stringAppend file (stringAppend ":" coordinates)
    };
}
