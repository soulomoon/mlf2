{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "problem_statement",
    "thesis_alignment",
    "root_cause",
    "exact_files_to_modify",
    "step_by_step_tasks",
    "tests_and_commands",
    "acceptance_criteria",
    "abort_criteria",
    "good_enough_definition"
  ],
  "properties": {
    "problem_statement": {"type": "string"},
    "thesis_alignment": {"type": "string"},
    "root_cause": {"type": "string"},
    "exact_files_to_modify": {"type": "array", "items": {"type": "string"}},
    "step_by_step_tasks": {"type": "array", "items": {"type": "string"}},
    "tests_and_commands": {"type": "array", "items": {"type": "string"}},
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
    "abort_criteria": {"type": "array", "items": {"type": "string"}},
    "good_enough_definition": {"type": "string"}
  }
}
