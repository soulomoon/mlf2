  "directions": [
    {
      "direction_id": "direction-1a-evidence-ledger-alignment",
      "milestone_id": "milestone-1",
      "summary": "Verify and align the readiness ledger, glossary, and docs against the full self-boot ADR order.",
      "preconditions": ["inspect readiness ledger, CONTEXT, README, accepted 2026-05-18 ADRs, and current seed/package evidence"],
      "parallel_hints": "serial setup"
    },
    {
      "direction_id": "direction-2a-conformance-corpus-migration",
      "milestone_id": "milestone-2",
      "summary": "Create the shared conformance corpus and migrate public .mlfp behavior fixtures into it.",
      "preconditions": ["milestone-1 complete", "inspect current fixtures, CLI tests, package-mode tests, and diagnostics"],
      "parallel_hints": "serial until metadata and expected-output meaning are stable"
    },
    {
      "direction_id": "direction-3a-broad-string-char-substrate",
      "milestone_id": "milestone-3",
      "summary": "Add native-capable Unicode scalar Char and broad String operations required before source-text parser parity.",
      "preconditions": ["conformance corpus stable enough to cover public behavior", "inspect Prelude, seed gaps, backend/native text lowering, and runtime representation"],
      "parallel_hints": "serial with parser parity until text substrate is native proven"
    },
    {
      "direction_id": "direction-4a-canonical-parser-parity",
      "milestone_id": "milestone-4",
      "summary": "Implement full canonical .mlfp parser parity on the broad text substrate.",
      "preconditions": ["milestone-3 complete", "parser-relevant conformance fixtures available"],
      "parallel_hints": "serial with text substrate"
    },
    {
      "direction_id": "direction-5a-platform-contract-substrate",
      "milestone_id": "milestone-5",
      "summary": "Implement stable ABI, runtime/GC/FFI, substrate declarations, bindings, locks, manifests, toolchain, link/native records, and ambient-input contracts.",
      "preconditions": ["milestone-2 complete", "milestone-3 complete enough for compiler frontend native workload"],
      "parallel_hints": "serial vertical slices; avoid concurrent ABI/runtime edits without explicit ownership"
    },
    {
      "direction_id": "direction-6a-compiler-package-semantics",
      "milestone_id": "milestone-6",
      "summary": "Build the compiler source package in .mlfp under the compiler-semantics boundary.",
      "preconditions": ["milestone-4 complete", "milestone-5 complete enough for compiler package inputs and substrate use"],
      "parallel_hints": "likely serial by compiler phase until phase interfaces are stable"
    },
    {
      "direction_id": "direction-7a-first-driver-modes",
      "milestone_id": "milestone-7",
      "summary": "Implement the first check, emit-backend, emit-native, and run-conformance driver modes over explicit local manifests and checked locks.",
      "preconditions": ["milestone-6 complete enough for selected driver modes"],
      "parallel_hints": "serial by command mode unless manifests and compiler package boundaries are stable"
    },
    {
      "direction_id": "direction-8a-conformance-first-stage-sequence",
      "milestone_id": "milestone-8",
      "summary": "Run and harden the two-stage proof sequence, conformance-first gate, proof manifest, and normalized semantic artifact comparison.",
      "preconditions": ["milestone-7 complete", "shared conformance and substrate ABI conformance pass for both stages"],
      "parallel_hints": "proof execution is serial; failure investigation follows proof failure taxonomy"
    }
  ],
